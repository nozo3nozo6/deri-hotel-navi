# ===== セキュリティ設定 =====

# .git ディレクトリへのアクセス遮断
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^\.git - [F,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# .env ファイルへのアクセス遮断
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# 機密ファイルへのアクセス遮断（設定ファイル、バックアップ等）
<FilesMatch "\.(sql|bak|log|ini|sh|yml|yaml|json\.bak|db-config\.php)$">
    Require all denied
</FilesMatch>

# README/CLAUDE.md 等へのアクセス遮断
<FilesMatch "^(README|CLAUDE|HANDOFF|PROPOSAL).*\.(md|txt)$">
    Require all denied
</FilesMatch>

# package.json, db-local.js 等の開発ファイルへのアクセス遮断
# ng-words.json は admin-api 経由でのみアクセス可能（直接アクセス遮断）
<FilesMatch "^(package\.json|package-lock\.json|ng-words\.json|db-local\.js|vitest\.config\..*)$">
    Require all denied
</FilesMatch>
<FilesMatch "^db\.php$">
    Require all denied
</FilesMatch>

# ディレクトリリスティング無効
Options -Indexes

# セキュリティヘッダー
<IfModule mod_headers.c>
    # HSTS（HTTPS強制、1年間）
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    # MIMEタイプ推測防止
    Header always set X-Content-Type-Options "nosniff"
    # クリックジャッキング防止
    Header always set X-Frame-Options "SAMEORIGIN"
    # XSS保護
    Header always set X-XSS-Protection "1; mode=block"
    # Referrer制御
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ===== 基本設定 =====
AddDefaultCharset UTF-8
DirectoryIndex index.html
RewriteEngine On
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ===== 静的ページ クリーンURL =====
# /contact/ → contact.html, /terms/ → terms.html 等
RewriteRule ^contact/?$ /contact.html [L]
RewriteRule ^terms/?$ /terms.html [L]
RewriteRule ^privacy/?$ /privacy.html [L]
RewriteRule ^legal/?$ /legal.html [L]
RewriteRule ^plan/?$ /plan.html [L]
RewriteRule ^shop-register/?$ /shop-register.html [L]

# 旧 .html URL → クリーンURL 301リダイレクト（ブラウザ直接リクエスト時のみ）
RewriteCond %{THE_REQUEST} \s/contact\.html [NC]
RewriteRule ^contact\.html$ /contact/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/terms\.html [NC]
RewriteRule ^terms\.html$ /terms/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/privacy\.html [NC]
RewriteRule ^privacy\.html$ /privacy/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/legal\.html [NC]
RewriteRule ^legal\.html$ /legal/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/plan\.html [NC]
RewriteRule ^plan\.html$ /plan/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/shop-register\.html [NC]
RewriteRule ^shop-register\.html$ /shop-register/ [R=301,L]

# ===== サブディレクトリ方式 URL ルーティング =====
# deli=men, jofu=women, same-m=men_same, same-f=women_same, este=este

# ホテル詳細クリーンURL: /deli/hotel/29599 → portal-men.html?hotel=29599
RewriteRule ^deli/hotel/([0-9]+)/?$ /portal-men.html?hotel=$1 [L,QSA]
RewriteRule ^jofu/hotel/([0-9]+)/?$ /portal-women.html?hotel=$1 [L,QSA]
RewriteRule ^same-m/hotel/([0-9]+)/?$ /portal-men-same.html?hotel=$1 [L,QSA]
RewriteRule ^same-f/hotel/([0-9]+)/?$ /portal-women-same.html?hotel=$1 [L,QSA]
RewriteRule ^este/hotel/([0-9]+)/?$ /portal-este.html?hotel=$1 [L,QSA]

# 店舗専用URL: /deli/shop/slug/ → portal-men.html?shop=slug
RewriteRule ^deli/shop/([a-z0-9\-]+)/?$ /portal-men.html?shop=$1 [L,QSA]
RewriteRule ^jofu/shop/([a-z0-9\-]+)/?$ /portal-women.html?shop=$1 [L,QSA]
RewriteRule ^same-m/shop/([a-z0-9\-]+)/?$ /portal-men-same.html?shop=$1 [L,QSA]
RewriteRule ^same-f/shop/([a-z0-9\-]+)/?$ /portal-women-same.html?shop=$1 [L,QSA]
RewriteRule ^este/shop/([a-z0-9\-]+)/?$ /portal-este.html?shop=$1 [L,QSA]

# 旧?shop=UUID → 新パスへ301リダイレクト（slug解決はJS側）
# ※ slug解決が必要なためJS側で処理。htaccessではリダイレクトしない

# 旧 ?hotel=ID → /deli/hotel/ID 301リダイレクト（リライトルールより前に配置）
RewriteCond %{QUERY_STRING} (?:^|&)hotel=([0-9]+)(?:&|$)
RewriteRule ^deli/?$ /deli/hotel/%1? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)hotel=([0-9]+)(?:&|$)
RewriteRule ^jofu/?$ /jofu/hotel/%1? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)hotel=([0-9]+)(?:&|$)
RewriteRule ^same-m/?$ /same-m/hotel/%1? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)hotel=([0-9]+)(?:&|$)
RewriteRule ^same-f/?$ /same-f/hotel/%1? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)hotel=([0-9]+)(?:&|$)
RewriteRule ^este/?$ /este/hotel/%1? [R=301,L]

# 4セグメント: /deli/東京都/東京２３区内/渋谷/渋谷区 → portal-men.html (pref+area+detail+city)
RewriteRule ^deli/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-men.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]
RewriteRule ^jofu/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-women.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]
RewriteRule ^same-m/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-men-same.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]
RewriteRule ^same-f/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-women-same.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]
RewriteRule ^este/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-este.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]

# 3セグメント: /deli/東京都/東京２３区内/渋谷区 → portal-men.html (pref+area+city)
RewriteRule ^deli/([^/]+)/([^/]+)/([^/]+)$ /portal-men.html?pref=$1&area=$2&city=$3 [L,QSA]
RewriteRule ^jofu/([^/]+)/([^/]+)/([^/]+)$ /portal-women.html?pref=$1&area=$2&city=$3 [L,QSA]
RewriteRule ^same-m/([^/]+)/([^/]+)/([^/]+)$ /portal-men-same.html?pref=$1&area=$2&city=$3 [L,QSA]
RewriteRule ^same-f/([^/]+)/([^/]+)/([^/]+)$ /portal-women-same.html?pref=$1&area=$2&city=$3 [L,QSA]
RewriteRule ^este/([^/]+)/([^/]+)/([^/]+)$ /portal-este.html?pref=$1&area=$2&city=$3 [L,QSA]

# 2セグメント: /deli/東京都/渋谷区 or /deli/東京都/東京２３区内 → portal-men.html (pref+area, JS側でarea/city判別)
RewriteRule ^deli/([^/]+)/([^/]+)$ /portal-men.html?pref=$1&area=$2 [L,QSA]
RewriteRule ^jofu/([^/]+)/([^/]+)$ /portal-women.html?pref=$1&area=$2 [L,QSA]
RewriteRule ^same-m/([^/]+)/([^/]+)$ /portal-men-same.html?pref=$1&area=$2 [L,QSA]
RewriteRule ^same-f/([^/]+)/([^/]+)$ /portal-women-same.html?pref=$1&area=$2 [L,QSA]
RewriteRule ^este/([^/]+)/([^/]+)$ /portal-este.html?pref=$1&area=$2 [L,QSA]

# 1セグメント: /deli/東京都 → portal-men.html (pref)
RewriteRule ^deli/([^/]+)$ /portal-men.html?pref=$1 [L,QSA]
RewriteRule ^jofu/([^/]+)$ /portal-women.html?pref=$1 [L,QSA]
RewriteRule ^same-m/([^/]+)$ /portal-men-same.html?pref=$1 [L,QSA]
RewriteRule ^same-f/([^/]+)$ /portal-women-same.html?pref=$1 [L,QSA]
RewriteRule ^este/([^/]+)$ /portal-este.html?pref=$1 [L,QSA]

# 0セグメント: /deli/ → portal-men.html (トップ)
RewriteRule ^deli/?$ /portal-men.html [L,QSA]
RewriteRule ^jofu/?$ /portal-women.html [L,QSA]
RewriteRule ^same-m/?$ /portal-men-same.html [L,QSA]
RewriteRule ^same-f/?$ /portal-women-same.html [L,QSA]
RewriteRule ^este/?$ /portal-este.html [L,QSA]

# ===== 旧パス /men/ 等 → 新パス /deli/ 等 301リダイレクト =====
RewriteRule ^men/(.+)$ /deli/$1 [R=301,L]
RewriteRule ^men/?$ /deli/ [R=301,L]
RewriteRule ^women/(.+)$ /jofu/$1 [R=301,L]
RewriteRule ^women/?$ /jofu/ [R=301,L]
RewriteRule ^men-same/(.+)$ /same-m/$1 [R=301,L]
RewriteRule ^men-same/?$ /same-m/ [R=301,L]
RewriteRule ^women-same/(.+)$ /same-f/$1 [R=301,L]
RewriteRule ^women-same/?$ /same-f/ [R=301,L]

# ===== 旧クエリURL → 新URL 301リダイレクト =====
# portal.html?mode=men&pref=X&city=Y → /deli/X/Y (pref+cityを1つのCondでキャプチャ)
RewriteCond %{QUERY_STRING} (?:^|&)mode=men(?:&|$)
RewriteCond %{QUERY_STRING} pref=([^&]+).*&city=([^&]+)
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /deli/%1/%2? [R=301,L,NE]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women(?:&|$)
RewriteCond %{QUERY_STRING} pref=([^&]+).*&city=([^&]+)
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /jofu/%1/%2? [R=301,L,NE]
RewriteCond %{QUERY_STRING} (?:^|&)mode=men_same(?:&|$)
RewriteCond %{QUERY_STRING} pref=([^&]+).*&city=([^&]+)
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /same-m/%1/%2? [R=301,L,NE]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women_same(?:&|$)
RewriteCond %{QUERY_STRING} pref=([^&]+).*&city=([^&]+)
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /same-f/%1/%2? [R=301,L,NE]

# portal.html?mode=men&pref=X → /deli/X
RewriteCond %{QUERY_STRING} (?:^|&)mode=men(?:&|$)
RewriteCond %{QUERY_STRING} pref=([^&]+)
RewriteCond %{QUERY_STRING} !(^|&)city=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /deli/%1? [R=301,L,NE]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women(?:&|$)
RewriteCond %{QUERY_STRING} pref=([^&]+)
RewriteCond %{QUERY_STRING} !(^|&)city=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /jofu/%1? [R=301,L,NE]
RewriteCond %{QUERY_STRING} (?:^|&)mode=men_same(?:&|$)
RewriteCond %{QUERY_STRING} pref=([^&]+)
RewriteCond %{QUERY_STRING} !(^|&)city=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /same-m/%1? [R=301,L,NE]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women_same(?:&|$)
RewriteCond %{QUERY_STRING} pref=([^&]+)
RewriteCond %{QUERY_STRING} !(^|&)city=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /same-f/%1? [R=301,L,NE]

# portal.html?mode=men → /deli/
RewriteCond %{QUERY_STRING} (?:^|&)mode=men(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)pref=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /deli/? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)pref=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /jofu/? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=men_same(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)pref=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /same-m/? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women_same(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)pref=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /same-f/? [R=301,L]

# ===== 旧Astroリライト（フォールバック） =====
RewriteCond %{QUERY_STRING} (?:^|&)mode=men(?:&|$)
RewriteRule ^portal\.html$ /portal-men.html [L,QSA]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women(?:&|$)
RewriteRule ^portal\.html$ /portal-women.html [L,QSA]
RewriteCond %{QUERY_STRING} (?:^|&)mode=men_same(?:&|$)
RewriteRule ^portal\.html$ /portal-men-same.html [L,QSA]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women_same(?:&|$)
RewriteRule ^portal\.html$ /portal-women-same.html [L,QSA]

# セキュリティヘッダー
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip圧縮
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>

# HTMLはキャッシュしない（常に最新を配信）
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>
</IfModule>

# ブラウザキャッシュ（JS/CSS/画像は長期キャッシュ、キャッシュバスター?v=で無効化）
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
</IfModule>

# 静的JSONファイルのキャッシュ制御
# ※ ExpiresByType application/json はPHP APIのJSONレスポンスまでキャッシュするため使わない
<IfModule mod_headers.c>
  # マスタ/エリアデータ: adminで変更されるため短キャッシュ
  <FilesMatch "(master-data|area-data)\.json$">
    Header set Cache-Control "public, max-age=60"
  </FilesMatch>
  # その他の静的JSON: 1時間キャッシュ
  <FilesMatch "search-index\.json$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# ETag
FileETag MTime Size
