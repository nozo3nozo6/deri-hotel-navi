DirectoryIndex index.html
RewriteEngine On
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ===== サブディレクトリ方式 URL ルーティング =====
# /men/東京都/東京２３区内/渋谷/渋谷区 → portal-men.html (pref+area+detail+city)
RewriteRule ^men/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-men.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]
RewriteRule ^women/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-women.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]
RewriteRule ^men-same/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-men-same.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]
RewriteRule ^women-same/([^/]+)/([^/]+)/([^/]+)/([^/]+)$ /portal-women-same.html?pref=$1&area=$2&detail=$3&city=$4 [L,QSA]

# /men/東京都/東京２３区内/渋谷区 → portal-men.html (pref+area+city)
RewriteRule ^men/([^/]+)/([^/]+)/([^/]+)$ /portal-men.html?pref=$1&area=$2&city=$3 [L,QSA]
RewriteRule ^women/([^/]+)/([^/]+)/([^/]+)$ /portal-women.html?pref=$1&area=$2&city=$3 [L,QSA]
RewriteRule ^men-same/([^/]+)/([^/]+)/([^/]+)$ /portal-men-same.html?pref=$1&area=$2&city=$3 [L,QSA]
RewriteRule ^women-same/([^/]+)/([^/]+)/([^/]+)$ /portal-women-same.html?pref=$1&area=$2&city=$3 [L,QSA]

# /men/東京都 → portal-men.html (pref)
RewriteRule ^men/([^/]+)$ /portal-men.html?pref=$1 [L,QSA]
RewriteRule ^women/([^/]+)$ /portal-women.html?pref=$1 [L,QSA]
RewriteRule ^men-same/([^/]+)$ /portal-men-same.html?pref=$1 [L,QSA]
RewriteRule ^women-same/([^/]+)$ /portal-women-same.html?pref=$1 [L,QSA]

# /men/ → portal-men.html (トップ)
RewriteRule ^men/?$ /portal-men.html [L,QSA]
RewriteRule ^women/?$ /portal-women.html [L,QSA]
RewriteRule ^men-same/?$ /portal-men-same.html [L,QSA]
RewriteRule ^women-same/?$ /portal-women-same.html [L,QSA]

# ===== 旧URL → 新URL 301リダイレクト =====
# mode値→URLパスのマッピング: men→men, women→women, men_same→men-same, women_same→women-same

# portal.html?mode=men&pref=X&city=Y → /men/X/Y
RewriteCond %{QUERY_STRING} (?:^|&)mode=men(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)pref=([^&]+)(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)city=([^&]+)(?:&|$)
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /men/%1/%2? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)pref=([^&]+)(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)city=([^&]+)(?:&|$)
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /women/%1/%2? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=men_same(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)pref=([^&]+)(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)city=([^&]+)(?:&|$)
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /men-same/%1/%2? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women_same(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)pref=([^&]+)(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)city=([^&]+)(?:&|$)
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /women-same/%1/%2? [R=301,L]

# portal.html?mode=men&pref=X → /men/X
RewriteCond %{QUERY_STRING} (?:^|&)mode=men(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)pref=([^&]+)(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)city=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /men/%1? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)pref=([^&]+)(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)city=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /women/%1? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=men_same(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)pref=([^&]+)(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)city=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /men-same/%1? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women_same(?:&|$)
RewriteCond %{QUERY_STRING} (?:^|&)pref=([^&]+)(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)city=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /women-same/%1? [R=301,L]

# portal.html?mode=men → /men/
RewriteCond %{QUERY_STRING} (?:^|&)mode=men(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)pref=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /men/? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)pref=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /women/? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=men_same(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)pref=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /men-same/? [R=301,L]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women_same(?:&|$)
RewriteCond %{QUERY_STRING} !(^|&)pref=
RewriteRule ^portal(?:-[a-z-]+)?\.html$ /women-same/? [R=301,L]

# ===== 旧Astroリライト（フォールバック） =====
RewriteCond %{QUERY_STRING} (?:^|&)mode=men(?:&|$)
RewriteRule ^portal\.html$ /portal-men.html [L,QSA]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women(?:&|$)
RewriteRule ^portal\.html$ /portal-women.html [L,QSA]
RewriteCond %{QUERY_STRING} (?:^|&)mode=men_same(?:&|$)
RewriteRule ^portal\.html$ /portal-men-same.html [L,QSA]
RewriteCond %{QUERY_STRING} (?:^|&)mode=women_same(?:&|$)
RewriteRule ^portal\.html$ /portal-women-same.html [L,QSA]

# セキュリティヘッダー
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip圧縮
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>

# HTMLはキャッシュしない（常に最新を配信）
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>
</IfModule>

# ブラウザキャッシュ（JS/CSS/画像は長期キャッシュ、キャッシュバスター?v=で無効化）
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType application/json "access plus 1 hour"
</IfModule>

# ETag
FileETag MTime Size
