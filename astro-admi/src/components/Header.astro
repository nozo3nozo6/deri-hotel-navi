---
const TEL = '090-1045-9155';
const TEL_RAW = TEL.replace(/-/g, '');
---
<header class="fixed top-0 w-full z-50 bg-[var(--bg-0)]/85 backdrop-blur-xl border-b border-[var(--neon-pink)]/35">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex justify-between items-center gap-3">
    <a href="/" class="flex items-baseline gap-2.5 min-w-0" aria-label="アドミ 吉祥寺デリヘル トップ">
      <span class="font-script neon-pink-glow text-3xl md:text-4xl leading-none">Admi</span>
      <span class="hidden sm:block leading-tight">
        <span class="block text-[10px] md:text-xs tracking-[0.25em] text-[var(--lav-soft)] whitespace-nowrap">SINCE 2009</span>
        <span class="block text-[10px] md:text-xs text-[var(--text-mute)]">吉祥寺デリヘル</span>
      </span>
    </a>

    <a
      href={`tel:${TEL_RAW}`}
      class="glossy-pill shrink-0 flex items-center gap-2 px-4 md:px-5 py-2 md:py-2.5 rounded-full text-sm md:text-base font-bold text-white whitespace-nowrap"
      aria-label={`電話で問い合わせる ${TEL}`}
    >
      <span class="text-base" aria-hidden="true">📞</span>
      <span class="tracking-wide">{TEL}</span>
    </a>
  </div>
</header>
