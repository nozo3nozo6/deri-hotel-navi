---
// AssureTabs.astro — 安心バンド群を1枚のタブUIに統合（2026-07-09、タブ見た目化）。
//   1枚のカード上部にタブ列（👛お釣り｜🏨呼べる？…今後追加予定）、タップしたタブの内容だけ下に展開。
//   同じタブを再タップで閉じる（既定は全タブ閉じ＝省スペース）。見た目は「タブトレイに浮くタブ」方式:
//   非アクティブはタブトレイ(--bg-1)に沈み、アクティブは --bg-0 で浮き上がりパネルとシームレスに接続。
//   段落ごとY2Kカラー（hot pink / lavender / ホログラムグラデ）・両テーマ自動追従は従来のまま。
//   YobuHoボタンは SHOP.yobuhoUrl がある店舗のみ表示（kichifu は空＝非表示・後日設定）。
//   ※ 訪問者向けコピーは欧文クォート " を使わず 『』「」を使用（フロント規約）。
//   ※ スクリプトは Astro が外部モジュール化するため CSP inline 問題なし。
//   ※ タブを追加する場合: TABS配列に1件足す→下のpanels配列にも同じkeyで1件足すだけでOK
//     （.asr-tabはflex:1 1 0で均等割り、3〜4枚まではこのままレイアウトが破綻しない設計）。
import { SHOP } from '../lib/config';
const yobuhoUrl = SHOP.yobuhoUrl;

const TABS = [
  { key: 'care', icon: '👛', label: 'お釣りは<strong>その場で</strong>' },
  { key: 'hotel', icon: '🏨', label: 'その<strong>ホテル、呼べる？</strong>' },
];
---
<section class="asr-section" aria-label="当店のこだわり・ホテルのご相談">
  <div class="asr glass-card" data-asr-root>
    <div class="asr-tabs" role="tablist">
      {TABS.map((t) => (
        <button
          type="button"
          class="asr-tab"
          data-asr={t.key}
          role="tab"
          aria-selected="false"
          aria-expanded="false"
          aria-controls={`asr-panel-${t.key}`}
        >
          <span class="asr-tab-icon" aria-hidden="true">{t.icon}</span>
          <span class="asr-tab-label" set:html={t.label} />
        </button>
      ))}
    </div>

    <div class="asr-panel" id="asr-panel-care" data-asr-panel="care" hidden>
      <p>当店では女の子がお釣り用のお札と小銭を持参し、お会計はその場で完了します。『お釣りはドライバーが帰りに』という待ち時間も、お金のやり取りの気まずさもございません。</p>
      <p>これは、お客様に余計なご不安やお気遣いをおかけしないため。そして、スムーズにスケジュールを進行することで、以降のご予約のお客様をお待たせせず、女の子が一人でも多くの方とお会いするための心づかいでもあります。</p>
      <p>ドライバーへの現金お支払いにまつわるトラブルのご心配もなく、安心してお楽しみいただけます。細かなところまで丁寧に——それがアドミのおもてなしです ♡</p>
    </div>

    <div class="asr-panel" id="asr-panel-hotel" data-asr-panel="hotel" hidden>
      <p>数えきれないご案内の一件ずつが、アドミのホテル情報になっています。『直通で行けるホテル』『お迎えが必要なホテル』『フロントNGのホテル』——地域ごとの最新事情を日々把握し、更新し続けています。だから『あのホテル、呼べる？』に、その場ではっきりお答えできます。</p>
      <p>ホテルによっては、手配したあとで『実は呼べなかった』とわかることも。思わぬキャンセル料が発生してしまう場合もあるようです。そうならないための『呼ぶ前のひと確認』を、どうぞお役立てください。</p>
      <p>ご利用のあるなしにかかわらず、『このホテルは大丈夫？』のご質問だけでも大歓迎。お迎えの要否やお部屋までの行き方まで、どうぞお気軽にお問い合わせください。</p>
      {yobuhoUrl && (
        <div class="asr-cta-wrap">
          <a class="asr-cta" href={yobuhoUrl} target="_self" rel="noopener">
            <span aria-hidden="true">🏨</span>ホテル検索は<span class="asr-cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      )}
    </div>
  </div>
</section>
<script>
  // タブ開閉（排他アコーディオン）。同じタブ再タップで閉じる。Astroが外部モジュール化。
  const root = document.querySelector('[data-asr-root]');
  if (root) {
    const tabs = root.querySelectorAll<HTMLButtonElement>('.asr-tab');
    const panels = root.querySelectorAll<HTMLElement>('.asr-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.getAttribute('data-asr');
        const wasOpen = tab.classList.contains('is-open');
        tabs.forEach((t) => {
          t.classList.remove('is-open');
          t.setAttribute('aria-expanded', 'false');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach((p) => { p.hidden = true; });
        if (!wasOpen && key) {
          tab.classList.add('is-open');
          tab.setAttribute('aria-expanded', 'true');
          tab.setAttribute('aria-selected', 'true');
          const panel = root.querySelector<HTMLElement>(`[data-asr-panel="${key}"]`);
          if (panel) panel.hidden = false;
        }
      });
    });
  }
</script>
<style>
  .asr-section { padding: 8px 16px; position: relative; z-index: 1; }
  .asr {
    max-width: 660px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
  }
  /* ---- タブトレイ（非アクティブ=沈む／アクティブ=浮いてパネルと同化） ---- */
  .asr-tabs {
    display: flex;
    align-items: stretch;
    gap: 4px;
    padding: 7px 7px 0;
    background: var(--bg-1);
  }
  .asr-tab {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;   /* タイトル中央揃え（従来踏襲） */
    gap: 5px;
    padding: 10px 5px 11px;
    background: transparent;
    border: none;
    border-radius: 10px 10px 0 0;
    cursor: pointer;
    font-family: inherit;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    transition: background .15s ease, transform .15s ease;
  }
  .asr-tab::after {
    /* アクティブタブの下線バー（タブらしさの要） */
    content: '';
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 0;
    height: 3px;
    border-radius: 3px 3px 0 0;
    background: transparent;
    transition: background .15s ease;
  }
  .asr-tab.is-open {
    background: var(--bg-0);
    box-shadow: 0 -3px 10px -2px rgba(255, 79, 216, .22);
  }
  .asr-tab.is-open::after {
    background: linear-gradient(90deg, var(--neon-pink-hot), var(--lav-soft));
  }
  .asr-tab-icon {
    font-size: 1.2rem;
    line-height: 1;
    flex: 0 0 auto;
    opacity: .72;
    filter: drop-shadow(0 1px 4px rgba(255, 79, 216, .45));
    transition: opacity .15s ease;
  }
  .asr-tab.is-open .asr-tab-icon { opacity: 1; }
  .asr-tab-label {
    font-size: .78rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--text-mute);   /* 非アクティブは沈んだ色 */
    min-width: 0;
    white-space: nowrap;       /* 常時1行（はみ出す時のみ…） */
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color .15s ease;
  }
  .asr-tab.is-open .asr-tab-label { color: var(--text-soft); }
  .asr-tab-label strong { color: inherit; }
  .asr-tab.is-open .asr-tab-label strong { color: var(--neon-pink); }
  /* ---- 展開パネル（アクティブタブと同じ --bg-0 でシームレスに接続） ---- */
  .asr-panel {
    font-size: .86rem;
    line-height: 1.85;
    color: var(--text-mute);
    margin: 0;
    padding: 14px 16px 16px;
    background: var(--bg-0);
  }
  .asr-panel p { margin: 0; }
  .asr-panel p + p { margin-top: .85em; }
  /* 段落ごとのY2Kカラー（両テーマで可読な変数のみ使用） */
  .asr-panel p:nth-of-type(1) { color: var(--neon-pink-hot); font-weight: 600; }
  .asr-panel p:nth-of-type(2) { color: var(--lav-soft); font-weight: 600; }
  .asr-panel p:nth-of-type(3) {
    font-weight: 700;
    color: var(--neon-pink-hot);       /* clip未対応時のフォールバック */
    background: linear-gradient(90deg, var(--neon-pink-hot), var(--lav-soft) 55%, var(--neon-pink-hot));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  /* ---- 末尾CTA（YobuHo）。文字色は bg-0＝明→白系/暗→黒系で両テーマ可読 ---- */
  .asr-cta-wrap { text-align: center; margin-top: 14px; }
  .asr-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 22px;
    border-radius: 999px;
    background: var(--neon-pink-hot);
    color: var(--bg-0);
    font-weight: 800;
    font-size: .9rem;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(255, 79, 216, .38), inset 0 0 0 1px rgba(255, 255, 255, .18);
    transition: transform .15s ease, box-shadow .15s ease;
  }
  .asr-cta:hover { transform: translateY(-1px); box-shadow: 0 7px 22px rgba(255, 79, 216, .5); }
  .asr-cta-arrow { font-weight: 900; margin-left: 1px; }
  /* ---- 狭幅・PC調整 ---- */
  @media (max-width: 374px) {
    .asr-tab { gap: 4px; padding: 10px 4px 11px; }
    .asr-tab-label { font-size: .72rem; }
    .asr-tab-icon { font-size: 1.1rem; }
  }
  @media (min-width: 641px) {
    .asr-tab { gap: 8px; padding: 13px 12px 14px; }
    .asr-tab-icon { font-size: 1.45rem; }
    .asr-tab-label { font-size: .95rem; }
    .asr-panel { font-size: .94rem; padding: 16px 20px 18px; }
    .asr-cta { font-size: .96rem; padding: 11px 26px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .asr-tab, .asr-tab-icon, .asr-tab-label, .asr-tab::after, .asr-cta { transition: none; }
  }
</style>
