---
// Site.astro — 現行 _inc/head.php + _inc/layout.php を Astro に移植（site.css 再利用）
import { statSync } from 'node:fs';
import { SHOP, FUJOHO, SHOP_ID } from '../lib/config';

export interface Props {
  title: string;
  description: string;
  path?: string;       // 例: "/girls"
  ogImage?: string;
  hideBack?: boolean;
  gate?: boolean;      // 年齢認証ゲート(index)= ナビ/ハンバーガー/チャットを出さない（認証クリア後に top 以降へ）
}
const SITE = 'https://admi2888.com'; // 本番。biyobu(ステージング)も canonical はここ(prod)を指す＝SEO正
const IS_PROD = import.meta.env.PUBLIC_PROD === '1'; // admi2888本番ビルド(deploy-prod-admi2888.sh)時のみ true。biyobuは未設定=noindex/GA無し
const { title, description, path = '/', ogImage = `${SITE}/img/og-image.jpg`, hideBack = false, gate = false } = Astro.props;
const canonical = SITE + path;

// キャッシュバスター: site.css/js の mtime（Cloudflareが1年immutableキャッシュするため必須）
const ver = (f: string): string => { try { return String(Math.floor(statSync(f).mtimeMs)); } catch { return '1'; } };
const cssV = ver('public/site.css');
const jsV = ver('public/site.js');
const favV = ver('public/favicon.svg');
const gvV = ver('public/girl-visibility.js');
---
<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={IS_PROD ? 'index, follow' : 'noindex, nofollow'} />
<meta name="google-site-verification" content="ndAzGRDjDiq5WpKQxeQH7qhtel-QoPel6DV4FxwOifw" />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={SHOP.fullName} />
<meta name="twitter:card" content="summary_large_image" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=M+PLUS+Rounded+1c:wght@400;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href={`/site.css?v=${cssV}`} />
<link rel="icon" href={`/favicon.svg?v=${favV}`} type="image/svg+xml" />
<!-- GA: 本番(admi2888.com)のみ有効。biyobuステージングでは出さない（kichifu/GAを汚さない） -->
{IS_PROD && (
<>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-50Q48YG34Z"></script>
<script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-50Q48YG34Z');</script>
</>
)}
</head>
<body>
<header class="site-header">
  <div class="site-header-inner">
    <a href="/top" class="brand" aria-label={`${SHOP.fullName} トップ`}>
      <span class="brand-script flicker">{SHOP.nameEn}</span>
      <span class="brand-sub">
        <span class="brand-since">立川デリヘル</span>
        <span class="brand-genre">すけべな素人専門店</span>
        <span class="brand-catch">アドミ since2002</span>
      </span>
    </a>
    {!gate && (
    <nav class="site-nav">
      <a href="/top">トップ</a>
      <a href="/girls">すけべな女の子達</a>
      <a href={FUJOHO.schedule} target="_self" rel="noopener">スケジュール</a>
      <a href="/system">料金システム</a>
      <a href="/howto">ご利用ガイド</a>
      <a href="/news">お知らせ</a>
      <a href={FUJOHO.diary} target="_self" rel="noopener">写メ日記</a>
      <a href="https://yobuho.com/deli/shop/0tkzk670/" target="_self">🏨 ホテル検索</a>
      <a href={SHOP.recruitUrl} target="_self">求人情報</a>
      <a href="/contacts">お問合せ</a>
    </nav>
    )}
    <div class="header-tel">
      <div class="header-reception">受付 {SHOP.reception}</div>
      <a href={`tel:${SHOP.telRaw}`} class="header-tel-num">📞 {SHOP.tel}</a>
    </div>
    <div class="reserve-stack">
      <span class="reserve-hours">営業時間</span>
      <span class="reserve-time">{SHOP.reception}</span>
      <button type="button" class="glossy-pill reserve-btn" data-reserve-open>ご予約</button>
    </div>
    {!gate && (
    <button type="button" class="burger" data-menu-open aria-label="メニューを開く">
      <span></span><span></span><span></span>
    </button>
    )}
  </div>
</header>
<div class="header-spacer" aria-hidden="true"></div>

<slot />

{!hideBack && (
<div class="back-bar">
  <button type="button" class="back-bar-btn" onclick="history.back()">← 前へ戻る</button>
</div>
)}
<footer class="site-footer">
  <hr class="footer-top-divider" />
  <div class="footer-inner">
    <p class="footer-brand font-script neon-pink-glow flicker">{SHOP.nameEn}</p>
    <p class="footer-sub">since {SHOP.since} ・ {SHOP.catch} &amp; Go To FANTASY</p>
    <div class="footer-cta">
      <a href={`tel:${SHOP.telRaw}`} class="footer-cta-tel glossy-pill">📞 電話で予約</a>
      <a href={SHOP.lineUrl} target="_self" rel="noopener" class="footer-cta-line">💬 LINEで予約</a>
      <p class="footer-cta-note">💝 LINEのご予約で<span class="footer-cta-note-em">プレイ時間＋10分無料</span>！</p>
      <a href="https://yobuho.com/chat-sheet.html?slug=0tkzk670" target="_self" class="footer-cta-chat">💭 チャットで相談</a>
      <p class="footer-cta-chat-note">登録不要です！お気軽に。</p>
    </div>
    <p class="footer-reception">受付時間 {SHOP.reception}</p>
    <nav class="footer-links">
      <a href="/top">トップ</a>
      <a href="/girls">すけべな女の子達</a>
      <a href="/schedule" target="_self">スケジュール</a>
      <a href="/system">料金システム</a>
      <a href="/howto">ご利用ガイド</a>
      <a href="/news">お知らせ</a>
      <a href={FUJOHO.diary} target="_self" rel="noopener">写メ日記</a>
      <a href={SHOP.recruitUrl} target="_self">求人情報</a>
      <a href="/contacts">お問合せ</a>
    </nav>
    <p class="footer-copy">&copy; {SHOP.since}-{new Date().getFullYear()} {SHOP.fullName} All Rights Reserved.</p>
  </div>
</footer>

{!gate && (
<div class="offcanvas-overlay" data-menu-close></div>
)}
{!gate && (
<div class="offcanvas" id="offcanvas" role="navigation" aria-label="メニュー">
  <div class="offcanvas-head">
    <a href="/top" class="brand" aria-label={`${SHOP.fullName} トップ`}>
      <span class="brand-script flicker">{SHOP.nameEn}</span>
      <span class="brand-sub">
        <span class="brand-since">立川デリヘル</span>
        <span class="brand-genre">すけべな素人専門店</span>
        <span class="brand-catch">アドミ since2002</span>
      </span>
    </a>
    <button type="button" class="offcanvas-close" data-menu-close aria-label="閉じる">✕</button>
  </div>
  <nav class="offcanvas-nav">
    <a href="/top">トップ</a>
    <a href="/girls">すけべな女の子達</a>
    <a href={FUJOHO.schedule} target="_self" rel="noopener">スケジュール</a>
    <a href="/system">料金システム</a>
    <a href="/howto">ご利用ガイド</a>
    <a href="/news">お知らせ</a>
    <a href={FUJOHO.diary} target="_self" rel="noopener">写メ日記</a>
    <a href="https://yobuho.com/deli/shop/0tkzk670/" target="_self">🏨 ホテル検索</a>
    <a href={SHOP.recruitUrl} target="_self">求人情報</a>
    <a href="/contacts">お問合せ</a>
  </nav>
  <div class="offcanvas-foot">
    <button type="button" class="glossy-pill offcanvas-reserve-btn" data-reserve-open>ご予約はこちら</button>
    <a href={`tel:${SHOP.telRaw}`} class="offcanvas-tel-link">📞 {SHOP.tel}<br /><span class="text-mute">(受付 {SHOP.reception})</span></a>
  </div>
</div>
)}

<div class="modal-overlay" id="reserve-modal" role="dialog" aria-modal="true" aria-label="ご予約" aria-hidden="true">
  <div class="modal-box">
    <div class="modal-head">
      <p class="modal-title holo-text">ご予約方法をお選びください</p>
      <button type="button" class="modal-close" data-reserve-close aria-label="閉じる">✕</button>
    </div>
    <p class="modal-sub">お問い合わせだけでもお気軽にどうぞ♡</p>
    <div class="reserve-cards">
      <a href={`tel:${SHOP.telRaw}`} class="reserve-card">
        <span class="reserve-icon">📞</span>
        <span>
          <span class="reserve-label">TELで予約</span>
          <span class="reserve-note">明るく優しいスタッフが対応！</span>
        </span>
      </a>
      <a href={SHOP.lineUrl} target="_self" rel="noopener" class="reserve-card">
        <span class="reserve-icon">💬</span>
        <span>
          <span class="reserve-label">LINEで予約</span>
          <span class="reserve-note">ご予約でプレイ時間＋10分無料！</span>
        </span>
      </a>
      <a href="https://yobuho.com/chat-sheet.html?slug=0tkzk670" target="_self" class="reserve-card">
        <span class="reserve-icon">💭</span>
        <span>
          <span class="reserve-label">チャットで相談</span>
          <span class="reserve-note">登録不要です！お気軽に。</span>
        </span>
      </a>
    </div>
  </div>
</div>
{!gate && (
<a href="https://yobuho.com/chat-sheet.html?slug=0tkzk670" target="_self"
   class="admi-chat-fab" aria-label="チャットで相談">💬</a>
)}
<style is:global>
.admi-chat-fab {
  position: fixed;
  right: 16px;
  bottom: 16px;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff4fd8 0%, #ff9f79 35%, #ffe580 60%, #b78fff 100%);
  background-size: 200% 200%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  text-decoration: none;
  box-shadow: 0 0 12px rgba(255,79,216,.8), 0 0 28px rgba(183,143,255,.5);
  z-index: 2147483646;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  animation: admi-chat-glow 2.4s ease-in-out infinite, admi-chat-gradient 4s linear infinite;
}
@keyframes admi-chat-gradient {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
@keyframes admi-chat-glow {
  0%, 100% { box-shadow: 0 0 12px rgba(255,79,216,.8), 0 0 28px rgba(183,143,255,.5); }
  50%       { box-shadow: 0 0 20px #ff4fd8, 0 0 40px rgba(255,79,216,.7), 0 0 60px rgba(183,143,255,.4); }
}
@media (prefers-reduced-motion: reduce) {
  .admi-chat-fab { animation: none; }
}
</style>
<script is:inline src={`/site.js?v=${jsV}`}></script>
<script is:inline define:vars={{ shopId: SHOP_ID }}>window.__SHOP_ID = shopId;</script>
<script is:inline src={`/girl-visibility.js?v=${gvV}`}></script>
</body>
</html>
