---
// Site.astro — 現行 _inc/head.php + _inc/layout.php を Astro に移植（site.css 再利用）
import { statSync } from 'node:fs';
import { SHOP, FUJOHO, SHOP_ID } from '../lib/config';

export interface Props {
  title: string;
  description: string;
  path?: string;       // 例: "/girls"
  ogImage?: string;
  hideBack?: boolean;
  gate?: boolean;      // 年齢認証ゲート(index)= ナビ/ハンバーガー/チャットを出さない（認証クリア後に top 以降へ）
  noindex?: boolean;   // 個別ページをnoindexにする（例: 写メ日記詳細=fujoho原典の転載でindex対象外、内部リンクはfollow）
}
const SITE = 'https://admi2888.com'; // 本番。biyobu(ステージング)も canonical はここ(prod)を指す＝SEO正
const IS_PROD = import.meta.env.PUBLIC_PROD === '1'; // admi2888本番ビルド(deploy-prod-admi2888.sh)時のみ true。biyobuは未設定=noindex/GA無し
const { title, description, path = '/', ogImage = `${SITE}/img/og-image.jpg`, hideBack = false, gate = false, noindex = false } = Astro.props;
const canonical = SITE + path;
// SEOキーワード（全ページ共通）。「おすすめ／オススメ」を含む立川デリヘル系の検索語を網羅。
// 複合KW（立川アドミ/アドミ立川・おすすめ語順両方・ひらがな/カタカナ）も明示（2026-07-03 語順SEO調査より）。
const keywords = `${SHOP.catch},${SHOP.area} デリヘル おすすめ,${SHOP.area} 風俗 おすすめ,デリヘル おすすめ,おすすめ,オススメ,${SHOP.area} デリバリーヘルス,素人 デリヘル ${SHOP.area},${SHOP.name},${SHOP.area}${SHOP.name},${SHOP.name}${SHOP.area},${SHOP.area}おすすめデリヘル,おすすめ${SHOP.area}デリヘル,${SHOP.area}オススメデリヘル,オススメ${SHOP.area}デリヘル`;
// robots: 非本番=全noindex / noindex prop=このページのみnoindex(内部リンクはfollow) / それ以外=index,follow
const robotsContent = !IS_PROD ? 'noindex, nofollow' : (noindex ? 'noindex, follow' : 'index, follow');
// 構造化データ（LocalBusiness）: エンティティ強化・ローカルSEO
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': SITE + '/#business',
  name: SHOP.fullName,
  // 通称を配列で明示（Web上の通称「立川アドミ」/TikTok名「アドミ立川」を同一エンティティに束ねる）
  alternateName: [SHOP.name, `${SHOP.area}${SHOP.name}`, `${SHOP.name}${SHOP.area}`],
  legalName: SHOP.fullName,
  url: SITE,
  telephone: SHOP.tel,
  image: `${SITE}/img/og-image.jpg`,
  areaServed: SHOP.area,
  // 公式アカウント・広告媒体の店舗ページ（エンティティ統合。特にTikTokは「アドミ立川」名義）
  sameAs: [
    'https://www.tiktok.com/@admi_girl',
    'https://fujoho.jp/index.php?p=shop_info&id=57',
    'https://ranking-deli.jp/8/shop/4517/',
    'https://www.cityheaven.net/tokyo/A1330/A133001/adomi2002_gtf/',
    'https://fuzoku.jp/admi2888/',
    'https://deli-fuzoku.jp/admi2888/',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: SHOP.area,
    addressRegion: '東京都',
    addressCountry: 'JP',
  },
};

// キャッシュバスター: site.css/js の mtime（Cloudflareが1年immutableキャッシュするため必須）
const ver = (f: string): string => { try { return String(Math.floor(statSync(f).mtimeMs)); } catch { return '1'; } };
const cssV = ver('public/site.css');
const jsV = ver('public/site.js');
const favV = ver('public/favicon.svg');
const i18nV = ver('public/i18n.js');
const contentI18nV = ver('public/content-i18n.js');
---
<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={robotsContent} />
<!-- 旧業者(admi2002fantasy@gmail.com)のGSC所有権メタタグを削除（2026-06-26、ロックアウト）。現所有権はドメインプロパティのDNS TXTで認証済み。 -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={SHOP.fullName} />
<meta name="twitter:card" content="summary_large_image" />
{IS_PROD && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=M+PLUS+Rounded+1c:wght@400;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href={`/site.css?v=${cssV}`} />
<link rel="icon" href={`/favicon.svg?v=${favV}`} type="image/svg+xml" />
<!-- GA: 本番(admi2888.com)のみ有効。biyobuステージングでは出さない（kichifu/GAを汚さない） -->
{IS_PROD && (
<>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-50Q48YG34Z"></script>
<script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-50Q48YG34Z');</script>
</>
)}
<script is:inline define:vars={{ shopId: SHOP_ID }}>window.__SHOP_ID = shopId;</script>
</head>
<body>
<header class="site-header">
  <div class="site-header-inner">
    <a href="/top" class="brand" aria-label={`${SHOP.fullName} トップ`}>
      <span class="brand-script flicker">{SHOP.nameEn}</span>
      <span class="brand-sub">
        <span class="brand-since">立川デリヘル</span>
        <span class="brand-genre">すけべな素人専門店</span>
        <span class="brand-catch">アドミ since2002</span>
      </span>
    </a>
    {!gate && (
    <nav class="site-nav">
      <a href="/top" data-i18n="nav_top">トップ</a>
      <a href="/girls" data-i18n="nav_girls">すけべな女の子達</a>
      <a href={FUJOHO.schedule} target="_self" rel="noopener" data-i18n="nav_schedule">スケジュール</a>
      <a href="/system" data-i18n="nav_system">料金システム</a>
      <a href="/howto" data-i18n="nav_howto">ご利用ガイド</a>
      <a href="https://ranking-deli.jp/tokyo/area39/style2/4517/news/" target="_self" rel="noopener" data-i18n="nav_news">お知らせ</a>
      <a href={FUJOHO.diary} target="_self" rel="noopener" data-i18n="nav_diary">写メ日記</a>
      <a href="https://yobuho.com/deli/shop/0tkzk670/" target="_self" data-i18n="nav_hotel_search">🏨 ホテル検索</a>
      <a href={SHOP.recruitUrl} target="_self" rel="noopener" data-i18n="nav_recruit">求人情報</a>
    </nav>
    )}
    <div class="header-tel">
      <div class="header-reception"><span data-i18n="header_reception_label">受付</span> {SHOP.reception}</div>
      <a href={`tel:${SHOP.telRaw}`} class="header-tel-num">📞 {SHOP.tel}</a>
    </div>
    <div class="reserve-stack">
      <span class="reserve-hours" data-i18n="reserve_hours_label">営業時間</span>
      <span class="reserve-time">{SHOP.reception}</span>
      <button type="button" class="glossy-pill reserve-btn" data-reserve-open data-i18n="btn_reserve">ご予約</button>
    </div>
    {!gate && (
    <button type="button" class="burger" data-menu-open aria-label="メニューを開く" data-i18n-attr="aria-label=menu_open_label">
      <span></span><span></span><span></span>
    </button>
    )}
  </div>
</header>
<div class="header-spacer" aria-hidden="true"></div>

<slot />

{!hideBack && (
<div class="back-bar">
  <button type="button" class="back-bar-btn" onclick="history.back()" data-i18n="btn_back">← 前へ戻る</button>
</div>
)}
<footer class="site-footer">
  <hr class="footer-top-divider" />
  <div class="footer-inner">
    <p class="footer-brand font-script neon-pink-glow flicker">{SHOP.nameEn}</p>
    <p class="footer-sub">since {SHOP.since} ・ {SHOP.catch} &amp; Go To FANTASY</p>
    <div class="footer-cta">
      <a href={`tel:${SHOP.telRaw}`} class="footer-cta-tel glossy-pill" data-i18n="footer_cta_tel">📞 電話で予約</a>
      <a href={SHOP.lineUrl} target="_self" rel="noopener" class="footer-cta-line" data-i18n="footer_cta_line">💬 LINEで予約</a>
      <p class="footer-cta-note" data-i18n-html="footer_cta_note_html">💝 LINEのご予約で<span class="footer-cta-note-em">プレイ時間＋10分無料</span>！</p>
      <a href="https://yobuho.com/chat-sheet.html?slug=0tkzk670" target="_self" class="footer-cta-chat" data-i18n="footer_cta_chat">💭 チャットで相談</a>
      <p class="footer-cta-chat-note" data-i18n="footer_cta_chat_note">登録不要です！お気軽に。</p>
    </div>
    <p class="footer-reception"><span data-i18n="footer_reception_label">受付時間</span> {SHOP.reception}</p>
    <nav class="footer-links">
      <a href="/top" data-i18n="nav_top">トップ</a>
      <a href="/girls" data-i18n="nav_girls">すけべな女の子達</a>
      <a href="/schedule" target="_self" data-i18n="nav_schedule">スケジュール</a>
      <a href="/system" data-i18n="nav_system">料金システム</a>
      <a href="/howto" data-i18n="nav_howto">ご利用ガイド</a>
      <a href="/guide">立川デリヘルガイド</a>
      <a href="https://ranking-deli.jp/tokyo/area39/style2/4517/news/" target="_self" rel="noopener" data-i18n="nav_news">お知らせ</a>
      <a href={FUJOHO.diary} target="_self" rel="noopener" data-i18n="nav_diary">写メ日記</a>
      <a href="/recruit" data-i18n="nav_recruit">求人情報</a>
    </nav>
    <p class="footer-copy">&copy; {SHOP.since}-{new Date().getFullYear()} {SHOP.fullName} All Rights Reserved.</p>
  </div>
</footer>

{!gate && (
<div class="offcanvas-overlay" data-menu-close></div>
)}
{!gate && (
<div class="offcanvas" id="offcanvas" role="navigation" aria-label="メニュー">
  <div class="offcanvas-head">
    <a href="/top" class="brand" aria-label={`${SHOP.fullName} トップ`}>
      <span class="brand-script flicker">{SHOP.nameEn}</span>
      <span class="brand-sub">
        <span class="brand-since">立川デリヘル</span>
        <span class="brand-genre">すけべな素人専門店</span>
        <span class="brand-catch">アドミ since2002</span>
      </span>
    </a>
    <button type="button" class="offcanvas-close" data-menu-close aria-label="閉じる" data-i18n-attr="aria-label=menu_close_label">✕</button>
  </div>
  <nav class="offcanvas-nav">
    <a href="/top" data-i18n="nav_top">トップ</a>
    <a href="/girls" data-i18n="nav_girls">すけべな女の子達</a>
    <a href={FUJOHO.schedule} target="_self" rel="noopener" data-i18n="nav_schedule">スケジュール</a>
    <a href="/system" data-i18n="nav_system">料金システム</a>
    <a href="/howto" data-i18n="nav_howto">ご利用ガイド</a>
    <a href="https://ranking-deli.jp/tokyo/area39/style2/4517/news/" target="_self" rel="noopener" data-i18n="nav_news">お知らせ</a>
    <a href={FUJOHO.diary} target="_self" rel="noopener" data-i18n="nav_diary">写メ日記</a>
    <a href="https://yobuho.com/deli/shop/0tkzk670/" target="_self" data-i18n="nav_hotel_search">🏨 ホテル検索</a>
    <a href={SHOP.recruitUrl} target="_self" rel="noopener" data-i18n="nav_recruit">求人情報</a>
  </nav>
  <div class="offcanvas-foot">
    <button type="button" class="glossy-pill offcanvas-reserve-btn" data-reserve-open data-i18n="offcanvas_reserve_btn">ご予約はこちら</button>
    <a href={`tel:${SHOP.telRaw}`} class="offcanvas-tel-link">📞 {SHOP.tel}<br /><span class="text-mute">(<span data-i18n="header_reception_label">受付</span> {SHOP.reception})</span></a>
  </div>
</div>
)}

<div class="modal-overlay" id="reserve-modal" role="dialog" aria-modal="true" aria-label="ご予約" aria-hidden="true">
  <div class="modal-box">
    <div class="modal-head">
      <p class="modal-title holo-text" data-i18n="modal_reserve_title">ご予約方法をお選びください</p>
      <button type="button" class="modal-close" data-reserve-close aria-label="閉じる" data-i18n-attr="aria-label=menu_close_label">✕</button>
    </div>
    <p class="modal-sub" data-i18n="modal_reserve_sub">お問い合わせだけでもお気軽にどうぞ♡</p>
    <div class="reserve-cards">
      <a href={`tel:${SHOP.telRaw}`} class="reserve-card">
        <span class="reserve-icon">📞</span>
        <span>
          <span class="reserve-label" data-i18n="modal_tel_label">TELで予約</span>
          <span class="reserve-note" data-i18n="modal_tel_note">明るく優しいスタッフが対応！</span>
        </span>
      </a>
      <a href={SHOP.lineUrl} target="_self" rel="noopener" class="reserve-card">
        <span class="reserve-icon">💬</span>
        <span>
          <span class="reserve-label" data-i18n="modal_line_label">LINEで予約</span>
          <span class="reserve-note" data-i18n="modal_line_note">ご予約でプレイ時間＋10分無料！</span>
        </span>
      </a>
      <a href="https://yobuho.com/chat-sheet.html?slug=0tkzk670" target="_self" class="reserve-card">
        <span class="reserve-icon">💭</span>
        <span>
          <span class="reserve-label" data-i18n="modal_chat_label">チャットで相談</span>
          <span class="reserve-note" data-i18n="modal_chat_note">登録不要です！お気軽に。</span>
        </span>
      </a>
    </div>
  </div>
</div>
{!gate && (
<a href="https://yobuho.com/chat-sheet.html?slug=0tkzk670" target="_self"
   class="admi-chat-fab" aria-label="チャットで相談" data-i18n-attr="aria-label=chat_fab_label">💬</a>
)}
<style is:global>
.admi-chat-fab {
  position: fixed;
  right: 16px;
  bottom: 16px;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff4fd8 0%, #ff9f79 35%, #ffe580 60%, #b78fff 100%);
  background-size: 200% 200%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  text-decoration: none;
  box-shadow: 0 0 12px rgba(255,79,216,.8), 0 0 28px rgba(183,143,255,.5);
  z-index: 2147483646;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  animation: admi-chat-glow 2.4s ease-in-out infinite, admi-chat-gradient 4s linear infinite;
}
@keyframes admi-chat-gradient {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
@keyframes admi-chat-glow {
  0%, 100% { box-shadow: 0 0 12px rgba(255,79,216,.8), 0 0 28px rgba(183,143,255,.5); }
  50%       { box-shadow: 0 0 20px #ff4fd8, 0 0 40px rgba(255,79,216,.7), 0 0 60px rgba(183,143,255,.4); }
}
@media (prefers-reduced-motion: reduce) {
  .admi-chat-fab { animation: none; }
}
</style>
<script is:inline src={`/site.js?v=${jsV}`}></script>
<!-- 多言語対応: i18n.js(静的UIラベル・言語切替の中枢) → content-i18n.js(動的コンテンツの機械翻訳) の順で読込必須 -->
<script is:inline src={`/i18n.js?v=${i18nV}`}></script>
<script is:inline src={`/content-i18n.js?v=${contentI18nV}`}></script>
</body>
</html>
