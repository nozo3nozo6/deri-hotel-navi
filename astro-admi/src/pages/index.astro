---
import Site from '../layouts/Site.astro';
import { SHOP, FUJOHO } from '../lib/config';
import Fujoho from '../components/Fujoho.astro';

const title = SHOP.fullName;   // 正式店名（広告媒体と完全一致＝ブランド検索/サイトリンク強化）
const desc = `${SHOP.catch}でおすすめの老舗「${SHOP.name}」。since${SHOP.since}、ハズレなしのすけべな素人娘をあなたのもとへ。立川で人気・オススメのデリヘルです。`;
const yearsInBusiness = new Date().getFullYear() - SHOP.since;

// admi2888 オリジナルの外部媒体バナー（SEO相互リンク＋集客）。画像は各広告サーバー直リンク。
const mediaBanners = [
  { href: 'https://e-yoyaku.jp/shop/11477/', img: 'https://d30ifc8mca3chm.cloudfront.net/banner/admin/cashback_eyoyaku_740140.jpg', alt: 'WEB予約ページはコチラ｜アドミ立川', big: true },
  // 「駅ちか版はコチラ」バナーは年齢ゲート下(退出リンク直下)に掲出済み＝重複のためバナーエリアからは削除（2026-06-29）
  { href: 'https://www.cityheaven.net/tokyo/A1330/A133001/adomi2002_gtf/', img: '/img/heaven_banner.png', alt: '立川のデリヘル アドミ｜シティヘブン版はこちら' },
  { href: 'https://fuzoku.jp/admi2888/', img: 'https://ad.fuzoku.jp/img/pc_fuzoku_banner1_1_468_60.png', alt: '店舗詳細 アドミsince2002立川デリヘル&Go To FANTASY東京本店｜風俗じゃぱん' },
  { href: 'https://fujoho.jp/index.php?p=shop_girl_list&id=57', img: 'https://img.fujoho.jp/public/bn/fujoho468x60.gif', alt: '口コミ風俗情報局｜アドミ立川' },
  { href: 'https://deli-fuzoku.jp/admi2888/', img: 'https://ad.deli-fuzoku.jp/img/pc_deli_banner1_1_468_60.png', alt: 'エロ娘ハズレなしデリヘル立川アドミ店舗詳細｜デリヘルじゃぱん' },
  { href: 'https://ranking-deli.jp/8/', img: 'https://ranking-deli.jp/assets/img/user/link/2018bnr01.jpg', alt: '東京のデリヘルの人気ランキングなら[駅ちか]' },
  { href: 'https://www.cityheaven.net/tokyo/A1330/A133001/shop-list/biz6/', img: 'https://img.cityheaven.net/img/mutual_link/468_68_241.jpg', alt: '立川のデリヘル｜シティヘブンネット' },
  { href: 'https://fuzoku.jp/admi2888/review/?FJ=official&id=review', img: 'https://ad.fuzoku.jp/img/pc_fuzoku_banner5_1_468_60.jpg', alt: '口コミ体験談一覧 アドミ立川｜風俗じゃぱん' },
  { href: 'https://fuzoku.jp/admi2888/girllist/?filter=4&FJ=official&id=ero_asmr', img: 'https://ad.fuzoku.jp/img/pc_fuzoku_banner5_468_60.png', alt: '在籍一覧 アドミ立川｜風俗じゃぱん' },
  { href: 'https://fuzoku.jp/admi2888/newsmovie/?FJ=official&id=newsmovie', img: 'https://ad.fuzoku.jp/img/pc_fuzoku_banner6_468_60.png', alt: '潜入取材高画質動画一覧 アドミ立川｜風俗じゃぱん' },
  { href: 'https://fuzoku.jp/admi2888/gravure/?FJ=official&id=gravure', img: 'https://ad.fuzoku.jp/img/pc_fuzoku_banner7_468_60.png', alt: '風俗嬢グラビア画像 アドミ立川｜風俗じゃぱん' },
];
// 求人・相互リンク（地域・SEO）
const linkBanners = [
  { href: 'https://kanto.qzin.jp/admi2888/?v=official', img: 'https://ad.qzin.jp/img/bnr_sp_sample_vanilla.jpg', alt: 'エロ娘ハズレなしデリヘル立川アドミで稼ぐならバニラ求人' },
  { href: 'https://www.girlsheaven-job.net/tokyo/ma-80/sa-117/', img: 'https://img.girlsheaven-job.net/img/fppc/468_68_241.png', alt: '立川の風俗求人｜ガールズヘブン' },
  { href: 'https://cocoa-job.jp/8/shop/308/', img: 'https://cocoa-job.jp/assets/img/user/pc/link/2018img-bnr5.jpg', alt: '風俗求人ココア【東京】立川アドミ' },
  { href: 'https://yoasobi-heaven.com/en/tokyo/', img: 'https://yoasobi-heaven.com/img/renewal/linklist/bn_yoasobi-heaven_468x68.jpg', alt: 'YOASOBI HEAVEN' },
  { href: 'https://deli-fuzoku.jp/admi2888/schedule/', img: 'https://ad.deli-fuzoku.jp/img/sp_deli_banner4_1_640_80.png', alt: 'アドミ立川 出勤情報一覧｜デリヘルじゃぱん' },
  { href: 'https://deli-fuzoku.jp/admi2888/girlsdiary/', img: 'https://ad.deli-fuzoku.jp/img/sp_deli_banner3_1_640_80.png', alt: 'アドミ立川 写メ日記一覧｜デリヘルじゃぱん' },
  { href: 'https://deli-fuzoku.jp/tokyo/tachikawa_area/', img: 'https://ad.deli-fuzoku.jp/img/delifuzoku88-31.gif', alt: '立川のデリヘルを検索するなら【デリヘルじゃぱん】', small: true },
  { href: 'https://cocoa-job.jp/8/area39/', img: 'https://cocoa-job.jp/assets/img/user/pc/link/2018img-bnr4.gif', alt: '立川で稼げる風俗バイトは風俗求人ココアで検索', small: true },
  { href: 'https://fuzoku.jp/tokyo/a_2040/biz_4/', img: 'https://ad.fuzoku.jp/img/sp_fuzoku_banner_640_80.jpg', alt: '立川/国分寺/八王子デリヘル人気店多数掲載！風俗じゃぱん' },
  { href: 'https://h-sns.net', img: 'https://h-sns.net/uploads/banners/01_200.jpg', alt: '風俗専門SNS', small: true },
  { href: 'https://www.fucolle.com/08/', img: 'https://www.fucolle.com/link/img/46860-3.gif', alt: 'フーコレ東京', small: true },
];
---
<Site title={title} description={desc} path="/" hideBack gate>
  <main>

    <!-- 年齢確認ゲート ===================================================== -->
    <section class="hero-bg" style="position:relative;min-height:100vh;display:flex;align-items:flex-start;justify-content:center;overflow:hidden;padding-top:var(--header-h);">
      <div class="hero-scrim" style="position:absolute;inset:0;pointer-events:none;"></div>

      <span class="sparkle" style="top:14%;left:12%;font-size:1.5rem;animation-delay:0s"    aria-hidden="true">✦</span>
      <span class="sparkle" style="top:22%;left:80%;font-size:1rem;animation-delay:.6s"     aria-hidden="true">✧</span>
      <span class="sparkle" style="top:62%;left:8%;font-size:1.25rem;animation-delay:1.1s"  aria-hidden="true">✦</span>
      <span class="sparkle" style="top:72%;left:86%;font-size:1.125rem;animation-delay:1.6s"aria-hidden="true">❤</span>
      <span class="sparkle" style="top:40%;left:90%;font-size:.875rem;animation-delay:.9s"  aria-hidden="true">✧</span>
      <span class="sparkle" style="top:18%;left:46%;font-size:1rem;animation-delay:2.1s"    aria-hidden="true">✦</span>

      <div style="position:relative;z-index:1;text-align:center;padding:4px 24px 32px;max-width:900px;margin:0 auto;">

        <p class="reveal reveal-1"
           style="font-size:.875rem;letter-spacing:.35em;margin-bottom:24px;font-weight:700;
                  color:var(--neon-pink);text-shadow:0 1px 0 rgba(255,255,255,.7),0 0 12px rgba(255,79,216,.3);"
           data-i18n="index_gate_tagline_admi">
          ✦ {SHOP.area} ・ SINCE {SHOP.since} ✦
        </p>

        <h1 style="margin-bottom:12px;line-height:1;">
          <span class="reveal reveal-1 font-script flicker neon-pink-glow"
                style="display:block;font-size:clamp(4.5rem,14vw,7rem);line-height:1;">Admi</span>
          <span class="reveal reveal-2"
                style="display:block;font-size:1.25rem;font-weight:600;letter-spacing:.4em;margin-top:16px;
                       color:var(--text-soft);text-shadow:0 1px 0 rgba(255,255,255,.7);">
            ア ド ミ
          </span>
          <span class="reveal reveal-2"
                style="display:block;font-size:clamp(1.75rem,6vw,2.75rem);font-weight:800;color:var(--text);
                       margin-top:20px;text-shadow:0 1px 0 rgba(255,255,255,.6),0 0 14px rgba(255,79,216,.25);"
                data-i18n="index_gate_catch_line_admi">
            {SHOP.catch}
          </span>
        </h1>

        <p class="reveal reveal-3 holo-text"
           style="font-size:1.125rem;font-weight:700;margin-top:10px;margin-bottom:20px;">
          &amp; Go To FANTASY ♡
        </p>

        <div class="reveal reveal-3 glass-card"
             style="border-radius:28px;padding:24px 20px;max-width:460px;margin:0 auto;">
          <p class="neon-pink-glow" style="font-size:1.125rem;font-weight:800;line-height:1.5;margin-bottom:8px;" data-i18n="index_gate_catch1">
            実は、素人が一番すけべ。♡
          </p>
          <p class="text-mute" style="font-size:.875rem;margin-bottom:20px;letter-spacing:.04em;" data-i18n="index_gate_catch2">
            ハズレなしのすけべな素人娘をあなたのもとへ
          </p>
          <a href="/top"
             class="cta-enter"
             style="display:block;max-width:360px;margin:0 auto;"
             aria-label="18歳以上の方はこちらから入場する"
             data-i18n-attr="aria-label=index_gate_enter_aria">
            <img src="/img/enter.png" alt="18歳以上の方はこちらから入場" width="813" height="312" data-i18n-attr="alt=index_gate_enter_alt">
          </a>
        </div>

        <div class="reveal reveal-4" style="margin-top:32px;">
          <a href="https://www.yahoo.co.jp/" rel="noopener"
             style="font-size:.8125rem;color:var(--text-mute);text-decoration:underline;text-underline-offset:4px;"
             data-i18n="index_exit_link">
            18歳未満の方はこちらよりご退出ください
          </a>
          <div style="margin-top:16px;">
            <a href="https://ranking-deli.jp/8/shop/4517/" target="_self" rel="noopener" style="display:inline-block;line-height:0;">
              <img src="https://ranking-deli.jp/assets/img/user/link/bnr30050.jpg"
                   alt="駅ちか版はコチラ｜アドミ立川"
                   width="300" height="57" loading="lazy"
                   style="max-width:300px;width:100%;height:auto;border-radius:6px;box-shadow:0 2px 10px -4px rgba(255,45,155,.4);" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 外部媒体バナー（admi2888 オリジナル・SEO相互リンク＋集客）======================= -->
    <section class="index-banners">
      <div class="index-banners-inner">
        {mediaBanners.map((b) => (
          <a href={b.href} target="_self" rel="noopener" class={`ib ${b.big ? 'ib-big' : ''}`}>
            <img src={b.img} alt={b.alt} loading="lazy" />
          </a>
        ))}
        <div class="ib-links">
          {linkBanners.map((b) => (
            <a href={b.href} target="_self" rel="noopener" class={`ib ${b.small ? 'ib-small' : ''}`}>
              <img src={b.img} alt={b.alt} loading="lazy" />
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- コンセプト（SEO：立川キーワード本文）===================================== -->
    <section class="index-concept">
      <div class="index-concept-inner">
        <h2><span data-i18n="index_h2_part1_admi">アドミ立川 ── 西東京最大の風俗楽園・立川で</span>{yearsInBusiness}<span data-i18n="index_h2_part2_admi">年の実績。お客様に最高のエロと思いやりを演出する、立川でおすすめのデリヘル</span></h2>
        <p data-i18n="index_concept_p1_admi">当店は、すけべな素人専門店「{SHOP.fullName}」。地元のお客様には「立川アドミ」「アドミ立川」の愛称で親しまれている、立川おすすめ・オススメのデリヘルです。</p>
        <p data-i18n="index_concept_p2">ビジュアル×エロさ×思いやりを兼ね揃えた、街で見かける33歳までの優しい・ちゃんとした女の子のみを厳選採用してご案内いたします。在籍の女の子にハズレなし！作業的なサービスは一切ございません。</p>
        <p data-i18n="index_concept_p3">街を歩く女子大生の胸元、すらりと伸びた足。オフィスで部下のヒップラインがクッキリ見えるタイトスカート。駅の階段で見えそうで見えないスカートの中……「ああ、触りたい」「このまま一緒にホテルへ」「自宅でイチャつきたい」——そんな衝動に駆られたことはありませんか。</p>
        <p data-i18n="index_concept_p4_admi">立川デリヘル アドミでは、そういった衝動・妄想を現実にする"街にいる女の子"たちが、あなたのムラムラを解消するため毎日出勤しています。身体の癒しだけでなく、心の癒しもお任せください。</p>
        <p data-i18n="index_concept_p5_admi">思いやりのあるエロい女の子の、本当に満足できるサービスを。立川市を中心に地元に愛され、立川でオススメと評判のお店づくりを心がける「{SHOP.fullName}」（立川アドミ）をお楽しみください。</p>
      </div>
    </section>

    <!-- 媒体ウィジェット（admi2888 オリジナル：写メ日記/口コミ/ブログ埋込）============= -->
    <section class="index-widgets">
      <div class="index-widgets-inner">
        <iframe src="https://qzin.jp/admi2888/blogwidget?width=320&amp;height=460" title="アドミ立川 ブログ" width="320" height="460" scrolling="no" loading="lazy" seamless></iframe>
        <iframe src="https://qzin.jp/admi2888/widget?d=0" title="アドミ立川 出勤" width="279" height="400" loading="lazy" seamless></iframe>
        <iframe src="https://ranking-deli.jp/8/shop/4517/diarywidget/?prev-sp=true&amp;type=3&amp;list=y" title="アドミ立川 写メ日記（駅ちか）" width="340" height="460" frameborder="0" loading="lazy"></iframe>
        <iframe src="https://ranking-deli.jp/8/shop/4517/review/reviewwidget/" title="アドミ立川 口コミ（駅ちか）" width="240" height="300" frameborder="0" loading="lazy"></iframe>
      </div>
    </section>

    <!-- 口コミ風俗情報局 広告バナー =========================================== -->
    <Fujoho />

  </main>

  <style>
    .index-banners { padding: 28px 16px 8px; }
    .index-banners-inner { max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 10px; }
    .index-banners .ib { display: block; width: 100%; max-width: 468px; line-height: 0; }
    .index-banners .ib img { width: 100%; height: auto; border-radius: 6px; box-shadow: 0 2px 10px -4px rgba(255,45,155,.4); }
    .index-banners .ib-big { max-width: 500px; }
    .index-banners .ib-links { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 8px; margin-top: 4px; }
    .index-banners .ib-links .ib { width: auto; max-width: 468px; }
    .index-banners .ib-links .ib img { border-radius: 4px; box-shadow: none; }
    .index-banners .ib-small { max-width: 90px; }
    .index-banners .ib-small img { max-height: 40px; width: auto; }

    .index-widgets { padding: 8px 8px 20px; }
    .index-widgets-inner { display: flex; flex-wrap: wrap; justify-content: center; align-items: flex-start; gap: 14px; max-width: 1000px; margin: 0 auto; }
    .index-widgets iframe { border: 1px solid rgba(255,79,216,.25); border-radius: 8px; background: #fff; max-width: 100%; }
    @media (max-width: 360px) { .index-widgets iframe { width: 100% !important; } }

    .index-concept { padding: 8px 16px 36px; }
    .index-concept-inner { max-width: 760px; margin: 0 auto; }
    .index-concept h2 { font-size: 1.0625rem; font-weight: 800; line-height: 1.7; margin-bottom: 18px; color: var(--neon-pink, #ff1493); }
    .index-concept p { font-size: .9rem; line-height: 1.9; margin-bottom: 12px; color: var(--text-soft, #4a1130); }
  </style>
</Site>
