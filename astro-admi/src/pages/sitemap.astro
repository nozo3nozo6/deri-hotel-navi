---
import Site from '../layouts/Site.astro';
import { getGirls, getNews } from '../lib/api';
import { SHOP } from '../lib/config';

const girls = await getGirls();
const newsItems = (await getNews()).slice(0, 20);

const title = `サイトマップ｜${SHOP.fullName}`;
const desc = `${SHOP.name} サイトマップ。各ページへのリンク一覧です。`;
---
<Site title={title} description={desc} path="/sitemap">
  <main>
    <section class="page-section">
      <div class="neon-room"></div>
      <div class="wrap-md" style="position:relative;z-index:1;">

        <nav class="breadcrumb">
          <a href="/top" data-i18n="nav_top">トップ</a>
          <span class="breadcrumb-sep">›</span>
          <span data-i18n="sitemap_title">サイトマップ</span>
        </nav>

        <div class="section-head">
          <span class="section-eyebrow holo-text">SITEMAP</span>
          <h1 class="section-title" data-i18n="sitemap_title">サイトマップ</h1>
        </div>

        <div class="sitemap-grid">

          <div>
            <p class="sitemap-group-title" data-i18n="sitemap_main_menu">メインメニュー</p>
            <ul class="sitemap-links">
              <li><a href="/top" data-i18n="nav_top">トップ</a></li>
              <li><a href="/girls" data-i18n="nav_girls">すけべな女の子達</a></li>
              <li><a href="/news" data-i18n="nav_news">お知らせ</a></li>
              <li><a href="/system" data-i18n="nav_system">料金システム</a></li>
              <li><a href="/howto" data-i18n="sitemap_howto">ご利用方法</a></li>
              <li><a href="/guide">立川デリヘル利用ガイド</a></li>
              <li><a href="/contacts" data-i18n="sitemap_contacts">お問い合わせ</a></li>
            </ul>

            {newsItems.length ? (
              <>
                <p class="sitemap-group-title" style="margin-top:32px;" data-i18n="nav_news">お知らせ</p>
                <ul class="sitemap-links">
                  {newsItems.map((it) => (
                    <li><a href={`/news/${it.id}`} data-i18n-dynamic>{it.title}</a></li>
                  ))}
                </ul>
              </>
            ) : null}
          </div>

          <div>
            {girls.length ? (
              <>
                <p class="sitemap-group-title" data-i18n="nav_girls">すけべな女の子達</p>
                <ul class="sitemap-links">
                  {girls.map((g) => (
                    <li><a href={`/girls/${g.id}`}>{g.name}</a></li>
                  ))}
                </ul>
              </>
            ) : null}
          </div>

        </div>
      </div>
    </section>
  </main>
</Site>
