---
import Site from '../../layouts/Site.astro';
import { getNews, getDiaries } from '../../lib/api';
import { asset, SHOP } from '../../lib/config';
import { statSync } from 'node:fs';
const ver = (f: string): string => { try { return String(Math.floor(statSync(f).mtimeMs)); } catch { return '1'; } };
const newsV = ver('public/news-latest.js');

// 最新情報 = 手動お知らせ(news) + 写メ日記(fujoho取込) を交互マージ（top と同じ並び・フルリスト）
const _news = (await getNews()).map((n) => ({
  kind: 'news' as const, id: n.id, title: n.title, thumb: n.thumb, body: n.body, posted_at: n.posted_at,
}));
const _diaries = (await getDiaries(30)).map((d) => ({
  kind: 'diary' as const, id: d.id, title: d.title, thumb: d.image, body: d.body, posted_at: d.posted_at,
}));
type FeedItem = (typeof _news)[number] | (typeof _diaries)[number];
const feed: FeedItem[] = [];
for (let i = 0; i < Math.max(_news.length, _diaries.length); i++) {
  if (_news[i]) feed.push(_news[i]);
  if (_diaries[i]) feed.push(_diaries[i]);
}

const title = `お知らせ｜${SHOP.fullName}`;
const desc = `${SHOP.name}の最新情報、キャンペーン、新人入店情報、写メ日記などをお届けします。`;
---
<Site title={title} description={desc} path="/news">
  <main>
    <section class="page-section">
      <div class="neon-room"></div>
      <div class="wrap-md" style="position:relative;z-index:1">

        <nav class="breadcrumb">
          <a href="/top">トップ</a>
          <span class="breadcrumb-sep">›</span>
          <span>お知らせ</span>
        </nav>

        <div class="section-head">
          <span class="section-eyebrow holo-text">NEWS</span>
          <h1 class="section-title">お知らせ</h1>
        </div>

        <div class="news-list" id="news-archive-list" data-thumb-w="108" data-thumb-h="144">
          {feed.map((it) => {
            const isD = it.kind === 'diary';
            const date = it.posted_at ? (function (s, diary) { var d = s.slice(0, 10).split('-'), y = +d[0], mo = +d[1], da = +d[2], w = '日月火水木金土'[new Date(y, mo - 1, da).getDay()]; return (diary ? '' : y + '年') + mo + '月' + da + '日(' + w + ')' + (s.length > 10 ? ' ' + s.slice(11, 16).replace(/^0/, '') : ''); })(it.posted_at, isD) : '';
            const href = isD ? `/diary/${it.id}` : `/news/${it.id}`;
            const imgSrc = it.thumb ? (isD ? it.thumb : asset(it.thumb)) : '';
            const plain = !isD && it.body ? it.body.replace(/<(style|script)\b[^>]*>[\s\S]*?<\/\1>/gi, '').replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim() : '';
            const excerpt = plain ? (plain.length > 80 ? plain.slice(0, 80) + '…' : plain) : '';
            return (
              <a href={href} target="_self" class="news-item">
                {imgSrc
                  ? <img src={imgSrc} alt="" width="108" height="144" loading="lazy" class="news-thumb" />
                  : <div class="news-no-thumb">📢</div>}
                <div class="news-meta">
                  <p class="news-date">{isD ? <span class="news-diary-badge">写メ日記</span> : null}{date}</p>
                  <h2 class="news-title">{it.title}</h2>
                  {excerpt ? <p class="news-excerpt">{excerpt}</p> : null}
                </div>
              </a>
            );
          })}
        </div>
        {feed.length === 0 ? <p class="empty-state" id="news-empty">お知らせはまだありません</p> : null}

      </div>
    </section>
  </main>
  <script is:inline src={`/news-latest.js?v=${newsV}`}></script>
</Site>
