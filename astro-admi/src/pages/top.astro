---
import Site from '../layouts/Site.astro';
import Fujoho from '../components/Fujoho.astro';
import HimeDiary from '../components/HimeDiary.astro';
import AssureTabs from '../components/AssureTabs.astro';
import { getGirls, getNews, getBanners, getSliders } from '../lib/api';
import { asset, localUrl, SHOP, FUJOHO, isNewcomer } from '../lib/config';
import GirlCardItem from '../components/GirlCardItem.astro';
import { statSync } from 'node:fs';
const ver = (f: string): string => { try { return String(Math.floor(statSync(f).mtimeMs)); } catch { return '1'; } };
const schedV = ver('public/schedule-badge.js');
const schedPageV = ver('public/schedule-page.js');
const gvV = ver('public/girl-visibility.js');
const bannerSliderV = ver('public/banner-slider.js');
const sliderLatestV = ver('public/slider-latest.js');
const newsV = ver('public/news-latest.js');
const bannerLatestV = ver('public/banner-latest.js');

// 言語スイッチャー（🌐 Lang）＝スライダー操作列の右端。クリックは i18n.js が document 全体で
//   イベント委譲するため data-lang-btn を置くだけで機能。開閉は <details>（JS最小）。
const LANGS = [
  { code: 'ja', flag: '🇯🇵', name: '日本語' },
  { code: 'en', flag: '🇺🇸', name: 'English' },
  { code: 'zh-CN', flag: '🇨🇳', name: '简体中文' },
  { code: 'zh-TW', flag: '🇹🇼', name: '繁體中文' },
  { code: 'ko', flag: '🇰🇷', name: '한국어' },
];

// 女の子カードのアイコン（フラグ）の見かた＝凡例。タップでモーダル説明。
const ICON_LEGEND = [
  { key: 'newgirl',    img: '/img/flag-newgirl.png',    title: '新人女性', desc: '新しく仲間入りした女性です！いち早く会えるチャンスをお見逃しなく。' },
  { key: 'machiawase', img: '/img/flag-machiawase.png', title: 'お待ち合わせOK', desc: '待ち合わせから楽しめる！デート気分を味わいたいお客様に。' },
  { key: 'tel',        img: '/img/flag-tel.png',        title: 'ご予約前のお試し通話OK', desc: '待機中の女性と直接お話し！声や雰囲気を確かめてから予約できます。' },
  { key: 'inbound',    img: '/img/flag-inbound.png',    title: '外国人のお客様OK', desc: '海外のお客様もWelcome！国境を越えて楽しめます。' },
  { key: 'genderless', img: '/img/flag-genderless.png', title: '女性のお客様もOK', desc: '女性のお客様も大歓迎！同性同士で楽しめます。' },
];

// 最新情報 = 手動お知らせ(news) のみ・上位6件（2026-07-06 写メ日記マージを撤去。
//   最新情報に日記を混ぜるとポイント対象の口コミ局ヒメ日記ウィジェットがクリックされなくなるため。
//   写メ日記は最新情報の下の <HimeDiary> ウィジェットに集約）
const feed = (await getNews()).slice(0, 3);

// 全女の子（本日の出勤セクションは全件hidden配置→JSが本日出勤のみ表示）
const allGirls = await getGirls();
// ヒーロースライダー（管理画面 /ctrl のスライダーで設定、ビルド時取得。画像未設定は除外）
const sliders = (await getSliders()).filter((s) => s.image_pc || s.image_sp);
// 下部バナー（管理画面 /ctrl で設定、ビルド時取得。画像未設定は除外）
const bottomBanners = (await getBanners('bottom')).filter((b) => b.image);
// 新人の女の子 = 入店3ヶ月未満を入店日の新しい順に 8件
const inNum = (g: any): number => g.in_date ? parseInt(String(g.in_date).slice(0, 10).replace(/-/g, ''), 10) || 0 : 0;
const newFaces = allGirls
  .filter((g) => isNewcomer(g.in_date))
  .sort((a, b) => (inNum(b) - inNum(a)) || (b.id - a.id))
  .slice(0, 8);

const title = `${SHOP.fullName}｜立川でおすすめ`;   // 正式店名 + おすすめKW
const desc = `${SHOP.catch}でおすすめの老舗「${SHOP.name}」（since${SHOP.since}）。${SHOP.area}で人気・オススメの厳選された素人の女の子をラブホテル・ご自宅までデリバリー。最新情報・新人の女の子・本日の出勤はこちら。`;
---
<Site title={title} description={desc} path="/top">
<main>

  <!-- ページh1: スライダー時はビジュアルヒーローに見出しが無いため sr-only で常時設置（h1不在対策・2026-07-03） -->
  <h1 class="sr-only">{SHOP.fullName}｜立川アドミ（アドミ立川）── 立川でおすすめのデリヘル</h1>

  <!-- ヒーロー = スライダー（/ctrl のスライダーで管理）。
       0枚でもセクションを常設し、登録直後に slider-latest.js が client 補正（0→1枚目も即反映）。
       0枚時はスライダー非表示＋下のロゴヒーローfallbackを表示（slider-latest.js が切替） == -->
  <section class="hero-slider-section" data-slider style={sliders.length ? '' : 'display:none'}>
    <div class="hero-slider">
      <div class="hero-slider-track">
        {sliders.map((s) => {
          const img = (
            s.image_sp
              ? <picture><source media="(max-width:640px)" srcset={asset(s.image_sp)} /><img src={asset(s.image_pc || s.image_sp)} alt={s.title} /></picture>
              : <img src={asset(s.image_pc)} alt={s.title} />
          );
          return (
            <div class="hero-slide">
              {s.url ? <a href={localUrl(s.url)} target="_self" rel="noopener">{img}</a> : img}
            </div>
          );
        })}
      </div>
    </div>
    <!-- 操作列は常時表示（右端に🌐Langを常設）。矢印+ドットだけスライド数で出し入れ -->
    <div class="hero-slider-controls">
      <div class="hero-slider-nav" style={sliders.length > 1 ? '' : 'display:none'}>
        <button type="button" class="hero-slider-arrow prev" data-slider-prev aria-label="前のスライド">‹</button>
        <div class="hero-slider-dots" data-slider-dots></div>
        <button type="button" class="hero-slider-arrow next" data-slider-next aria-label="次のスライド">›</button>
      </div>
      <details class="hero-lang">
        <summary class="hero-lang-btn"><span aria-hidden="true">🌐</span> Lang<span class="hero-lang-caret" aria-hidden="true">▾</span></summary>
        <div class="hero-lang-menu" role="group" aria-label="Language / 言語">
          {LANGS.map((l) => (
            <button type="button" class="hero-lang-item" data-lang-btn={l.code}>
              <span class="hero-lang-flag" aria-hidden="true">{l.flag}</span>
              <span class="hero-lang-name">{l.name}</span>
            </button>
          ))}
        </div>
      </details>
    </div>
  </section>
  <section class="hero-bg hero-fallback" style={`position:relative;min-height:46vh;align-items:center;justify-content:center;overflow:hidden;display:${sliders.length ? 'none' : 'flex'};`}>
    <div class="hero-scrim" style="position:absolute;inset:0;pointer-events:none;"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:48px 24px;max-width:760px;margin:0 auto;">
      <p class="font-script neon-pink-glow" style="font-size:clamp(3.5rem,11vw,5.5rem);line-height:1;margin-bottom:12px;">{SHOP.nameEn}</p>
      <p class="holo-text" style="font-size:1.75rem;font-weight:800;margin-bottom:20px;">ハズレなしの素人娘を、あなたのもとへ ♡</p><!-- h1はmain先頭のsr-onlyに一本化（重複回避） -->
      <button type="button" data-reserve-open class="glossy-pill" style="padding:12px 32px;border-radius:9999px;font-size:1.0625rem;font-weight:700;color:#fff;border:none;">ご予約はこちら</button>
    </div>
  </section>

  <!-- スライダー関連スクリプトはヒーロー直後に配置（お知らせ/女の子一覧/出勤表等より前）。
       ページ最下部だと全コンテンツのパース完了までJS実行が遅れ、SSG焼き込みの古いスライド画像が
       目に見えて表示されてから新しい画像に差し替わる「チラつき」が起きていた（2026-07-07 修正）。 -->
  <script is:inline src={`/banner-slider.js?v=${bannerSliderV}`}></script>
  <script is:inline src={`/slider-latest.js?v=${sliderLatestV}`}></script>

  <!-- 🌐Langドロップダウン: 言語選択で閉じる＋外側クリックで閉じる（<details>・Astro外部化でCSP安全） -->
  <script>
    document.addEventListener('click', (e) => {
      const target = e.target as Element | null;
      if (!target || !target.closest) return;
      const picked = target.closest('.hero-lang [data-lang-btn]');
      if (picked) {
        const d = picked.closest('details.hero-lang') as HTMLDetailsElement | null;
        if (d) d.open = false;
        return;
      }
      document.querySelectorAll<HTMLDetailsElement>('details.hero-lang[open]').forEach((d) => {
        if (!d.contains(target)) d.open = false;
      });
    });
  </script>

  <!-- 安心タブ（ヒーロー直下）＝👛お釣りその場｜🏨そのホテル呼べる？ を1行タブに統合 -->
  <AssureTabs />

  <style>
    /* スライダー操作列＝右端に🌐Langを常設。矢印/ドットは残り幅の中央(.hero-slider-nav)。
       flexで同一行に共存させ、幅が足りない時は自動的に詰まる＝絶対配置と違い物理的に重ならない。
       操作列は常時表示・min-heightで高さ保持（1枚時に矢印が消えてもLangが浮かない）。 */
    .hero-slider-controls { position: relative; min-height: 44px; display: flex; align-items: center; gap: 10px; }
    .hero-slider-nav { display: flex; align-items: center; justify-content: center; gap: 14px; flex: 1 1 auto; min-width: 0; }
    .hero-lang { position: relative; flex: 0 0 auto; margin-left: auto; z-index: 70; }
    .hero-lang-btn {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 6px 12px; border-radius: 999px;
      background: var(--bg-1); border: 1.5px solid rgba(255, 79, 216, .35);
      color: var(--text-soft); font-family: inherit; font-weight: 800; font-size: .8rem; line-height: 1;
      cursor: pointer; list-style: none; white-space: nowrap;
      -webkit-tap-highlight-color: transparent;
    }
    .hero-lang-btn::-webkit-details-marker { display: none; }
    .hero-lang-caret { font-size: .75rem; margin-left: 1px; transition: transform .2s ease; }
    .hero-lang[open] .hero-lang-caret { transform: rotate(180deg); }
    .hero-lang-menu {
      position: absolute; right: 0; top: calc(100% + 6px);
      background: var(--bg-0); border: 1px solid rgba(255, 79, 216, .28);
      border-radius: 14px; box-shadow: 0 12px 30px -8px rgba(255, 45, 155, .4);
      padding: 6px; display: flex; flex-direction: column; gap: 2px;
      z-index: 60; min-width: 156px;
    }
    .hero-lang-item {
      display: flex; align-items: center; gap: 9px;
      padding: 8px 12px; border-radius: 10px;
      background: transparent; border: none; cursor: pointer; font-family: inherit; text-align: left;
      -webkit-tap-highlight-color: transparent; transition: background .12s ease;
    }
    .hero-lang-item:hover { background: var(--bg-1); }
    .hero-lang-item.is-active { background: linear-gradient(135deg, rgba(255, 79, 216, .16), rgba(183, 143, 255, .14)); }
    .hero-lang-flag { font-size: 1.35rem; line-height: 1; }
    .hero-lang-name { font-size: .82rem; font-weight: 700; color: var(--text-soft); }
    .hero-lang-item.is-active .hero-lang-name { color: var(--neon-pink-hot); }
    @media (min-width: 641px) {
      .hero-lang-btn { font-size: .88rem; padding: 7px 14px; }
    }
    /* 狭幅: 矢印/ドットの間隔とLangボタンを詰めて1行に収める（320px級でも重ならない） */
    @media (max-width: 400px) {
      .hero-slider-nav { gap: 8px; }
      .hero-lang-btn { padding: 6px 9px; font-size: .74rem; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-lang-caret { transition: none; }
    }
  </style>

  <!-- お知らせ ============================================================== -->
  <section class="top-news-section">
    <div class="wrap-md">
      <div class="section-topper" aria-hidden="true">
        <span class="section-topper-line"></span>
        <span class="section-topper-stars">✦ ⋆ ♡ ⋆ ✦</span>
        <span class="section-topper-line"></span>
      </div>
      <div class="section-head">
        <span class="section-eyebrow holo-text">NEWS</span>
        <h2 class="section-title">最新情報</h2>
      </div>
      <div class="news-list" id="top-news-list">
        {feed.length ? feed.map((it) => {
          const date = it.posted_at ? (function (s) { var d = s.slice(0, 10).split('-'), y = +d[0], mo = +d[1], da = +d[2], w = '日月火水木金土'[new Date(y, mo - 1, da).getDay()]; return y + '年' + mo + '月' + da + '日(' + w + ')' + (s.length > 10 ? ' ' + s.slice(11, 16).replace(/^0/, '') : ''); })(it.posted_at) : '';
          const imgSrc = it.thumb ? asset(it.thumb) : '';
          return (
        <a href={`/news/${it.id}`} target="_self" class="news-item">
          {imgSrc
            ? <img src={imgSrc} alt="" width="64" height="80" loading="lazy" class="news-thumb" />
            : <div class="news-no-thumb">📢</div>}
          <div class="news-meta">
            <p class="news-date">{date}</p>
            <h3 class="news-title">{it.title}</h3>
          </div>
        </a>
          );
        }) : <p class="empty-state">お知らせを読み込み中…</p>}
      </div>
      <div class="section-more-wrap">
        <a href="/news" class="section-more glossy-pill">お知らせをもっと見る</a>
      </div>
    </div>
  </section>

  <!-- 最新情報を即時反映（お知らせセクション直後に配置。以前はページ最下部で女の子一覧・
       出勤表・バナー等を挟んでから実行されており、古いお知らせが目に見える時間が長かった
       （2026-07-08 修正） -->
  <script is:inline src={`/news-latest.js?v=${newsV}`}></script>

  <!-- ヒメ日記（口コミ風俗情報局・ポイント対象）＝最新情報の下に単体設置。スマホ横幅100% -->
  <HimeDiary />

  <!-- 口コミ風俗情報局 広告バナー =========================================== -->
  <Fujoho />

  <!-- 新人の女の子 =========================================================== -->
  <section class="top-girls-section">
    <div class="wrap-lg">
      <div class="section-topper" aria-hidden="true">
        <span class="section-topper-line"></span>
        <span class="section-topper-stars">✦ ⋆ ♡ ⋆ ✦</span>
        <span class="section-topper-line"></span>
      </div>
      <div class="section-head">
        <span class="section-eyebrow holo-text">NEW FACE</span>
        <h2 class="section-title">新人の女の子</h2>
      </div>
      {newFaces.length ? (
      <div class="girl-grid">
        {newFaces.map((g) => <GirlCardItem girl={g} />)}
      </div>
      ) : (
        <p class="empty-state">現在新人情報はありません</p>
      )}
      <div class="section-more-wrap">
        <a href="/girls" class="section-more glossy-pill">すけべな女の子達を見る</a>
      </div>
    </div>
  </section>

  <!-- アイコンの見かた（凡例）======================================================= -->
  <section class="top-iconlegend-section">
    <div class="wrap-lg">
      <div class="section-topper" aria-hidden="true">
        <span class="section-topper-line"></span>
        <span class="section-topper-stars">✦ ⋆ ♡ ⋆ ✦</span>
        <span class="section-topper-line"></span>
      </div>
      <div class="iconlegend-head">
        <span class="iconlegend-eyebrow">🏷️ アイコンの見かた</span>
        <span class="iconlegend-hint">タップで説明が見られます</span>
      </div>
      <div class="iconlegend-row">
        {ICON_LEGEND.map((ic) => (
          <button type="button" class="iconlegend-btn" data-icons-open data-icon-key={ic.key} aria-label={ic.title}>
            <img src={ic.img} alt={ic.title} width="40" height="40" loading="lazy" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- 本日の出勤 ============================================================= -->
  <section class="top-girls-section">
    <div class="wrap-lg">
      <div class="section-topper" aria-hidden="true">
        <span class="section-topper-line"></span>
        <span class="section-topper-stars">✦ ⋆ ♡ ⋆ ✦</span>
        <span class="section-topper-line"></span>
      </div>
      <div class="section-head">
        <span class="section-eyebrow holo-text">today's schedule</span>
        <h2 class="section-title">本日の出勤</h2>
      </div>
      <div class="schedule-date-band" id="schedule-date" aria-live="polite"></div>
      <p class="empty-state" id="schedule-empty" style="display:none">本日の出勤情報は準備中です。</p>
      <div class="girl-grid is-schedule" id="schedule-grid">
        {allGirls.map((g) => <GirlCardItem girl={g} />)}
      </div>
      <div class="section-more-wrap">
        <a href="/schedule" class="section-more glossy-pill">スケジュール確認</a>
      </div>
    </div>
  </section>

  <!-- 女の子カードの掲載状況をここで即時反映（新人セクション＋本日の出勤の両グリッドが
       既にDOM上にあるこの位置に配置。以前はSite.astro末尾でフッター等の後に実行されており、
       古い写真/削除済みカードが目に見える時間が長かった（2026-07-08 修正） -->
  <script is:inline src={`/girl-visibility.js?v=${gvV}`}></script>

  <!-- 下部バナー（管理画面 /ctrl で設定）= バナーエリア ======================
       0枚でもセクションを常設し、banner-latest.js が client 補正（0→1枚目/差し替え/全消しも即反映） -->
  <section class="bottom-banner-section" data-bottom-banners style={bottomBanners.length ? '' : 'display:none'}>
    <hr class="holo-divider bottom-banner-divider" />
    <div class="bottom-banner-grid">
      {bottomBanners.map((b) => (
        b.url
          ? <a href={localUrl(b.url)} target="_self" rel="noopener" class="bottom-banner-item"><img src={asset(b.image)} alt={b.title} loading="lazy" /></a>
          : <span class="bottom-banner-item"><img src={asset(b.image)} alt={b.title} loading="lazy" /></span>
      ))}
    </div>
  </section>
  <script is:inline src={`/banner-latest.js?v=${bannerLatestV}`}></script>

  <script is:inline src={`/schedule-badge.js?v=${schedV}`}></script>
  <script is:inline src={`/schedule-page.js?v=${schedPageV}`}></script>
</main>

<!-- アイコンの見かた モーダル -->
<div class="modal-overlay" id="icons-modal" role="dialog" aria-modal="true" aria-label="アイコンの説明" aria-hidden="true">
  <div class="modal-box">
    <div class="modal-head">
      <p class="modal-title holo-text">アイコンの見かた</p>
      <button type="button" class="modal-close" data-icons-close aria-label="閉じる">✕</button>
    </div>
    <div class="reserve-cards">
      {ICON_LEGEND.map((ic) => (
        <div class="reserve-card iconlegend-item" data-icon-key={ic.key}>
          <img class="iconlegend-item-icon" src={ic.img} alt="" width="44" height="44" loading="lazy" />
          <span>
            <span class="reserve-label">{ic.title}</span>
            <span class="reserve-note">{ic.desc}</span>
          </span>
        </div>
      ))}
    </div>
  </div>
</div>
</Site>
