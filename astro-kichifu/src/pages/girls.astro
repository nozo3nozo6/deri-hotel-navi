---
import SiteLayout from '../layouts/SiteLayout.astro';
import GirlCard from '../components/site/GirlCard.astro';
import { GIRLS } from '../data/girls.ts';
import { SHOP } from '../data/shop.ts';
const title = `女の子一覧｜${SHOP.fullName}`;
const description = `${SHOP.brand}（${SHOP.catch}）の在籍女の子一覧。厳選された素人の女の子をご紹介します。`;
---
<SiteLayout title={title} description={description} pathname="/girls">
  <section class="relative py-12 md:py-16 bg-[var(--bg-0)] min-h-[60vh]">
    <div class="neon-room absolute inset-0 opacity-50"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <div class="text-center mb-8">
        <p class="holo-text text-sm tracking-[0.3em] font-bold">GIRLS</p>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white">女の子一覧</h1>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-5">
        {GIRLS.map((girl) => <GirlCard girl={girl} />)}
      </div>
    </div>
  </section>
</SiteLayout>
