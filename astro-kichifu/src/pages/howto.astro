---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SHOP } from '../data/shop.ts';

const steps = [
  { icon: '📞', title: 'ご予約', text: 'お電話・LINE・WEBからご予約ください。ご希望の女の子・コース・時間・待ち合わせ場所をお伝えください。' },
  { icon: '🏨', title: '待ち合わせ', text: 'ラブホテルやご自宅など、ご指定の場所へ女の子がお伺いします。ホテルが分からない場合もスタッフがご案内します。' },
  { icon: '💳', title: 'お支払い', text: '女の子と合流後、最初にコース料金をお支払いください。明朗会計で安心してご利用いただけます。' },
  { icon: '💞', title: 'お楽しみ', text: 'あとは二人だけの特別な時間を心ゆくまでお楽しみください。延長も随時受付しております。' },
];
const title = `ご利用ガイド｜${SHOP.fullName}`;
const description = `${SHOP.brand}（${SHOP.catch}）のご利用方法。はじめての方も安心の、かんたん4ステップをご案内します。`;
---
<SiteLayout title={title} description={description} pathname="/howto">
  <section class="relative py-12 md:py-16 bg-[var(--bg-1)] min-h-[70vh]">
    <div class="max-w-2xl mx-auto px-6">
      <div class="text-center mb-10">
        <p class="holo-text text-sm tracking-[0.3em] font-bold">GUIDE</p>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white">ご利用ガイド</h1>
        <p class="text-sm text-[var(--text-mute)] mt-2">はじめての方も安心、かんたん4ステップ</p>
      </div>

      <ol class="space-y-4">
        {steps.map((s, i) => (
          <li class="glass-card rounded-2xl p-5 flex gap-4 items-start">
            <span class="shrink-0 w-11 h-11 rounded-full bg-[var(--neon-pink)]/15 border border-[var(--neon-pink)]/40 flex items-center justify-center text-xl">{s.icon}</span>
            <div>
              <p class="text-[var(--lav-soft)] text-xs font-bold mb-0.5">STEP {i + 1}</p>
              <h2 class="text-white font-bold mb-1">{s.title}</h2>
              <p class="text-sm text-[var(--text-soft)] leading-relaxed">{s.text}</p>
            </div>
          </li>
        ))}
      </ol>

      <div class="text-center mt-10">
        <button type="button" data-reserve-open class="glossy-pill px-8 py-3.5 rounded-full text-lg font-bold text-white">さっそく予約する</button>
      </div>
    </div>
  </section>
</SiteLayout>
