---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SHOP } from '../data/shop.ts';
const title = `お問い合わせ｜${SHOP.fullName}`;
const description = `${SHOP.brand}（${SHOP.catch}）へのお問い合わせ。ご予約・ご質問はお電話・LINE・フォームからお気軽にどうぞ。`;
// iOS の入力欄オートズーム防止のため input は 16px(text-base) 以上
const field = 'w-full text-base text-white bg-white/5 border border-[var(--neon-pink)]/30 rounded-xl px-4 py-3 placeholder:text-[var(--text-mute)] focus:border-[var(--neon-pink)]/70 focus:outline-none';
---
<SiteLayout title={title} description={description} pathname="/contacts">
  <section class="relative py-12 md:py-16 bg-[var(--bg-0)] min-h-[70vh]">
    <div class="neon-room absolute inset-0 opacity-50"></div>
    <div class="relative z-10 max-w-xl mx-auto px-6">
      <div class="text-center mb-8">
        <p class="holo-text text-sm tracking-[0.3em] font-bold">CONTACT</p>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white">お問い合わせ</h1>
        <p class="text-sm text-[var(--text-mute)] mt-2">お急ぎの方はお電話・LINEが確実です</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
        <a href={`tel:${SHOP.telRaw}`} class="glossy-pill flex-1 text-center px-5 py-3 rounded-full font-bold text-white">📞 {SHOP.tel}</a>
        <a href={SHOP.lineUrl} target="_blank" rel="noopener" class="flex-1 text-center px-5 py-3 rounded-full font-bold text-white bg-[#06c755] hover:brightness-110 transition">💬 LINEで相談</a>
      </div>

      <form id="contactForm" class="glass-card rounded-3xl p-6 md:p-7 space-y-4" novalidate>
        <p class="hidden" aria-hidden="true">
          <label>このフィールドは入力しないでください<input type="text" name="_hp" tabindex="-1" autocomplete="off" /></label>
        </p>
        <div>
          <label class="block text-sm text-[var(--text-soft)] mb-1.5" for="cf-name">お名前 <span class="text-[var(--neon-pink)]">*</span></label>
          <input id="cf-name" name="name" type="text" required class={field} placeholder="お名前またはニックネーム" />
        </div>
        <div>
          <label class="block text-sm text-[var(--text-soft)] mb-1.5" for="cf-tel">電話番号</label>
          <input id="cf-tel" name="tel" type="tel" inputmode="tel" class={field} placeholder="090-0000-0000" />
        </div>
        <div>
          <label class="block text-sm text-[var(--text-soft)] mb-1.5" for="cf-email">メールアドレス</label>
          <input id="cf-email" name="email" type="email" class={field} placeholder="example@email.com" />
        </div>
        <div>
          <label class="block text-sm text-[var(--text-soft)] mb-1.5" for="cf-msg">お問い合わせ内容 <span class="text-[var(--neon-pink)]">*</span></label>
          <textarea id="cf-msg" name="message" rows="5" required class={field} placeholder="ご予約・ご質問など"></textarea>
        </div>
        <button type="submit" class="glossy-pill w-full py-3.5 rounded-full text-lg font-bold text-white">送信する</button>
        <p id="cf-status" class="text-center text-sm" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    const status = document.getElementById('cf-status');
    if (form && status) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
        const fd = new FormData(form);
        const payload = Object.fromEntries(fd.entries());
        if (!payload.name || !payload.message) {
          status.textContent = 'お名前とお問い合わせ内容をご入力ください。';
          status.style.color = '#ff8fb1';
          return;
        }
        btn.disabled = true;
        status.style.color = '';
        status.textContent = '送信中…';
        try {
          const res = await fetch('/api/contact.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const json = await res.json();
          if (res.ok && json.ok) {
            form.reset();
            status.style.color = '#b78fff';
            status.textContent = '送信しました。ありがとうございます！折り返しご連絡いたします。';
          } else {
            throw new Error(json.error || 'failed');
          }
        } catch (err) {
          status.style.color = '#ff8fb1';
          status.textContent = '送信に失敗しました。お手数ですがお電話・LINEでご連絡ください。';
        } finally {
          btn.disabled = false;
        }
      });
    }
  </script>
</SiteLayout>
