---
import SiteLayout from '../layouts/SiteLayout.astro';
import NewsCard from '../components/site/NewsCard.astro';
import { fetchNews } from '../data/news.ts';
import { SHOP } from '../data/shop.ts';

const items = await fetchNews();
const title = `お知らせ｜${SHOP.fullName}`;
const description = `${SHOP.brand}（${SHOP.catch}）の最新情報・お知らせ一覧。`;
---
<SiteLayout title={title} description={description} pathname="/news">
  <section class="relative py-12 md:py-16 bg-[var(--bg-1)] min-h-[60vh]">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-8">
        <p class="holo-text text-sm tracking-[0.3em] font-bold">NEWS</p>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white">お知らせ</h1>
      </div>
      {items.length > 0 ? (
        <div class="space-y-3">
          {items.map((item) => <NewsCard item={item} />)}
        </div>
      ) : (
        <p class="text-center text-[var(--text-mute)] py-20">お知らせはありません</p>
      )}
    </div>
  </section>
</SiteLayout>
