---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { GIRLS } from '../../data/girls.ts';
import { SHOP } from '../../data/shop.ts';

export function getStaticPaths() {
  return GIRLS.map((girl) => ({ params: { id: String(girl.id) }, props: { girl } }));
}
const { girl } = Astro.props;
const photo = girl.photo ?? '/img/placeholder.svg';
const size = `B${girl.bust}(${girl.cup}) W${girl.waist} H${girl.hip}`;
const title = `${girl.name}（${girl.age}）｜${SHOP.fullName}`;
const description = `${girl.name}（${girl.age}）T${girl.height} ${size}。${girl.catch ?? ''} ${SHOP.catch}の${SHOP.brand}。`;
---
<SiteLayout title={title} description={description} pathname={`/girls/${girl.id}`}>
  <section class="relative py-10 md:py-14 bg-[var(--bg-0)] min-h-[70vh]">
    <div class="neon-room absolute inset-0 opacity-40"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <a href="/girls" class="text-sm text-[var(--lav-soft)] hover:text-white">← 女の子一覧へ</a>
      <div class="mt-4 grid md:grid-cols-2 gap-6 md:gap-10 items-start">
        <div class="relative overflow-hidden rounded-2xl ring-1 ring-[var(--neon-pink)]/40 shadow-[0_18px_50px_-18px_rgba(255,45,155,0.6)]">
          <img src={photo} alt={girl.name} width="600" height="800" class="w-full aspect-[3/4] object-cover" />
          {girl.isNew && <span class="absolute top-3 left-3 px-2.5 py-1 rounded-full text-xs font-bold text-white bg-[var(--neon-pink-hot)]">NEW</span>}
        </div>
        <div>
          <p class="neon-lav-glow text-xs tracking-[0.3em] mb-2">PROFILE</p>
          <h1 class="text-3xl font-extrabold text-white mb-1">{girl.name}<span class="text-lg text-[var(--lav-soft)] ml-2">（{girl.age}）</span></h1>
          {girl.catch && <p class="holo-text font-bold mb-4">{girl.catch}</p>}
          <dl class="glass-card rounded-2xl p-5 grid grid-cols-[5em_1fr] gap-y-3 text-sm mb-5">
            <dt class="text-[var(--text-mute)]">身長</dt><dd class="text-white font-bold">{girl.height} cm</dd>
            <dt class="text-[var(--text-mute)]">3サイズ</dt><dd class="text-white font-bold">{size}</dd>
          </dl>
          {girl.tags && (
            <div class="flex flex-wrap gap-2 mb-6">
              {girl.tags.map((t) => <span class="neon-chip rounded-full px-3 py-1 text-xs">{t}</span>)}
            </div>
          )}
          <button type="button" data-reserve-open class="glossy-pill w-full sm:w-auto px-8 py-3.5 rounded-full text-lg font-bold text-white">この子を予約する</button>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
