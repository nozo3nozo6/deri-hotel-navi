---
import Site from '../layouts/Site.astro';
import { SHOP, FUJOHO } from '../lib/config';
import Fujoho from '../components/Fujoho.astro';

const title = SHOP.fullName;   // 正式店名（広告媒体と完全一致＝ブランド検索/サイトリンク強化）
const desc = `${SHOP.catch}の老舗「${SHOP.name}」。since2009、ハズレなしのすけべな素人娘をあなたのもとへ。`;
const yearsInBusiness = new Date().getFullYear() - SHOP.since;
---
<Site title={title} description={desc} path="/" gate={true}>
  <main>

    <!-- 年齢確認ゲート ===================================================== -->
    <section class="hero-bg" style="position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;padding-top:var(--header-h);">
      <div class="hero-scrim" style="position:absolute;inset:0;pointer-events:none;"></div>

      <span class="sparkle" style="top:14%;left:12%;font-size:1.5rem;animation-delay:0s"    aria-hidden="true">✦</span>
      <span class="sparkle" style="top:22%;left:80%;font-size:1rem;animation-delay:.6s"     aria-hidden="true">✧</span>
      <span class="sparkle" style="top:62%;left:8%;font-size:1.25rem;animation-delay:1.1s"  aria-hidden="true">✦</span>
      <span class="sparkle" style="top:72%;left:86%;font-size:1.125rem;animation-delay:1.6s"aria-hidden="true">❤</span>
      <span class="sparkle" style="top:40%;left:90%;font-size:.875rem;animation-delay:.9s"  aria-hidden="true">✧</span>
      <span class="sparkle" style="top:18%;left:46%;font-size:1rem;animation-delay:2.1s"    aria-hidden="true">✦</span>

      <div style="position:relative;z-index:1;text-align:center;padding:48px 24px 64px;max-width:900px;margin:0 auto;">

        <p class="reveal reveal-1"
           style="font-size:.875rem;letter-spacing:.35em;margin-bottom:24px;font-weight:700;
                  color:#fff;text-shadow:0 1px 6px rgba(0,0,0,.95),0 0 10px rgba(183,143,255,.9),0 0 24px rgba(183,143,255,.5);"
           data-i18n="index_gate_tagline_kichifu">
          ✦ 吉祥寺 ・ SINCE 2009 ✦
        </p>

        <h1 style="margin-bottom:12px;line-height:1;">
          <span class="reveal reveal-1 font-script flicker neon-pink-glow"
                style="display:block;font-size:clamp(4.5rem,14vw,7rem);line-height:1;">Admi</span>
          <span class="reveal reveal-2"
                style="display:block;font-size:1.25rem;font-weight:600;letter-spacing:.4em;margin-top:16px;
                       color:var(--lav-soft);text-shadow:0 2px 6px rgba(0,0,0,.95),0 0 16px rgba(183,143,255,.9);">
            ア ド ミ
          </span>
          <span class="reveal reveal-2"
                style="display:block;font-size:clamp(1.75rem,6vw,2.75rem);font-weight:800;color:#fff;
                       margin-top:20px;text-shadow:0 0 18px rgba(183,143,255,.5);"
                data-i18n="index_gate_catch_line_kichifu">
            吉祥寺デリヘル
          </span>
        </h1>

        <p class="reveal reveal-3 holo-text"
           style="font-size:1.125rem;font-weight:700;margin-top:16px;margin-bottom:48px;">
          &amp; Go To FANTASY ♡
        </p>

        <div class="reveal reveal-3 glass-card"
             style="border-radius:28px;padding:24px 20px;max-width:460px;margin:0 auto;">
          <p class="neon-pink-glow" style="font-size:1.125rem;font-weight:800;line-height:1.5;margin-bottom:8px;" data-i18n="index_gate_catch1">
            実は、素人が一番すけべ。♡
          </p>
          <p class="text-mute" style="font-size:.875rem;margin-bottom:20px;letter-spacing:.04em;" data-i18n="index_gate_catch2">
            ハズレなしのすけべな素人娘をあなたのもとへ
          </p>
          <a href="/top"
             class="cta-enter"
             style="display:block;max-width:360px;margin:0 auto;"
             aria-label="18歳以上の方はこちらから入場する"
             data-i18n-attr="aria-label=index_gate_enter_aria">
            <img src="/img/enter.png" alt="18歳以上の方はこちらから入場" width="813" height="312" data-i18n-attr="alt=index_gate_enter_alt">
          </a>
        </div>

        <div class="reveal reveal-4" style="margin-top:32px;">
          <a href="https://www.yahoo.co.jp/" rel="noopener"
             style="font-size:.8125rem;color:var(--text-mute);text-decoration:underline;text-underline-offset:4px;"
             data-i18n="index_exit_link">
            18歳未満の方はこちらよりご退出ください
          </a>
        </div>
      </div>
    </section>

    <!-- コンセプト（SEO：吉祥寺キーワード本文）===================================== -->
    <section class="index-concept">
      <div class="index-concept-inner">
        <h2><span data-i18n="index_h2_part1_kichifu">アドミ吉祥寺 ── 中央線屈指の人気タウン・吉祥寺で</span>{yearsInBusiness}<span data-i18n="index_h2_part2_kichifu">年の実績。お客様に最高のエロと思いやりを演出する吉祥寺デリヘル</span></h2>
        <p data-i18n="index_concept_p1_kichifu">当店は…すけべな アドミ吉祥寺 since2009 吉祥寺デリヘル＆Go To FANTASY。</p>
        <p data-i18n="index_concept_p2">ビジュアル×エロさ×思いやりを兼ね揃えた、街で見かける33歳までの優しい・ちゃんとした女の子のみを厳選採用してご案内いたします。在籍の女の子にハズレなし！作業的なサービスは一切ございません。</p>
        <p data-i18n="index_concept_p3">街を歩く女子大生の胸元、すらりと伸びた足。オフィスで部下のヒップラインがクッキリ見えるタイトスカート。駅の階段で見えそうで見えないスカートの中……「ああ、触りたい」「このまま一緒にホテルへ」「自宅でイチャつきたい」——そんな衝動に駆られたことはありませんか。</p>
        <p data-i18n="index_concept_p4_kichifu">吉祥寺デリヘル アドミでは、そういった衝動・妄想を現実にする"街にいる女の子"たちが、あなたのムラムラを解消するため毎日出勤しています。身体の癒しだけでなく、心の癒しもお任せください。</p>
        <p data-i18n="index_concept_p5_kichifu">思いやりのあるエロい女の子の、本当に満足できるサービスを。吉祥寺・武蔵野市を中心に、三鷹・西荻窪エリアまで地元に愛されるお店づくりを心がける アドミ吉祥寺 since2009 吉祥寺デリヘル＆Go To FANTASY をお楽しみください。</p>
      </div>
    </section>

    <!-- 口コミ風俗情報局 広告バナー =========================================== -->
    <Fujoho />

    <!-- 外部媒体バナー（kichifuオリジナル：駅ちか・風俗じゃぱん）================= -->
    <section class="index-media-banners">
      <p class="index-media-banners-label">吉祥寺 デリヘル 風俗 口コミサイトもチェック</p>
      <div class="index-media-banners-grid">
        <a class="index-media-banner-card" href="https://ranking-deli.jp/tokyo/area38/style2/" target="_self">
          <img src="https://ranking-deli.jp/assets/img/user/link/2018bnr01.jpg" width="468" height="60" border="0" loading="lazy" alt="[駅ちか]で探す吉祥寺のデリヘル情報">
        </a>
        <a class="index-media-banner-card" href="https://fuzoku.jp/tokyo/" target="_self">
          <img src="https://ad.fuzoku.jp/img/sp_fuzoku_banner_640_80.jpg" width="100%" border="0" loading="lazy" alt="東京の風俗店探しはお任せ！風俗じゃぱん">
        </a>
      </div>
    </section>

  </main>

  <style>
    .index-concept { padding: 8px 16px 40px; }
    .index-concept-inner { max-width: 760px; margin: 0 auto; }
    .index-concept h2 { font-size: 1.0625rem; font-weight: 800; line-height: 1.7; margin-bottom: 18px; color: var(--neon-pink, #ff4fd8); text-shadow: 0 0 10px rgba(255,79,216,.35); }
    .index-concept p { font-size: .9rem; line-height: 1.95; margin-bottom: 12px; color: var(--text-soft, #f6ecff); }
    .index-media-banners { max-width: 520px; margin: 0 auto; padding: 32px 16px 40px; }
    .index-media-banners-label {
      text-align: center;
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .2em;
      color: var(--text-mute);
      margin: 0 0 16px;
    }
    .index-media-banners-grid { display: flex; flex-direction: column; gap: 14px; }
    .index-media-banner-card {
      display: block;
      padding: 10px;
      border-radius: 12px;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,79,216,.18);
      transition: border-color .2s, background .2s, transform .2s;
    }
    .index-media-banner-card:hover { border-color: rgba(255,79,216,.4); background: rgba(255,255,255,.07); transform: translateY(-1px); }
    .index-media-banner-card img { display: block; max-width: 100%; height: auto; border-radius: 4px; margin: 0 auto; }
  </style>
</Site>
