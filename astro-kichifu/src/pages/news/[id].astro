---
import Site from '../../layouts/Site.astro';
import { SHOP, asset, ASSET_ORIGIN, localizeBody } from '../../lib/config';
import { getNews, getNewsItem } from '../../lib/api';

export async function getStaticPaths() {
  const items = await getNews();
  return items.map((n) => ({ params: { id: String(n.id) } }));
}

const { id } = Astro.params;
const it = await getNewsItem(Number(id));

// サムネのリンク先: ガールズ優先 → URL → どちらも無ければ null（リンク無し）
const thumbLink = it ? (it.link_girl_id ? `/girls/${it.link_girl_id}` : (it.link_url || null)) : null;

const date = it && it.posted_at ? (function (s) { var d = s.slice(0, 10).split('-'), y = +d[0], mo = +d[1], da = +d[2], w = '日月火水木金土'[new Date(y, mo - 1, da).getDay()]; return y + '年' + mo + '月' + da + '日(' + w + ')' + (s.length > 10 ? ' ' + s.slice(11, 16).replace(/^0/, '') : ''); })(it.posted_at) : '';
const excerpt = it && it.body
  ? it.body.replace(/<[^>]*>/g, '').slice(0, 120) + (it.body.replace(/<[^>]*>/g, '').length > 120 ? '…' : '')
  : '';
const title = it ? `${it.title}｜${SHOP.fullName}` : `ページが見つかりません｜${SHOP.fullName}`;
const desc = excerpt || `${SHOP.name}からのお知らせです。`;

// 本文: HTMLタグを含めば「ソース投稿」としてそのまま表示（管理者のみ=信頼コンテンツ）。
// タグ無し=プレーンテキストはエスケープ＋改行→<br>で従来通り安全に表示。
const bodyIsHtml = !!(it && it.body && /<[a-z!/][^>]*>/i.test(it.body));
const bodyPlain = it && it.body
  ? it.body.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/\n/g, '<br />')
  : '';
// 本文HTML内の画像パスを ASSET_ORIGIN(admi2888) 絶対URLに正規化（旧kichifu絶対 + 相対 両対応）
const bodyHtml = localizeBody(                                            // 本文の電話を当店番号に統一（他店登録の2店舗掲載対策）
  (bodyIsHtml ? (it?.body ?? '') : bodyPlain)
    .replace(/https?:\/\/kichifu\.com(\/uploads\/)/g, `${ASSET_ORIGIN}$1`)  // 旧kichifu絶対→admi2888
    .replace(/(["'])\/uploads\//g, `$1${ASSET_ORIGIN}/uploads/`)           // 相対→admi2888
);
---
{!it ? (
  <Site title={`ページが見つかりません｜${SHOP.fullName}`} description="" path={`/news/${id}`}>
    <main>
      <div class="wrap-md" style="padding:80px 24px;text-align:center">
        <p class="empty-state">ページが見つかりません</p>
        <p style="margin-top:24px"><a href="/news" class="back-link">← お知らせ一覧に戻る</a></p>
      </div>
    </main>
  </Site>
) : (
  <Site title={title} description={desc} path={`/news/${id}`}>
    <main>
      <section class="page-section">
        <div class="neon-room"></div>
        <div class="wrap-md" style="position:relative;z-index:1">

          <nav class="breadcrumb">
            <a href="/top">トップ</a>
            <span class="breadcrumb-sep">›</span>
            <a href="/news">お知らせ</a>
            <span class="breadcrumb-sep">›</span>
            <span>{it.title}</span>
          </nav>

          <p class="news-detail-date">{date}</p>
          <h1 class="news-detail-title">{it.title}</h1>

          {it.thumb ? (
            thumbLink ? (
              <a href={thumbLink} target="_self" class="news-detail-thumb-link">
                <img src={asset(it.thumb)} alt=""
                     loading="lazy" class="news-detail-thumb" />
              </a>
            ) : (
              <img src={asset(it.thumb)} alt=""
                   loading="lazy" class="news-detail-thumb" />
            )
          ) : null}

          {it.body ? (
            <div class="prose-neon" set:html={bodyHtml}></div>
          ) : null}

          <p style="margin-top:40px">
            <a href="/news" class="back-link">← お知らせ一覧に戻る</a>
          </p>

        </div>
      </section>
    </main>
  </Site>
)}
