---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { NEWS } from '../../data/news.ts';
import { SHOP } from '../../data/shop.ts';

export function getStaticPaths() {
  return NEWS.map((item) => ({ params: { id: String(item.id) }, props: { item } }));
}
const { item } = Astro.props;
const paragraphs = item.body.split('\n\n');
const title = `${item.title}｜${SHOP.fullName}`;
---
<SiteLayout title={title} description={item.excerpt} pathname={`/news/${item.id}`}>
  <article class="relative py-10 md:py-14 bg-[var(--bg-1)] min-h-[60vh]">
    <div class="max-w-2xl mx-auto px-6">
      <a href="/news" class="text-sm text-[var(--lav-soft)] hover:text-white">← お知らせ一覧へ</a>
      <p class="text-xs text-[var(--lav-soft)] mt-5 mb-2">{item.date}</p>
      <h1 class="text-2xl md:text-3xl font-extrabold text-white leading-snug mb-6">{item.title}</h1>
      <div class="prose-neon text-[15px] md:text-base">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="text-center mt-12">
        <button type="button" data-reserve-open class="glossy-pill px-8 py-3.5 rounded-full text-lg font-bold text-white">ご予約はこちら</button>
      </div>
    </div>
  </article>
</SiteLayout>
