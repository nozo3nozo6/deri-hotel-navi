---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { fetchNews, fetchNewsDetail } from '../../data/news.ts';
import { SHOP } from '../../data/shop.ts';

export async function getStaticPaths() {
  const items = await fetchNews();
  return items.map((item) => ({ params: { id: String(item.id) } }));
}

const { id } = Astro.params;
const item = await fetchNewsDetail(Number(id));
if (!item) return Astro.redirect('/news', 302);

const date       = item.published_at ? item.published_at.slice(0, 10).replace(/-/g, '.') : '';
const paragraphs = (item.body ?? '').split('\n\n').filter(Boolean);
const excerpt    = paragraphs[0]?.slice(0, 100) ?? '';
const title      = `${item.title}｜${SHOP.fullName}`;
---
<SiteLayout title={title} description={excerpt} pathname={`/news/${item.id}`}>
  <article class="relative py-10 md:py-14 bg-[var(--bg-1)] min-h-[60vh]">
    <div class="max-w-2xl mx-auto px-6">
      <a href="/news" class="text-sm text-[var(--lav-soft)] hover:text-white">← お知らせ一覧へ</a>
      <p class="text-xs text-[var(--lav-soft)] mt-5 mb-2">{date}</p>
      <h1 class="text-2xl md:text-3xl font-extrabold text-white leading-snug mb-6">{item.title}</h1>
      <div class="prose-neon text-[15px] md:text-base space-y-4">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="text-center mt-12">
        <button type="button" data-reserve-open
                class="glossy-pill px-8 py-3.5 rounded-full text-lg font-bold text-white">
          ご予約はこちら
        </button>
      </div>
    </div>
  </article>
</SiteLayout>
