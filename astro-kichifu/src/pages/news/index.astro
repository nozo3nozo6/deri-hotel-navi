---
import Site from '../../layouts/Site.astro';
import { getNews } from '../../lib/api';
import { asset, SHOP } from '../../lib/config';
import { statSync } from 'node:fs';
const ver = (f: string): string => { try { return String(Math.floor(statSync(f).mtimeMs)); } catch { return '1'; } };
const newsV = ver('public/news-latest.js');

// お知らせ(news)のみ（2026-07-06 写メ日記マージ撤去。写メ日記はtopのHimeDiaryウィジェットに集約）
const feed = await getNews();

const title = `お知らせ｜${SHOP.fullName}`;
const desc = `${SHOP.name}の最新情報、キャンペーン、新人入店情報などをお届けします。`;
---
<Site title={title} description={desc} path="/news">
  <main>
    <section class="page-section">
      <div class="neon-room"></div>
      <div class="wrap-md" style="position:relative;z-index:1">

        <nav class="breadcrumb">
          <a href="/top" data-i18n="nav_top">トップ</a>
          <span class="breadcrumb-sep">›</span>
          <span data-i18n="nav_news">お知らせ</span>
        </nav>

        <div class="section-head">
          <span class="section-eyebrow holo-text">NEWS</span>
          <h1 class="section-title" data-i18n="nav_news">お知らせ</h1>
        </div>

        <div class="news-list" id="news-archive-list" data-thumb-w="112" data-thumb-h="112">
          {feed.map((it) => {
            const date = it.posted_at ? (function (s) { var d = s.slice(0, 10).split('-'), y = +d[0], mo = +d[1], da = +d[2], w = '日月火水木金土'[new Date(y, mo - 1, da).getDay()]; return y + '年' + mo + '月' + da + '日(' + w + ')' + (s.length > 10 ? ' ' + s.slice(11, 16).replace(/^0/, '') : ''); })(it.posted_at) : '';
            const imgSrc = it.thumb ? asset(it.thumb) : '';
            const plain = it.body ? it.body.replace(/<(style|script)\b[^>]*>[\s\S]*?<\/\1>/gi, '').replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim() : '';
            const excerpt = plain ? (plain.length > 80 ? plain.slice(0, 80) + '…' : plain) : '';
            return (
              <a href={`/news/${it.id}`} target="_self" class="news-item">
                {imgSrc
                  ? <img src={imgSrc} alt="" width="112" height="112" loading="lazy" class="news-thumb" />
                  : <div class="news-no-thumb">📢</div>}
                <div class="news-meta">
                  <p class="news-date">{date}</p>
                  <h2 class="news-title" data-i18n-dynamic>{it.title}</h2>
                  {excerpt ? <p class="news-excerpt" data-i18n-dynamic>{excerpt}</p> : null}
                </div>
              </a>
            );
          })}
        </div>
        {feed.length === 0 ? <p class="empty-state" id="news-empty" data-i18n="news_empty">お知らせはまだありません</p> : null}

      </div>
    </section>
  </main>
  <script is:inline src={`/news-latest.js?v=${newsV}`}></script>
</Site>
