---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SHOP } from '../data/shop.ts';

// TODO: 正式な料金表に差し替え（現状はサンプル）
const courses = [
  { time: '60分', price: '11,000' },
  { time: '90分', price: '16,500' },
  { time: '120分', price: '22,000' },
  { time: '150分', price: '27,500' },
  { time: '180分', price: '33,000' },
];
const extras = [
  { label: '延長 30分', price: '5,500円' },
  { label: '指名料', price: '要確認' },
  { label: '交通費', price: 'エリアにより変動' },
];
const title = `料金システム｜${SHOP.fullName}`;
const description = `${SHOP.brand}（${SHOP.catch}）の料金システム。明朗会計でわかりやすいコース料金をご案内します。`;
---
<SiteLayout title={title} description={description} pathname="/system">
  <section class="relative py-12 md:py-16 bg-[var(--bg-0)] min-h-[70vh]">
    <div class="neon-room absolute inset-0 opacity-50"></div>
    <div class="relative z-10 max-w-2xl mx-auto px-6">
      <div class="text-center mb-8">
        <p class="holo-text text-sm tracking-[0.3em] font-bold">SYSTEM</p>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white">料金システム</h1>
        <p class="text-sm text-[var(--text-mute)] mt-2">時代に合わせた、わかりやすい納得プライス</p>
      </div>

      <div class="glass-card rounded-3xl p-6 md:p-8 mb-6">
        <h2 class="holo-text text-lg font-extrabold mb-4 text-center">コース料金</h2>
        <ul class="divide-y divide-white/10">
          {courses.map((c) => (
            <li class="flex items-center justify-between py-3">
              <span class="text-white font-bold text-lg">{c.time}</span>
              <span class="text-[var(--lav-soft)] font-extrabold text-lg">{c.price}<span class="text-sm font-normal ml-0.5">円</span></span>
            </li>
          ))}
        </ul>
      </div>

      <div class="glass-card rounded-3xl p-6 md:p-8 mb-6">
        <h2 class="holo-text text-lg font-extrabold mb-4 text-center">各種料金</h2>
        <ul class="divide-y divide-white/10">
          {extras.map((e) => (
            <li class="flex items-center justify-between py-3">
              <span class="text-[var(--text-soft)]">{e.label}</span>
              <span class="text-white font-bold">{e.price}</span>
            </li>
          ))}
        </ul>
      </div>

      <p class="text-xs text-[var(--text-mute)] leading-relaxed mb-8">
        ※ 表示は税込価格です。初めてご利用のお客様にはお得な初回割引クーポンをご用意しております。
        詳しくはお電話・LINEにてお気軽にお問い合わせください。
      </p>

      <div class="text-center">
        <button type="button" data-reserve-open class="glossy-pill px-8 py-3.5 rounded-full text-lg font-bold text-white">ご予約はこちら</button>
      </div>
    </div>
  </section>
</SiteLayout>
