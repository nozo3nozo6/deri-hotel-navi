---
const ENTER_URL = 'https://fujoho.jp/index.php?p=shop&id=53179';
---
<section class="hero-bg min-h-screen flex items-center justify-center relative pt-16 md:pt-0">
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/80 to-black/95"></div>

  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
    <h1 class="font-bold mb-12 md:mb-16 tracking-tighter leading-none">
      <span class="block text-5xl sm:text-6xl md:text-7xl mb-4">
        <span class="text-white">アドミ</span><br class="md:hidden" />
        <span class="text-pink-500">since 2009</span>
      </span>
      <span class="block text-3xl sm:text-4xl md:text-5xl font-medium text-zinc-100">
        吉祥寺デリヘル
      </span>
    </h1>

    <div class="inline-block bg-white/10 backdrop-blur-2xl border border-white/20 rounded-3xl p-8 md:p-12 lg:p-16 shadow-2xl w-full max-w-[420px] mx-auto">
      <a
        href={ENTER_URL}
        rel="noopener"
        class="block bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-500 hover:to-rose-500 text-white text-xl md:text-2xl lg:text-3xl font-bold py-5 md:py-8 px-8 md:px-24 rounded-2xl transition-all duration-300 hover:scale-[1.03] active:scale-95 text-center"
      >
        18歳以上の方はこちらから入場
      </a>
    </div>

    <div class="mt-8 md:mt-10">
      <a
        href="https://www.yahoo.co.jp/"
        rel="noopener"
        class="text-zinc-400 hover:text-white text-sm md:text-lg underline transition-colors"
      >
        18歳未満の方はこちらよりご退出ください
      </a>
    </div>
  </div>
</section>
