---
// HimeDiary.astro — 口コミ風俗情報局「ヒメ日記」単体ウィジェット（最新情報の下に設置）。
// ※ iframe 内部スタイルは口コミ局の指定。外枠だけ装飾・スマホは横幅100%。
//   最新情報に写メ日記を混ぜるとポイント対象のこのヒメ日記がクリックされないため単体掲出（2026-07-06）。
import { SHOP } from '../lib/config';
const id = SHOP.fujohoId;
---
<section class="hime-diary-section">
  <div class="hime-diary-widget">
    <div class="fujoho_custom_banner" style="position:relative;width:310px;height:245px;margin:0 auto;">
      <a class="fujoho_header_area" target="_top" href={`https://fujoho.jp/index.php?p=shop_girl_blog_list&id=${id}`}
         style="height:40px;line-height:40px;padding:0 7px;display:block;background-color:#ff63c8;text-decoration:none;text-align:left;">
        <span class="fujoho_banner_title" style="font-size:16px;font-weight:bold;color:#fff;text-shadow:1px 1px 0 #ee4bb4;">ヒメ日記</span>
        <span class="fujoho_btn_more" style="border-radius:3px;font-size:12px;color:#fff;height:26px;line-height:26px;display:inline-block;float:right;margin-top:7px;padding:0 6px;letter-spacing:-0.3px;background-color:#cf2d96;">もっと見る&raquo;</span>
      </a>
      <div class="fujoho_iphone_scroll_size_box" style="height:166px;margin:0 auto;overflow:auto;-webkit-overflow-scrolling:touch;border-left:solid 1px #ff63c8;border-right:solid 1px #ff63c8;">
        <iframe src={`https://fujoho.jp/index.php?p=sp_shop_girl_blog_list&id=${id}&ct=color_diary_pink&iframe=ON2`} loading="lazy" title="ヒメ日記 - 口コミ風俗情報局" frameborder="0" style="width:100%;height:100%;display:block;"></iframe>
      </div>
      <div class="fujoho_footer_area" style="position:absolute;bottom:0;width:100%;padding:10px 0;line-height:19px;text-align:center;color:#fff;background-color:#ff63c8;text-shadow:1px 1px 0px #ee4bb4;text-decoration:none;">
        <div>
          <a target="_top" href="https://fujoho.jp/index.php?p=shop_list&s=2&k=2"
             style="font-size:12px;color:#fff;display:inline-block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;vertical-align:text-bottom;text-decoration:none;">{SHOP.catch}</a>
          <a target="_top" href="https://fujoho.jp/"
             style="font-size:15px;font-weight:700;color:#fff;margin-left:3px;display:inline-block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;vertical-align:text-bottom;text-decoration:none;">口コミ風俗情報局</a>
        </div>
      </div>
    </div>
  </div>
</section>
<style is:global>
  .hime-diary-section { padding: 4px 0 12px; position: relative; z-index: 1; }
  .hime-diary-widget { max-width: 420px; margin: 0 auto; padding: 0 12px; }
  /* fujoho の外枠 width:310px を上書き＝枠内で 100% 追従（iframe内部は不変） */
  .hime-diary-widget .fujoho_custom_banner { width: 100% !important; margin: 0 auto; }
  @media (max-width: 640px) {
    .hime-diary-widget { max-width: 100%; padding: 0; } /* スマホは横幅100% */
  }
</style>
