---
import { SHOP, NAV } from '../../data/shop.ts';
---
<!-- backdrop -->
<div class="offcanvas-backdrop fixed inset-0 z-[60] bg-black/70 backdrop-blur-sm" data-menu-close aria-hidden="true"></div>

<!-- panel -->
<aside
  class="offcanvas-panel fixed top-0 right-0 z-[61] h-full w-[82%] max-w-[340px] bg-[var(--bg-1)] border-l border-[var(--neon-pink)]/40 shadow-2xl flex flex-col"
  aria-label="メニュー"
>
  <div class="flex items-center justify-between px-5 h-16 border-b border-white/10 shrink-0">
    <span class="font-script neon-pink-glow text-3xl">{SHOP.brandEn}</span>
    <button type="button" data-menu-close class="w-10 h-10 flex items-center justify-center rounded-lg text-2xl text-[var(--lav-soft)] hover:text-white" aria-label="メニューを閉じる">✕</button>
  </div>

  <nav class="flex-1 overflow-y-auto py-2">
    {NAV.map((n) => (
      <a
        href={n.href}
        target={n.external ? '_blank' : undefined}
        rel={n.external ? 'noopener' : undefined}
        class="flex items-baseline gap-3 px-6 py-3.5 border-b border-white/5 hover:bg-[var(--neon-pink)]/10 transition-colors"
      >
        <span class="text-base font-semibold text-white">{n.label}</span>
        <span class="text-[10px] tracking-[0.2em] uppercase text-[var(--text-mute)]">{n.ruby}</span>
      </a>
    ))}
  </nav>

  <div class="p-5 border-t border-white/10 shrink-0">
    <button type="button" data-reserve-open class="glossy-pill block w-full text-center py-3 rounded-full font-bold text-white mb-3">ご予約はこちら</button>
    <a href={`tel:${SHOP.telRaw}`} class="block text-center text-sm text-[var(--text-soft)]">
      <span aria-hidden="true">📞 </span>{SHOP.tel}<span class="text-[var(--text-mute)]">（受付 {SHOP.reception}）</span>
    </a>
  </div>
</aside>
