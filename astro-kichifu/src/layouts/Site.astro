---
// Site.astro — 現行 _inc/head.php + _inc/layout.php を Astro に移植（site.css 再利用）
import { statSync } from 'node:fs';
import { SHOP, FUJOHO, SHOP_ID } from '../lib/config';

export interface Props {
  title: string;
  description: string;
  path?: string;       // 例: "/girls"
  ogImage?: string;
  gate?: boolean;      // 年齢確認ゲート(index)はハンバーガー/戻るボタンを出さない
  noindex?: boolean;   // 個別ページをnoindexにする（例: 写メ日記詳細=fujoho原典の転載でindex対象外、内部リンクはfollow）
}
const SITE = 'https://kichifu.com';
const { title, description, path = '/', ogImage = `${SITE}/img/og-image.jpg`, gate = false, noindex = false } = Astro.props;
const canonical = SITE + path;
const robotsContent = noindex ? 'noindex, follow' : 'index, follow';
// 構造化データ（LocalBusiness）: エンティティ強化・ローカルSEO（吉祥寺アドミ）
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': SITE + '/#business',
  name: SHOP.fullName,
  alternateName: SHOP.name,
  legalName: SHOP.fullName,
  url: SITE,
  telephone: SHOP.tel,
  image: `${SITE}/img/og-image.jpg`,
  areaServed: '吉祥寺',
  address: {
    '@type': 'PostalAddress',
    addressLocality: '武蔵野市',
    addressRegion: '東京都',
    addressCountry: 'JP',
  },
};

// キャッシュバスター: site.css/js の mtime（Cloudflareが1年immutableキャッシュするため必須）
const ver = (f: string): string => { try { return String(Math.floor(statSync(f).mtimeMs)); } catch { return '1'; } };
const cssV = ver('public/site.css');
const jsV = ver('public/site.js');
const i18nV = ver('public/i18n.js');
const contentI18nV = ver('public/content-i18n.js');
---
<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={robotsContent} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={SHOP.fullName} />
<meta name="twitter:card" content="summary_large_image" />
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=M+PLUS+Rounded+1c:wght@400;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href={`/site.css?v=${cssV}`} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<script async src="https://www.googletagmanager.com/gtag/js?id=G-VJ1TW4WBYN"></script>
<script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-VJ1TW4WBYN');</script>
<script is:inline define:vars={{ shopId: SHOP_ID }}>window.__SHOP_ID = shopId;</script>
</head>
<body>
<header class="site-header">
  <div class="site-header-inner">
    <a href="/top" class="brand" aria-label={`${SHOP.fullName} トップ`}>
      <span class="brand-script flicker">{SHOP.nameEn}</span>
      <span class="brand-sub">
        <span class="brand-since">吉祥寺デリヘル</span>
        <span class="brand-genre">すけべな素人専門店</span>
        <span class="brand-catch">アドミ since2009</span>
      </span>
    </a>
    <nav class="site-nav">
      <a href="/top" data-i18n="nav_top">トップ</a>
      <a href="/girls" data-i18n="nav_girls">すけべな女の子達</a>
      <a href={FUJOHO.schedule} target="_self" rel="noopener" data-i18n="nav_schedule">スケジュール</a>
      <a href="/system" data-i18n="nav_system">料金システム</a>
      <a href="/news" data-i18n="nav_news">お知らせ</a>
    </nav>
    <div class="header-tel">
      <div class="header-reception"><span data-i18n="header_reception_label">受付</span> {SHOP.reception}</div>
      <a href={`tel:${SHOP.telRaw}`} class="header-tel-num">📞 {SHOP.tel}</a>
    </div>
    <div class="reserve-stack">
      <span class="reserve-hours" data-i18n="reserve_hours_label">営業時間</span>
      <span class="reserve-time">{SHOP.reception}</span>
      <button type="button" class="glossy-pill reserve-btn" data-reserve-open data-i18n="btn_reserve">ご予約</button>
    </div>
    {!gate && (
      <button type="button" class="burger" data-menu-open aria-label="メニューを開く" data-i18n-attr="aria-label=menu_open_label">
        <span></span><span></span><span></span>
      </button>
    )}
  </div>
</header>
<div class="header-spacer" aria-hidden="true"></div>

<slot />

{!gate && (
  <div class="back-bar">
    <button type="button" class="back-bar-btn" onclick="history.back()" data-i18n="btn_back">← 前へ戻る</button>
  </div>
)}
<footer class="site-footer">
  <hr class="footer-top-divider" />
  <div class="footer-inner">
    <p class="footer-brand font-script neon-pink-glow flicker">{SHOP.nameEn}</p>
    <p class="footer-sub">since {SHOP.since} ・ {SHOP.catch} &amp; Go To FANTASY</p>
    <div class="footer-cta">
      <a href={`tel:${SHOP.telRaw}`} class="footer-cta-tel glossy-pill" data-i18n="footer_cta_tel">📞 電話で予約</a>
      <a href={SHOP.lineUrl} target="_self" rel="noopener" class="footer-cta-line" data-i18n="footer_cta_line">💬 LINEで予約</a>
      <p class="footer-cta-note" data-i18n-html="footer_cta_note_html">💝 LINEのご予約で<span class="footer-cta-note-em">プレイ時間＋10分無料</span>！</p>
    </div>
    <p class="footer-reception"><span data-i18n="footer_reception_label">受付時間</span> {SHOP.reception}</p>
    <nav class="footer-links">
      <a href="/top" data-i18n="nav_top">トップ</a>
      <a href="/girls" data-i18n="nav_girls">すけべな女の子達</a>
      <a href="/schedule" target="_self" data-i18n="nav_schedule">スケジュール</a>
      <a href="/system" data-i18n="nav_system">料金システム</a>
      <a href="/howto" data-i18n="nav_howto">ご利用ガイド</a>
      <a href="/news" data-i18n="nav_news">お知らせ</a>
      <a href={FUJOHO.diary} target="_self" rel="noopener" data-i18n="nav_diary">写メ日記</a>
      <a href={SHOP.recruitUrl} target="_self" data-i18n="nav_recruit">求人情報</a>
      <a href="/contacts" data-i18n="nav_contacts">お問合せ</a>
    </nav>
    <p class="footer-copy">&copy; {SHOP.since}-{new Date().getFullYear()} {SHOP.fullName} All Rights Reserved.</p>
  </div>
</footer>

<div class="offcanvas-overlay" data-menu-close style={gate ? 'display:none' : undefined}></div>
<div class="offcanvas" id="offcanvas" role="navigation" aria-label="メニュー" style={gate ? 'display:none' : undefined}>
  <div class="offcanvas-head">
    <a href="/top" class="brand" aria-label={`${SHOP.fullName} トップ`}>
      <span class="brand-script flicker">{SHOP.nameEn}</span>
      <span class="brand-sub">
        <span class="brand-since">吉祥寺デリヘル</span>
        <span class="brand-genre">すけべな素人専門店</span>
        <span class="brand-catch">アドミ since2009</span>
      </span>
    </a>
    <button type="button" class="offcanvas-close" data-menu-close aria-label="閉じる" data-i18n-attr="aria-label=menu_close_label">✕</button>
  </div>
  <nav class="offcanvas-nav">
    <a href="/top" data-i18n="nav_top">トップ</a>
    <a href="/girls" data-i18n="nav_girls">すけべな女の子達</a>
    <a href={FUJOHO.schedule} target="_self" rel="noopener" data-i18n="nav_schedule">スケジュール</a>
    <a href="/system" data-i18n="nav_system">料金システム</a>
    <a href="/howto" data-i18n="nav_howto">ご利用ガイド</a>
    <a href="/news" data-i18n="nav_news">お知らせ</a>
    <a href={FUJOHO.diary} target="_self" rel="noopener" data-i18n="nav_diary">写メ日記</a>
    <a href={SHOP.recruitUrl} target="_self" data-i18n="nav_recruit">求人情報</a>
    <a href="/contacts" data-i18n="nav_contacts">お問合せ</a>
  </nav>
  <div class="offcanvas-foot">
    <button type="button" class="glossy-pill offcanvas-reserve-btn" data-reserve-open data-i18n="offcanvas_reserve_btn">ご予約はこちら</button>
    <a href={`tel:${SHOP.telRaw}`} class="offcanvas-tel-link">📞 {SHOP.tel}<br /><span class="text-mute">(<span data-i18n="header_reception_label">受付</span> {SHOP.reception})</span></a>
  </div>
</div>

<div class="modal-overlay" id="reserve-modal" role="dialog" aria-modal="true" aria-label="ご予約" aria-hidden="true">
  <div class="modal-box">
    <div class="modal-head">
      <p class="modal-title holo-text" data-i18n="modal_reserve_title">ご予約方法をお選びください</p>
      <button type="button" class="modal-close" data-reserve-close aria-label="閉じる" data-i18n-attr="aria-label=menu_close_label">✕</button>
    </div>
    <p class="modal-sub" data-i18n="modal_reserve_sub">お問い合わせだけでもお気軽にどうぞ♡</p>
    <div class="reserve-cards">
      <a href={`tel:${SHOP.telRaw}`} class="reserve-card">
        <span class="reserve-icon">📞</span>
        <span>
          <span class="reserve-label" data-i18n="modal_tel_label">TELで予約</span>
          <span class="reserve-note" data-i18n="modal_tel_note">明るく優しいスタッフが対応！</span>
        </span>
      </a>
      <a href={SHOP.lineUrl} target="_self" rel="noopener" class="reserve-card">
        <span class="reserve-icon">💬</span>
        <span>
          <span class="reserve-label" data-i18n="modal_line_label">LINEで予約</span>
          <span class="reserve-note" data-i18n="modal_line_note">ご予約でプレイ時間＋10分無料！</span>
        </span>
      </a>
    </div>
  </div>
</div>
<script is:inline src={`/site.js?v=${jsV}`}></script>
<!-- 多言語対応: i18n.js(静的UIラベル・言語切替の中枢) → content-i18n.js(動的コンテンツの機械翻訳) の順で読込必須 -->
<script is:inline src={`/i18n.js?v=${i18nV}`}></script>
<script is:inline src={`/content-i18n.js?v=${contentI18nV}`}></script>
</body>
</html>
