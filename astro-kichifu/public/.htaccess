# ============================================================
# kichifu.com .htaccess  (Apache 2.4 / シンレンサーバー)
#   Astro(SSG) 静的配信 + /api(PHP) + /admin(PHP CMS)
# ============================================================
AddDefaultCharset UTF-8
Options -Indexes

# ルート / は Astro の index.html を最優先（index.php は安全用フォールバック）
DirectoryIndex index.html index.php

# mod_dir の自動トレイリングスラッシュ301を無効化（/girls 等が girls/ ディレクトリと
# 衝突して /girls/ に飛ばされるのを防ぎ、下の rewrite で /girls.html へ向ける）
DirectorySlash Off

# --- 機密ファイルへの直アクセスを遮断 ---
<FilesMatch "(^\.ht|db-config\.php$|deploy-config\.php$|.*\.sample\.php$|\.(env|sql|md|log|bak)$)">
  Require all denied
</FilesMatch>

# --- セキュリティヘッダー ---
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- キャッシュ方針 ---
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js|mjs|svg|png|jpg|jpeg|webp|gif|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# --- クリーンURL（Astro静的） --------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 末尾 .html 付き直アクセスは拡張子なしへ 301（重複URL防止）
  RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # 一覧ページは同名サブディレクトリ(girls/ news/)が存在し DirectorySlash で
  # /girls→/girls/ に飛ばされるため、明示的に .html へ先回りマッピング
  RewriteRule ^girls/?$ /girls.html [L]
  RewriteRule ^news/?$  /news.html  [L]

  # CMS(/ctrl)は admi2888.com に一本化。kichifu.com/ctrl・/admin は admi2888 へ恒久リダイレクト
  # （kichifu側の ctrl 実体は廃止。旧ブックマーク救済のため301で誘導）
  RewriteRule ^ctrl(/.*)?$  https://admi2888.com/ctrl$1 [R=301,L]
  RewriteRule ^admin(/.*)?$ https://admi2888.com/ctrl$1 [R=301,L]

  # 拡張子なしリクエストを .html へ内部マッピング（存在する時のみ）
  #   例: /top→/top.html, /girls→/girls.html, /girls/123→/girls/123.html
  #   /api/*.php /admin/*.php /uploads/* は実ファイル(-f)なので素通り
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # /news/[id] の静的 .html が未生成の場合 PHP で動的フォールバック
  #   ctrl/から新規ニュース追加後にビルドしなくても詳細ページが表示される
  #   ※ 上の generic ルールが [L] で止まるため、ここに来るのは .html 未生成時のみ
  RewriteRule ^news/([0-9]+)/?$ /news-ssr.php?id=$1 [L]

  # /diary/[id] の静的 .html が未生成の場合 PHP で動的フォールバック（cron取込後の新規日記用）
  RewriteRule ^diary/([0-9]+)/?$ /diary-ssr.php?id=$1 [L]
</IfModule>
