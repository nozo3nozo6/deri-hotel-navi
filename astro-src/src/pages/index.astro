---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const csp = "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; img-src 'self' data: https:;";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "YobuHo",
    "alternateName": "よぶほ",
    "url": "https://yobuho.com/",
    "description": "デリヘル・女性用風俗・同性利用、あなたの目的に合った呼べるホテルを全国43,000件以上から検索。ユーザー口コミと店舗提供情報で信頼できるホテル情報。",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://yobuho.com/deli/?keyword={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "YobuHo",
    "alternateName": "よぶほ",
    "url": "https://yobuho.com/",
    "logo": "https://yobuho.com/ogp.png",
    "description": "呼べるホテル検索ポータル - デリヘル・女性用風俗・同性利用可能なホテルの口コミ検索サービス",
    "sameAs": ["https://x.com/yobuho_com"]
  }
];
---

<BaseLayout
  title="デリヘル・女風が呼べるホテル検索 YobuHo | 全国43,000件以上の口コミ"
  description="デリヘル・女性用風俗・同性利用、あなたの目的に合ったホテルを全国43,000件以上から検索。ユーザー口コミと店舗提供情報で信頼できるホテル情報。"
  keywords="呼べるホテル,ホテル検索,デリヘル 呼べる ホテル,女性用風俗 呼べる ホテル,同性利用 ホテル,デリヘル ホテル 検索,女風 ホテル,ラブホテル 口コミ,出張 ホテル 呼べる,ビジネスホテル デリヘル,シティホテル 呼べる,ホテル 派遣,呼べるホテル 口コミ,呼べたホテル"
  canonical="https://yobuho.com/"
  ogTitle="デリヘル・女風が呼べるホテル検索 YobuHo"
  ogDescription="ユーザー口コミ×店舗情報で信頼できるホテル検索。全国43,000件以上対応。"
  ogUrl="https://yobuho.com/"
  ogImageAlt="YobuHo - 呼べるホテル検索ポータル"
  twitterTitle="デリヘル・女風が呼べるホテル検索 YobuHo | 全国43,000件以上"
  twitterDescription="デリヘル・女性用風俗・同性利用、あなたの目的に合ったホテルを全国43,000件以上から検索。"
  twitterImage="https://yobuho.com/ogp.png"
  csp={csp}
  jsonLd={jsonLd}
>
    <Fragment slot="head">
        <meta name="google-site-verification" content="nQWgZIeYu0-5NzyWjCcLGezF8ojgPviuSztTr0M1bl4" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
    </Fragment>

    <header class="lp-header">
        <div class="logo"><b>YobuHo</b></div>
    </header>

    <section class="hero">
        <h1>デリヘル・女性用風俗を<br>ホテルに呼べるか、すぐわかる</h1>
        <p class="hero-sub">全国43,000件以上のホテルについて、実際に利用したユーザーの体験談から<br>「呼べたホテル」「呼べなかったホテル」を検索できます</p>
    </section>

    <section class="mode-section">
        <h2>ご利用の目的を選択</h2>
        <p class="age-notice-inline">※当サイトは成人向けの情報を含みます。18歳未満および高校生の方はご利用いただけません。</p>
        <div class="mode-grid">
            <a href="/deli/" class="mode-btn men">&#9794; 男性用（デリヘルを呼ぶ）</a>
            <a href="/jofu/" class="mode-btn women">&#9792; 女性用（女風を呼ぶ）</a>
            <a href="/este/" class="mode-btn este">💆‍♂️ デリエステ（風俗エステを呼ぶ）</a>
            <div>
                <button id="btn-same" class="mode-btn same">&#9895; 同性利用</button>
                <div id="same-panel" class="mode-sub-panel">
                    <a href="/same-f/" class="mode-btn-sub women-same">&#9792;&#9792; 女性同士</a>
                    <a href="/same-m/" class="mode-btn-sub men-same">&#9794;&#9794; 男性同士</a>
                </div>
            </div>
            <div id="recent-shops-gate"></div>
            <hr class="mode-divider">
            <a href="/shop-register/" class="mode-btn shop">&#127978; 店舗様・掲載用はこちら</a>
            <div id="recent-reviews-gate" style="width:100%;max-width:480px;margin:20px auto 0;box-sizing:border-box;"></div>
        </div>
    </section>

    <section class="trust-section">
        <h2>YobuHoが選ばれる理由</h2>
        <div class="trust-cards">
            <div class="trust-card">
                <div class="trust-icon">&#128172;</div>
                <h3>ユーザーの実体験口コミ</h3>
                <p>実際に利用したユーザーの実体験口コミをもとにした、リアルな情報。</p>
            </div>
            <div class="trust-card">
                <div class="trust-icon">&#127978;</div>
                <h3>店舗からの公式情報</h3>
                <p>届出確認済み店舗の派遣実績データ。</p>
            </div>
            <div class="trust-card">
                <div class="trust-icon">&#9989;</div>
                <h3>ダブルチェックで高い信頼性</h3>
                <p>口コミと店舗情報の両面で確認。</p>
            </div>
        </div>
    </section>

    <p class="age-notice">※当サイトは成人向けの情報を含みます。18歳未満および高校生の方はご利用いただけません。</p>

    <Footer variant="full" seoText='<strong>YobuHo（よぶほ）</strong>は、全国43,000件以上のホテルから派遣サービスを「呼べるホテル」を探せる口コミ検索サイトです。デリヘル・女風・デリエステ・出張マッサージの利用可否を、ユーザーと掲載店舗のダブルチェック情報で確認できます。同性カップル（LGBT）対応ホテルやラブホテルの一人利用情報も掲載。都道府県・市区町村・最寄駅から絞り込めます。' />
</BaseLayout>

<script is:inline>
document.getElementById('btn-same').addEventListener('click', function() {
    var p = document.getElementById('same-panel');
    p.style.display = p.style.display === 'flex' ? 'none' : 'flex';
});
(function(){
    var iconMap = {men:'♂',women:'♀',men_same:'♂♂',women_same:'♀♀',este:'💆‍♂️'};
    var modePathMap = {men:'/deli/',women:'/jofu/',men_same:'/same-m/',women_same:'/same-f/',este:'/este/'};
    var modeColor = {men:'#c94870',women:'#b760a0',men_same:'#d8182e',women_same:'#c46078',este:'#9f83c0'};
    fetch('/api/recent-shops.php?mode=all').then(function(r){return r.json();}).then(function(shops){
        if(!shops||!shops.length)return;
        var lines=shops.map(function(s){
            var _dm=s.approved_at?String(s.approved_at).replace('T',' ').match(/(\d{4})-(\d{2})-(\d{2})/):null;
            var ds=_dm?(_dm[2]+'/'+_dm[3]):'';
            var icon=iconMap[s.gender_mode]||'♂';
            var color=modeColor[s.gender_mode]||'#666';
            var name=s.shop_name.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            var link=s.shop_url||(s.slug?(modePathMap[s.gender_mode]||'/deli/')+'shop/'+s.slug+'/':'');
            var nameHTML=link?'<a href="'+link+'" target="_blank" rel="noopener" style="color:'+color+';font-weight:600;text-decoration:none;">'+icon+' '+name+'</a>':'<span style="color:'+color+';font-weight:600;">'+icon+' '+name+'</span>';
            return '<div style="font-size:13px;color:#6a5a4a;padding:3px 0;"><span style="color:#a09080;margin-right:6px;">'+ds+'</span>'+nameHTML+' <span style="color:#a09080;">様 ご登録いただきました</span></div>';
        }).join('');
        var el=document.getElementById('recent-shops-gate');
        if(el)el.innerHTML='<div style="padding:14px 18px;margin:12px 0;background:#fbfaf7;border:1px solid #e8e3d8;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,0.04);">'+lines+'</div>';
    }).catch(function(){});
})();

/* 最新の口コミ30件（10件表示＋20件スクロール、全モード統合） */
(function(){
    var MODES = ['men', 'women', 'men_same', 'women_same', 'este'];
    var modePathMap = {men:'/deli/',women:'/jofu/',men_same:'/same-m/',women_same:'/same-f/',este:'/este/'};
    var modeIcon = {men:'♂', women:'♀', men_same:'♂♂', women_same:'♀♀', este:'💆‍♂️'};
    var modeAccent = {men:'#c94870', women:'#b760a0', men_same:'#d8182e', women_same:'#c46078', este:'#9f83c0'};
    Promise.all(MODES.map(function(m){
        return fetch('/api/recent-reviews.php?mode='+m+'&limit=30').then(function(r){return r.ok?r.json():[];}).then(function(list){
            return (list||[]).map(function(item){ item._mode = m; return item; });
        }).catch(function(){return [];});
    })).then(function(all){
        var merged = [];
        all.forEach(function(arr){ merged = merged.concat(arr); });
        merged.sort(function(a,b){ return (b.created_at||'').localeCompare(a.created_at||''); });
        var top30 = merged.slice(0, 30);
        if (top30.length === 0) return;
        var renderRow = function(r){
            var d = r.created_at ? new Date(r.created_at) : null;
            var ts = d ? (String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0')) : '';
            var name = (r.hotel_name||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            var hotelLink = modePathMap[r._mode] + 'hotel/' + r.hotel_id;
            var badge = '';
            if (r.type === 'hotel') {
                badge = r.can_call ? '<span style="color:#3a9a60;font-weight:600;">✅</span>' : '<span style="color:#c05050;font-weight:600;">❌</span>';
            } else {
                badge = r.solo_entry === 'yes' ? '<span style="color:#3a9a60;">🚪</span>' : r.solo_entry === 'no' ? '<span style="color:#c05050;">🚪</span>' : '<span style="color:#a09080;">🏩</span>';
            }
            var modeTag = '<span style="color:'+modeAccent[r._mode]+';font-size:11px;margin-left:6px;">'+modeIcon[r._mode]+'</span>';
            return '<a href="'+hotelLink+'" style="display:flex;width:100%;max-width:100%;box-sizing:border-box;align-items:center;gap:6px;padding:8px 0;font-size:12px;color:var(--text-2,#6a5a4a);text-decoration:none;border-bottom:1px solid rgba(0,0,0,0.06);min-width:0;"><span style="color:#a09080;flex-shrink:0;">'+ts+'</span><span style="flex-shrink:0;">'+badge+'</span><span style="font-weight:600;color:var(--text,#1a1410);flex:1 1 0;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+name+'</span><span style="flex-shrink:0;">'+modeTag+'</span></a>';
        };
        var allLines = top30.map(renderRow).join('');
        var el = document.getElementById('recent-reviews-gate');
        if (el) el.innerHTML = '<div style="padding:14px 14px;background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.04);max-width:100%;box-sizing:border-box;overflow:hidden;"><div style="font-size:13px;font-weight:700;color:var(--text,#1a1410);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid rgba(0,0,0,0.08);">💬 最新の口コミ</div><div style="max-height:190px;overflow-y:auto;overflow-x:hidden;padding-right:4px;">'+allLines+'</div></div>';
    }).catch(function(){});
})();
</script>

<style>
    :root {
        --accent: #9f83c0;
        --accent-light: #b8a0d5;
        --accent-dim: #7a5e98;
        --bg: #faf8f4;
        --bg-2: #ffffff;
        --bg-3: #f5f2ec;
        --text: #1a1410;
        --text-2: #6a5a4a;
        --text-3: #a09080;
        --border: rgba(180,140,80,0.15);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
    }
    .lp-header { background: linear-gradient(135deg, #1a1228 0%, #2a1838 100%); padding: 14px 20px; text-align: center; }
    .lp-header .logo { font-size: 22px; color: var(--accent); font-weight: 300; letter-spacing: 0.06em; }
    .lp-header .logo b { font-weight: 700; }
    .hero {
        background:
            radial-gradient(ellipse at 10% 30%, rgba(201,72,112,0.25) 0%, transparent 50%),
            radial-gradient(ellipse at 90% 20%, rgba(216,24,46,0.18) 0%, transparent 45%),
            radial-gradient(ellipse at 75% 80%, rgba(159,131,192,0.25) 0%, transparent 55%),
            radial-gradient(ellipse at 30% 90%, rgba(192,104,130,0.22) 0%, transparent 50%),
            radial-gradient(ellipse at 55% 50%, rgba(196,96,120,0.18) 0%, transparent 55%),
            linear-gradient(135deg, #1a1228 0%, #2a1838 35%, #3a2040 70%, #1a1228 100%);
        padding: 36px 20px 32px; text-align: center; color: #fff;
        position: relative; overflow: hidden;
    }
    .hero::before {
        content: ""; position: absolute; inset: 0;
        background: repeating-linear-gradient(45deg, transparent 0, transparent 40px, rgba(255,255,255,0.015) 40px, rgba(255,255,255,0.015) 80px);
        pointer-events: none;
    }
    .hero h1 { font-size: 28px; font-weight: 700; line-height: 1.5; margin-bottom: 12px; text-shadow: 0 2px 20px rgba(0,0,0,0.4); position: relative; z-index: 1; letter-spacing: 0.03em; }
    .hero-sub { font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.7; position: relative; z-index: 1; }
    .mode-section { padding: 40px 20px 32px; background: var(--bg); }
    .mode-section h2 { text-align: center; font-size: 18px; font-weight: 700; margin-bottom: 24px; }
    .age-notice-inline { text-align: center; color: #999; font-size: 12px; margin: 16px 0; }
    .mode-grid { width: 100%; max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; min-width: 0; }
    .mode-btn {
        display: block; width: 100%; padding: 16px 20px; border: 1px solid var(--border);
        background: var(--bg-2); font-size: 15px; font-weight: 600;
        font-family: inherit; cursor: pointer; text-align: center; text-decoration: none;
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; color: var(--text);
    }
    .mode-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
    .mode-btn.men { border-color: rgba(201,72,112,0.3); color: #c94870; border-radius: 8px; }
    .mode-btn.men:hover { border-color: #c94870; }
    .mode-btn.este { border-color: rgba(159,131,192,0.3); color: #9f83c0; border-radius: 15px; }
    .mode-btn.este:hover { border-color: #9f83c0; }
    .mode-btn.women { border-color: rgba(183,96,160,0.3); color: #b760a0; border-radius: 999px; }
    .mode-btn.women:hover { border-color: #b760a0; }
    .mode-btn.same { border-color: rgba(100,100,120,0.25); color: var(--text-2); font-size: 14px; padding: 14px 20px; border-radius: 12px; }
    .mode-btn.same:hover { border-color: rgba(100,100,120,0.5); }
    .mode-sub-panel { display: none; flex-direction: row; gap: 12px; justify-content: center; margin-top: 8px; }
    .mode-btn-sub {
        display: inline-block; flex: 1; padding: 14px 12px; border: 1px solid var(--border);
        background: var(--bg-2); font-size: 14px; font-weight: 600;
        font-family: inherit; cursor: pointer; text-align: center; text-decoration: none;
        color: var(--text); transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .mode-btn-sub:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
    .mode-btn-sub.women-same { border-color: rgba(196,96,120,0.3); color: #c46078; border-radius: 999px; }
    .mode-btn-sub.women-same:hover { border-color: #c46078; }
    .mode-btn-sub.men-same { border-color: rgba(216,24,46,0.3); color: #d8182e; border-radius: 8px; }
    .mode-btn-sub.men-same:hover { border-color: #d8182e; }
    .mode-divider { margin: 20px 0; border: 0; border-top: 1px solid var(--border); }
    .mode-btn.shop { border-color: var(--border); color: var(--text-2); font-weight: 500; font-size: 14px; border-radius: 12px; }
    .trust-section { padding: 40px 20px; background: var(--bg-2); }
    .trust-section h2 { text-align: center; font-size: 18px; font-weight: 700; margin-bottom: 24px; }
    .trust-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: 800px; margin: 0 auto; }
    .trust-card { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 20px 16px; text-align: center; }
    .trust-icon { font-size: 28px; margin-bottom: 10px; }
    .trust-card h3 { font-size: 13px; font-weight: 700; margin-bottom: 6px; color: var(--accent-dim); }
    .trust-card p { font-size: 12px; color: var(--text-2); line-height: 1.7; }
    .age-notice { text-align: center; color: #999; font-size: 12px; margin: 16px 0; padding: 0 20px; }
    @media (max-width: 640px) {
        .hero { padding: 24px 16px 22px; }
        .hero h1 { font-size: 22px; margin-bottom: 8px; }
        .hero-sub { font-size: 13px; line-height: 1.6; }
        .trust-cards { grid-template-columns: 1fr; gap: 12px; }
    }
</style>
