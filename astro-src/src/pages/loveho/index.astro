---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LPFooter from '../../components/LPFooter.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "LoveHo YobuHo",
  "url": "https://loveho.yobuho.com/",
  "description": "全国6,000件以上のラブホテル・レンタルルームの口コミ・評価を検索。清潔感・雰囲気・一人で入れるかなど、リアルな情報。",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://yobuho.com//men/&tab=loveho&search={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};

const footerLinks = [
  { href: 'https://yobuho.com/', label: 'YobuHo トップ' },
  { href: 'https://deli.yobuho.com/', label: 'デリヘル' },
  { href: 'https://jofu.yobuho.com/', label: '女性用風俗' },
  { href: 'https://same.yobuho.com/', label: '同性利用' },
  { href: 'https://yobuho.com/terms.html', label: '利用規約' },
  { href: 'https://yobuho.com/privacy.html', label: 'プライバシーポリシー' },
  { href: 'https://yobuho.com/contact.html', label: 'お問い合わせ' },
];
---

<BaseLayout
  title="ラブホテル検索・口コミ | LoveHo YobuHo - 全国6,000件以上"
  description="全国6,000件以上のラブホテル・レンタルルームの口コミ・評価を検索。清潔感・雰囲気・一人で入れるかなど、リアルな情報をお届けします。"
  keywords="ラブホテル 口コミ,ラブホ 検索,ラブホテル 清潔,ラブホ おすすめ,ラブホテル 一人入り,ラブホ 一人利用,ラブホテル 雰囲気,ラブホ コスパ,ラブホテル 同性,ラブホ カップル,ラブホテル デリヘル,ラブホ 風俗,レンタルルーム,ラブホテル レビュー"
  canonical="https://loveho.yobuho.com/"
  ogTitle="ラブホテル検索・口コミ | LoveHo YobuHo"
  ogDescription="全国6,000件以上のラブホテル・レンタルルームの口コミ・評価を検索。清潔感・雰囲気・一人で入れるかなど。"
  ogUrl="https://loveho.yobuho.com/"
  ogImageAlt="LoveHo YobuHo - ラブホテル検索・口コミ"
  twitterTitle="ラブホテル検索・口コミ | LoveHo YobuHo"
  twitterDescription="全国6,000件以上のラブホテルの口コミ・評価を検索。清潔感・雰囲気・一人で入れるかなど。"
  twitterImage="https://yobuho.com/ogp.png"
  themeColor="#1a1a2e"
  jsonLd={jsonLd}
>
    <Fragment slot="head">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
    </Fragment>

    <header class="lp-header"><div class="logo">LoveHo <b>YobuHo</b></div></header>

    <section class="hero">
        <h1>ラブホテル検索・口コミ</h1>
        <p class="hero-sub">全国6,000件以上のラブホテル・レンタルルームの口コミ情報</p>
        <p class="age-notice">※当サイトは成人向けの情報を含みます。18歳未満および高校生の方はご利用いただけません。</p>
        <a href="https://yobuho.com//men/" class="cta-button">&#127977; ラブホテルを検索する</a>
    </section>

    <section class="trust-section">
        <h2>LoveHo YobuHoの特徴</h2>
        <div class="trust-cards">
            <div class="trust-card">
                <div class="trust-icon">&#10024;</div>
                <h3>清潔感・雰囲気の口コミ</h3>
                <p>実際に利用したユーザーが投稿する清潔感・雰囲気・コスパの評価。星5段階で一目瞭然。</p>
            </div>
            <div class="trust-card">
                <div class="trust-icon">&#128682;</div>
                <h3>一人で入れるかチェック</h3>
                <p>一人で先に入れるか、一緒にチェックインが必要か。デリヘルや風俗利用時に重要な情報を確認。</p>
            </div>
            <div class="trust-card">
                <div class="trust-icon">&#127978;</div>
                <h3>店舗からの公式情報</h3>
                <p>届出確認済みの掲載店舗が提供する入室方法・交通費情報。実績に基づいた確かなデータです。</p>
            </div>
        </div>
    </section>

    <section class="features">
        <h2>こんな情報が見つかります</h2>
        <div class="feature-list">
            <div class="feature-item">
                <span class="feature-num">01</span>
                <div><h3>全国6,000件以上のラブホテル・レンタルルーム</h3><p>北海道から沖縄まで全国を網羅。地域・エリア・市区町村から簡単に検索できます。</p></div>
            </div>
            <div class="feature-item">
                <span class="feature-num">02</span>
                <div><h3>口コミが多いホテルから表示</h3><p>情報が充実しているホテルが上位に表示されるので、信頼できるホテルをすぐに見つけられます。</p></div>
            </div>
            <div class="feature-item">
                <span class="feature-num">03</span>
                <div><h3>完全無料・匿名で利用可能</h3><p>会員登録不要。誰でも無料でホテル情報を検索・口コミを投稿できます。</p></div>
            </div>
        </div>
    </section>

    <section class="howto">
        <h2>使い方はかんたん3ステップ</h2>
        <div class="steps">
            <div class="step"><span class="step-num">1</span><p>地域・都道府県を選択</p></div>
            <div class="step"><span class="step-num">2</span><p>市区町村を選んでラブホタブをクリック</p></div>
            <div class="step"><span class="step-num">3</span><p>口コミ・店舗情報を確認</p></div>
        </div>
    </section>

    <section class="cta-section">
        <h2>さっそく検索してみよう</h2>
        <a href="https://yobuho.com//men/" class="cta-button">&#127977; ラブホテルを検索する</a>
    </section>

    <LPFooter
      seoText="LoveHo YobuHoは、全国6,000件以上のラブホテル・レンタルルームの口コミ検索サイトです。清潔感・雰囲気・コスパの評価、一人で入れるか、同性カップルでの利用可否など、リアルな口コミ情報を掲載。デリヘル（デリバリーヘルス）や風俗利用時のホテル選びにも役立ちます。"
      links={footerLinks}
      dark={true}
    />
</BaseLayout>

<style is:global>
    :root {
        --accent: #c9a96e; --accent-dim: #a8894e;
        --accent-bg: rgba(201,169,110,0.08);
        --bg: #0d0d14; --bg-2: #141420; --bg-3: #1a1a2e;
        --text: #f0ede8; --text-2: rgba(240,237,232,0.7); --text-3: rgba(240,237,232,0.5);
        --border: rgba(201,169,110,0.18);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif; min-height: 100vh; -webkit-font-smoothing: antialiased; }
    .lp-header { background: var(--bg-2); padding: 14px 20px; text-align: center; border-bottom: 1px solid var(--border); }
    .lp-header .logo { font-size: 22px; color: var(--accent); font-weight: 300; letter-spacing: 0.06em; }
    .lp-header .logo b { font-weight: 700; }
    .hero { background: linear-gradient(135deg, #0d0d14 0%, #1a1a2e 50%, #16213e 100%); padding: 60px 20px 56px; text-align: center; color: #fff; }
    .hero h1 { font-size: 24px; font-weight: 700; line-height: 1.5; margin-bottom: 16px; }
    .hero-sub { font-size: 14px; color: var(--text-2); margin-bottom: 32px; line-height: 1.7; }
    .age-notice { text-align: center; color: var(--text-3); font-size: 12px; margin: 16px 0; }
    .cta-button { display: inline-block; padding: 16px 40px; background: linear-gradient(135deg, #c9a96e, #e0c88a); color: #1a1a2e; text-decoration: none; border-radius: 50px; font-size: 16px; font-weight: 700; letter-spacing: 0.04em; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 20px rgba(201,169,110,0.3); }
    .cta-button:hover { transform: translateY(-1px); box-shadow: 0 6px 28px rgba(201,169,110,0.4); }
    .trust-section { padding: 56px 20px; background: var(--bg-2); }
    .trust-section h2 { text-align: center; font-size: 20px; font-weight: 700; margin-bottom: 32px; color: var(--accent); }
    .trust-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 900px; margin: 0 auto; }
    .trust-card { background: var(--bg-3); border: 1px solid var(--border); border-radius: 12px; padding: 28px 20px; text-align: center; }
    .trust-icon { font-size: 36px; margin-bottom: 14px; }
    .trust-card h3 { font-size: 15px; font-weight: 700; margin-bottom: 10px; color: var(--accent); }
    .trust-card p { font-size: 13px; color: var(--text-2); line-height: 1.8; }
    .features { padding: 56px 20px; background: var(--bg); }
    .features h2 { text-align: center; font-size: 20px; font-weight: 700; margin-bottom: 32px; color: var(--text); }
    .feature-list { max-width: 700px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; }
    .feature-item { display: flex; align-items: flex-start; gap: 16px; background: var(--bg-2); border: 1px solid var(--border); border-radius: 12px; padding: 24px 20px; }
    .feature-num { font-size: 28px; font-weight: 700; color: var(--accent); line-height: 1; min-width: 40px; }
    .feature-item h3 { font-size: 15px; font-weight: 700; margin-bottom: 6px; color: var(--text); }
    .feature-item p { font-size: 13px; color: var(--text-2); line-height: 1.7; }
    .howto { padding: 56px 20px; background: var(--bg-2); }
    .howto h2 { text-align: center; font-size: 20px; font-weight: 700; margin-bottom: 32px; color: var(--accent); }
    .steps { display: flex; justify-content: center; gap: 24px; max-width: 700px; margin: 0 auto; }
    .step { flex: 1; text-align: center; padding: 24px 16px; background: var(--bg-3); border-radius: 12px; border: 1px solid var(--border); }
    .step-num { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; background: var(--accent); color: var(--bg); border-radius: 50%; font-size: 20px; font-weight: 700; margin-bottom: 12px; }
    .step p { font-size: 14px; font-weight: 500; color: var(--text); line-height: 1.6; }
    .cta-section { padding: 56px 20px; background: linear-gradient(135deg, #0d0d14 0%, #16213e 100%); text-align: center; }
    .cta-section h2 { font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 24px; }
    @media (max-width: 640px) {
        .hero { padding: 44px 16px 40px; } .hero h1 { font-size: 20px; }
        .trust-cards { grid-template-columns: 1fr; gap: 14px; }
        .steps { flex-direction: column; gap: 14px; }
        .cta-button { padding: 14px 32px; font-size: 15px; }
    }
</style>
