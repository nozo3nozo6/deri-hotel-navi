---
import BaseLayout from '../layouts/BaseLayout.astro';

const csp = "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://cdn.jsdelivr.net https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; img-src 'self' data: https:;";
---

<BaseLayout
  title="店舗掲載・広告掲載 | YobuHo - デリヘル・女性用風俗・出張マッサージ店舗様向け"
  description="YobuHoに店舗を無料掲載しませんか？デリヘル（デリバリーヘルス）・女性用風俗（女風）・出張マッサージ・メンズエステ店舗様向け。呼べるホテル情報を提供して集客アップ。登録無料。"
  keywords="デリヘル 広告,女性用風俗 広告,風俗店 掲載,デリバリーヘルス 集客,女風 広告,出張マッサージ 掲載,メンズエステ 広告,風俗 ホテル情報,YobuHo 店舗登録"
  canonical="https://yobuho.com/shop-register/"
  ogTitle="店舗登録 | YobuHo"
  ogDescription="YobuHoに店舗を掲載しませんか？届出確認済みの店舗として、ホテル対応情報を提供できます。"
  ogUrl="https://yobuho.com/shop-register/"
  themeColor="#b5627a"
  csp={csp}
>
    <Fragment slot="head">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
        <!-- Supabase SDK removed: メール認証はPHP API経由 -->
    </Fragment>

    <div class="logo"><b>YobuHo</b></div>
    <div class="logo-sub">Shop Registration</div>

    <section class="pricing-section">
        <div class="pricing-title">掲載無料！</div>
        <div class="pricing-sub">YobuHoへの店舗掲載は<strong>完全無料</strong>。<br>今すぐ登録して、ホテル情報の発信を始めましょう。</div>
        <div class="merit-list">
            <div class="merit-item"><span class="merit-icon">&#9989;</span><div><strong>店舗名がポータルに掲載</strong><br><span class="merit-desc">対応エリアのホテル一覧に店舗名が表示。ユーザー口コミに加えて店舗の公式情報があることで「この店なら安心」という信頼感が生まれ、貴店への導線になります</span></div></div>
            <div class="merit-item"><span class="merit-icon">&#128221;</span><div><strong>「ご案内実績あり」を公式発信</strong><br><span class="merit-desc">実際にご案内できたホテルの実績を店舗公式として投稿。「このホテルならこの店が対応済み」とユーザーに伝わり、予約前の不安を解消して利用につなげます</span></div></div>
            <div class="merit-item"><span class="merit-icon">&#127991;&#65039;</span><div><strong>認定店バッジ付与</strong><br><span class="merit-desc">口コミに「認定店」マークが表示され、信頼性がアップ</span></div></div>
            <div class="merit-item"><span class="merit-icon">&#128279;</span><div><strong>店舗専用URLを発行</strong><br><span class="merit-desc">自店舗の情報だけが表示される専用ページを発行。自社サイトやSNSに貼るだけで「呼べるホテル一覧」が完成。ホテルリストを自分で作る手間なし、交通費や対応情報もまとめて掲載できます</span></div></div>
            <div class="merit-item"><span class="merit-icon">&#128202;</span><div><strong>店舗管理画面を利用</strong><br><span class="merit-desc">投稿の管理・編集がいつでも可能。スマホからも操作できます</span></div></div>
            <div class="merit-item"><span class="merit-icon">&#128269;</span><div><strong>全国43,000件以上のホテルに対応</strong><br><span class="merit-desc">対応エリアのホテルを検索して情報を登録できます</span></div></div>
            <div class="merit-item"><span class="merit-icon">&#128176;</span><div><strong>初期費用・月額費用ゼロ</strong><br><span class="merit-desc">完全無料で始められます。クレジットカード登録も不要です</span></div></div>
        </div>
    </section>

    <div class="card" id="step-email">
        <div class="card-title">店舗様登録</div>
        <div class="card-sub">登録メールアドレスに認証リンクを送信します</div>
        <div class="steps"><div class="step-dot on"></div><div class="step-dot"></div><div class="step-dot"></div></div>
        <div class="f-group">
            <label class="f-label" for="reg-genre">店舗ジャンル<span class="req">*</span></label>
            <select id="reg-genre" class="f-input">
                <option value="men">男性向け（デリヘル）</option>
                <option value="women">女性向け（女性用風俗）</option>
                <option value="este">デリエステ</option>
                <option value="women_same">女性同士向け</option>
                <option value="men_same">男性同士向け</option>
            </select>
        </div>
        <div class="f-group">
            <label class="f-label" for="reg-email">メールアドレス<span class="req">*</span></label>
            <input type="email" id="reg-email" class="f-input" placeholder="shop@example.com" autocomplete="email">
        </div>
        <div class="err-msg" id="email-err" role="alert" aria-live="polite"></div>
        <button class="btn-primary" id="send-btn">認証メールを送信する</button>
        <p class="note">※ 届いたメールのリンクをクリックすると次のステップに進みます。<br>迷惑メールフォルダもご確認ください。</p>
    </div>

    <div class="card" id="step-sent" style="display:none;">
        <div class="success-wrap">
            <div class="success-icon">&#128231;</div>
            <div class="success-title">メールを送信しました</div>
            <div class="success-sub">認証メールを送信しました。<br>メールのリンクをクリックして<br>登録を続けてください。<br><br><span class="note-small">迷惑メールフォルダもご確認ください。</span></div>
        </div>
    </div>

    <div class="card" id="step-form" style="display:none;">
        <div class="card-title">店舗情報入力</div>
        <div class="card-sub">審査後、メールにてご連絡いたします</div>
        <div class="steps"><div class="step-dot on"></div><div class="step-dot on"></div><div class="step-dot"></div></div>
        <div id="session-email-box" class="session-email-box" style="display:none;">
            <p class="session-email-label">貴店様のID（メールアドレス）</p>
            <p class="session-email-val" id="session-email-val"></p>
        </div>
        <div class="info-box">&#128203; 審査には通常2〜3営業日かかります。承認後にポータル画面への掲載が開始されます。<br>虚偽の情報や不正な書類は審査不通過となります。</div>
        <div class="f-group">
            <label class="f-label" for="shop-gender">店舗ジャンル<span class="req">*</span></label>
            <select id="shop-gender" class="f-input">
                <option value="men">男性向け（デリヘル）</option>
                <option value="women">女性向け（女性用風俗）</option>
                <option value="este">デリエステ</option>
                <option value="women_same">女性同士向け</option>
                <option value="men_same">男性同士向け</option>
            </select>
        </div>
        <div class="f-group">
            <label class="f-label" for="shop-name">店舗名<span class="req">*</span></label>
            <input type="text" id="shop-name" class="f-input" placeholder="例: エステート新宿">
            <div class="f-hint">※届出確認書に記載の名称を入力してください</div>
            <div class="f-err" id="err-shop-name" role="alert" aria-live="polite"></div>
        </div>
        <div class="f-group">
            <label class="f-label" for="shop-url">店舗URL<span class="req">*</span></label>
            <input type="url" id="shop-url" class="f-input" placeholder="https://...">
            <div class="f-err" id="err-shop-url" role="alert" aria-live="polite"></div>
        </div>
        <div class="f-group">
            <label class="f-label" for="shop-tel">電話番号<span class="req">*</span></label>
            <input type="tel" id="shop-tel" class="f-input" placeholder="00-0000-0000">
            <div class="f-err" id="err-shop-tel" role="alert" aria-live="polite"></div>
        </div>
        <div class="f-group">
            <label class="f-label" for="shop-pw">パスワード<span class="req">*</span></label>
            <input type="password" id="shop-pw" class="f-input" placeholder="8文字以上" autocomplete="new-password">
            <div class="f-err" id="err-shop-pw" role="alert" aria-live="polite"></div>
        </div>
        <div class="f-group">
            <label class="f-label" for="shop-pw2">パスワード（確認）<span class="req">*</span></label>
            <input type="password" id="shop-pw2" class="f-input" placeholder="もう一度入力" autocomplete="new-password">
            <label class="pw-toggle"><input type="checkbox" id="pw-toggle-check"> パスワードを表示</label>
            <div class="f-err" id="err-shop-pw2" role="alert" aria-live="polite"></div>
        </div>
        <div class="f-group">
            <label class="f-label" for="shop-doc">無店舗型性風俗特殊営業届出確認書<span class="req">*</span><span style="font-weight:400;color:var(--text-3);margin-left:8px;">（最大3枚）</span></label>
            <div class="file-zone" id="file-zone">
                <input type="file" id="shop-doc" accept="image/*" multiple>
                <div id="file-zone-inner">
                    <div class="file-zone-icon">&#128196;</div>
                    <div class="file-zone-label">タップまたはドラッグ&amp;ドロップで選択<br><span class="file-zone-hint">画像ファイル（JPG / PNG）最大3枚・各5MBまで</span></div>
                </div>
                <div id="file-preview-list" style="display:none;"></div>
            </div>
            <div class="f-err" id="err-shop-doc" role="alert" aria-live="polite"></div>
            <div id="upload-progress" style="display:none; margin-top:8px;">
                <div class="progress-bar-bg"><div id="upload-progress-bar" class="progress-bar-fill"></div></div>
                <div id="upload-progress-text" class="progress-text">読み込み中...</div>
            </div>
        </div>
        <div class="f-group" style="margin-top:16px;">
            <label style="display:flex;align-items:flex-start;gap:8px;cursor:pointer;font-size:13px;line-height:1.6;">
                <input type="checkbox" id="agree-terms" style="margin-top:4px;flex-shrink:0;">
                <span><a href="/terms.html" target="_blank" style="color:#b5627a;font-weight:600;">利用規約</a>および<a href="/terms.html" target="_blank" style="color:#b5627a;font-weight:600;">広告掲載規約</a>に同意する</span>
            </label>
        </div>
        <div class="err-msg" id="form-err" role="alert" aria-live="polite"></div>
        <button class="btn-primary" id="btn-confirm">確認画面へ進む</button>
    </div>

    <div class="card" id="step-confirm" style="display:none;">
        <div class="card-title">入力内容の確認</div>
        <div class="card-sub">以下の内容で登録します。よろしいですか？</div>
        <div class="steps"><div class="step-dot on"></div><div class="step-dot on"></div><div class="step-dot on"></div></div>
        <div id="confirm-body"></div>
        <div class="err-msg" id="confirm-err" role="alert" aria-live="polite"></div>
        <button class="btn-primary" id="submit-btn">登録する</button>
        <button class="btn-secondary" id="btn-back-form">&#8592; 修正する</button>
    </div>

    <div id="step-done" style="display:none;width:100%;max-width:480px;">
        <div class="steps"><div class="step-dot on"></div><div class="step-dot on"></div><div class="step-dot on"></div></div>
        <div class="done-hero">
            <div class="done-icon">&#9989;</div>
            <h2 class="done-title">登録が完了しました</h2>
            <p class="done-text">ご登録ありがとうございます。</p>
            <p class="done-text">現在、届出確認書の審査を行っております。</p>
            <p class="done-text">審査完了後、ご登録のメールアドレスに<br>管理画面のログインURLをお送りいたします。</p>
            <p class="done-note">審査には通常1〜3営業日かかります。<br>しばらくお待ちください。</p>
        </div>
        <div class="done-summary-card">
            <p class="done-summary-title">登録内容</p>
            <table id="done-summary" class="confirm-table"></table>
            <p class="done-summary-note">※この内容を控えとして保存してください。</p>
        </div>
    </div>

    <footer class="shop-footer">
        <nav class="footer-links" aria-label="フッターナビゲーション">
            <a href="/deli/">デリヘル専用</a><span>|</span>
            <a href="/jofu/">女性用風俗専用</a><span>|</span>
            <a href="/este/">デリエステ</a><span>|</span>
            <a href="/same-m/">同性利用専用</a><span>|</span>
            <a href="/deli/?tab=loveho">ラブホテル検索</a><span>|</span>
            <a href="/index.html">トップページ</a><span>|</span>
            <a href="/terms/">利用規約</a><span>|</span>
            <a href="/privacy/">プライバシーポリシー</a><span>|</span>
            <a href="/contact/">お問い合わせ</a>
        </nav>
        <p>&copy; 2026 YobuHo Check-In Partners All Rights Reserved.</p>
    </footer>
</BaseLayout>

<script is:inline>
const GENRE_LABELS={men:'男性向け（デリヘル）',women:'女性向け（女性用風俗）',men_same:'男性同士向け',women_same:'女性同士向け',este:'デリエステ'};
function detectGenre(){const p=new URLSearchParams(location.search);if(p.get('genre')&&GENRE_LABELS[p.get('genre')])return p.get('genre');const h=location.hostname;if(h.startsWith('deli.'))return'men';if(h.startsWith('jofu.'))return'women';if(h.startsWith('same.'))return'men_same';if(h.startsWith('este.'))return'este';try{const r=new URL(document.referrer);if(r.hostname.startsWith('deli.'))return'men';if(r.hostname.startsWith('jofu.'))return'women';if(r.hostname.startsWith('same.'))return'men_same';if(r.hostname.startsWith('este.'))return'este';const m=new URLSearchParams(r.search).get('mode');if(m&&GENRE_LABELS[m])return m;}catch(e){}const s=localStorage.getItem('shop_register_genre');if(s&&GENRE_LABELS[s])return s;return null;}
const _detectedGenre=detectGenre();if(_detectedGenre){document.addEventListener('DOMContentLoaded',()=>{const s=document.getElementById('shop-gender');if(s)s.value=_detectedGenre;const r=document.getElementById('reg-genre');if(r)r.value=_detectedGenre;});}
function showNotice(msg,d){d=d||3000;let el=document.getElementById('shop-notice-toast');if(!el){el=document.createElement('div');el.id='shop-notice-toast';el.style.cssText='position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#333;color:#fff;padding:12px 24px;border-radius:8px;z-index:99999;font-size:14px;max-width:90vw;text-align:center;opacity:0;transition:opacity .3s;';document.body.appendChild(el);}el.textContent=msg;el.style.opacity='1';clearTimeout(el._timer);el._timer=setTimeout(()=>{el.style.opacity='0';},d);}
let _selectedFiles=[];
function showStep(name){['email','sent','form','confirm','done'].forEach(s=>document.getElementById('step-'+s).style.display=(s===name)?'':'none');const el=document.getElementById('step-'+name);if(el)el.scrollIntoView({behavior:'smooth',block:'start'});}
function showErr(id,msg){const el=document.getElementById(id);if(!el)return;el.innerHTML=msg;el.style.display=msg?'block':'none';}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
let _verifiedEmail=null;
function displaySessionEmail(email){const box=document.getElementById('session-email-box');const val=document.getElementById('session-email-val');if(box&&val&&email){val.textContent=email;box.style.display='';}}
let _isResubmission=false;
function applyResubmission(shop){if(shop&&shop.status==='revision_required'){_isResubmission=true;document.getElementById('shop-name').value=shop.shop_name||'';document.getElementById('shop-gender').value=shop.gender_mode||'men';document.getElementById('shop-url').value=shop.shop_url||'';document.getElementById('shop-tel').value=shop.shop_tel||'';const ib=document.querySelector('.info-box');if(ib)ib.innerHTML='⚠️ <strong>登録内容に不備がありました。</strong><br>修正の上、再度ご申請ください。届出確認書の画像も再アップロードしてください。';}}
(async function init(){const p=new URLSearchParams(location.search);if(p.get('step')==='profile'&&p.get('token')){try{const res=await fetch('/api/verify-email-token.php?token='+encodeURIComponent(p.get('token')));const data=await res.json();if(data.valid&&data.email){_verifiedEmail=data.email;displaySessionEmail(data.email);if(data.existing_shop)applyResubmission(data.existing_shop);if(data.genre||_detectedGenre)document.getElementById('shop-gender').value=data.genre||_detectedGenre;showStep('form');return;} else{showErr('email-err',data.error||'認証に失敗しました。再度メールアドレスを入力してください。');}}catch(e){showErr('email-err','認証エラーが発生しました。');}showStep('email');}})();
function togglePwVis(show){const t=show?'text':'password';document.getElementById('shop-pw').type=t;document.getElementById('shop-pw2').type=t;}
function onFileSelect(input){if(!input.files.length)return;const at=['image/jpeg','image/png','image/gif','image/webp'];for(const f of input.files){if(_selectedFiles.length>=3){showFieldErr('file-zone','err-shop-doc','最大3枚までです');break;}if(!at.includes(f.type)){showFieldErr('file-zone','err-shop-doc','許可されていないファイル形式です。JPG, PNG, GIF, WebPのみ');continue;}if(f.size>5*1024*1024){showFieldErr('file-zone','err-shop-doc','ファイルサイズが5MBを超えています');continue;}_selectedFiles.push(f);clearFieldErr(document.getElementById('file-zone'));}input.value='';renderFilePreviews();}
function showUploadProgress(show){document.getElementById('upload-progress').style.display=show?'':'none';if(show){document.getElementById('upload-progress-bar').style.width='0%';document.getElementById('upload-progress-text').textContent='\u8aad\u307f\u8fbc\u307f\u4e2d...';}}
function updateUploadProgress(e){if(e.lengthComputable){const p=Math.round((e.loaded/e.total)*100);document.getElementById('upload-progress-bar').style.width=p+'%';document.getElementById('upload-progress-text').textContent=p+'%';}}
function renderFilePreviews(){const inner=document.getElementById('file-zone-inner');const list=document.getElementById('file-preview-list');if(!_selectedFiles.length){inner.style.display='';list.style.display='none';list.innerHTML='';return;}inner.style.display='none';list.style.display='';list.innerHTML=_selectedFiles.map((f,i)=>`<div class="file-preview-item" id="fp-${i}"><img id="fp-img-${i}" src="" alt=""><div class="file-info"><div class="file-name">📎 ${esc(f.name)}</div></div><button class="file-remove" onclick="removeFile(${i})" title="削除">✕</button></div>`).join('')+(_selectedFiles.length<3?`<div style="text-align:center;padding:12px;font-size:16px;font-weight:500;color:var(--rose);cursor:pointer;" onclick="document.getElementById('shop-doc').click()">＋ 画像を追加（あと${3-_selectedFiles.length}枚）</div>`:'');_selectedFiles.forEach((f,i)=>{const r=new FileReader();r.onload=(e)=>{const img=document.getElementById('fp-img-'+i);if(img)img.src=e.target.result;};r.readAsDataURL(f);});}
function removeFile(idx){_selectedFiles.splice(idx,1);renderFilePreviews();}
function showFieldErr(inputId,errId,msg){const i=document.getElementById(inputId);const e=document.getElementById(errId);if(i)i.classList.add('has-error');if(e){e.textContent=msg;e.style.display='block';}}
function clearFieldErr(el){if(!el)return;el.classList.remove('has-error');const e=el.parentElement?.querySelector('.f-err');if(e){e.textContent='';e.style.display='none';}}
function clearAllFieldErrs(){document.querySelectorAll('.has-error').forEach(el=>el.classList.remove('has-error'));document.querySelectorAll('.f-err').forEach(el=>{el.textContent='';el.style.display='none';});}
function goToConfirm(){showErr('form-err','');clearAllFieldErrs();const genre=document.getElementById('shop-gender').value;const name=document.getElementById('shop-name').value.trim();const url=document.getElementById('shop-url').value.trim();const tel=document.getElementById('shop-tel').value.trim();const pw=document.getElementById('shop-pw').value;const pw2=document.getElementById('shop-pw2').value;const docFiles=_selectedFiles.length?_selectedFiles:[];let hasErr=false;if(!name){showFieldErr('shop-name','err-shop-name','\u3053\u306e\u9805\u76ee\u306f\u5fc5\u9808\u3067\u3059');hasErr=true;}if(!url){showFieldErr('shop-url','err-shop-url','\u3053\u306e\u9805\u76ee\u306f\u5fc5\u9808\u3067\u3059');hasErr=true;}else if(!url.startsWith('https://')){showFieldErr('shop-url','err-shop-url','URL\u306f https:// \u3067\u59cb\u307e\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059');hasErr=true;}if(!tel){showFieldErr('shop-tel','err-shop-tel','\u3053\u306e\u9805\u76ee\u306f\u5fc5\u9808\u3067\u3059');hasErr=true;}if(!_isResubmission){if(!pw){showFieldErr('shop-pw','err-shop-pw','\u3053\u306e\u9805\u76ee\u306f\u5fc5\u9808\u3067\u3059');hasErr=true;}else if(pw.length<8){showFieldErr('shop-pw','err-shop-pw','\u30d1\u30b9\u30ef\u30fc\u30c9\u306f8\u6587\u5b57\u4ee5\u4e0a\u306b\u3057\u3066\u304f\u3060\u3055\u3044');hasErr=true;}if(!pw2){showFieldErr('shop-pw2','err-shop-pw2','\u3053\u306e\u9805\u76ee\u306f\u5fc5\u9808\u3067\u3059');hasErr=true;}else if(pw&&pw!==pw2){showFieldErr('shop-pw2','err-shop-pw2','\u30d1\u30b9\u30ef\u30fc\u30c9\u304c\u4e00\u81f4\u3057\u307e\u305b\u3093');hasErr=true;}}else if(pw){if(pw.length<8){showFieldErr('shop-pw','err-shop-pw','\u30d1\u30b9\u30ef\u30fc\u30c9\u306f8\u6587\u5b57\u4ee5\u4e0a\u306b\u3057\u3066\u304f\u3060\u3055\u3044');hasErr=true;}if(pw!==pw2){showFieldErr('shop-pw2','err-shop-pw2','\u30d1\u30b9\u30ef\u30fc\u30c9\u304c\u4e00\u81f4\u3057\u307e\u305b\u3093');hasErr=true;}}if(!docFiles.length){showFieldErr('file-zone','err-shop-doc','\u5c4a\u51fa\u78ba\u8a8d\u66f8\u306e\u753b\u50cf\u3092\u6dfb\u4ed8\u3057\u3066\u304f\u3060\u3055\u3044');hasErr=true;}if(!document.getElementById('agree-terms').checked){showErr('form-err','利用規約および広告掲載規約への同意が必要です');hasErr=true;}if(hasErr)return;function renderConfirm(imgDataUrls){let imgHtml=imgDataUrls.map(u=>'<img src="'+u+'" style="max-width:100px;max-height:80px;border-radius:4px;margin:4px 4px 0 0;object-fit:cover;">').join('');const namesHtml=docFiles.map(f=>esc(f.name)).join(', ');document.getElementById('confirm-body').innerHTML='<table class="confirm-table"><tr><th>\u30b8\u30e3\u30f3\u30eb</th><td>'+esc(GENRE_LABELS[genre]||genre)+'</td></tr><tr><th>\u5e97\u8217\u540d</th><td>'+esc(name)+'</td></tr><tr><th>URL</th><td>'+esc(url)+'</td></tr><tr><th>\u96fb\u8a71\u756a\u53f7</th><td>'+esc(tel)+'</td></tr><tr><th>\u30d1\u30b9\u30ef\u30fc\u30c9</th><td>'+'\u25cf'.repeat(pw.length)+'</td></tr><tr><th>\u5c4a\u51fa\u78ba\u8a8d\u66f8</th><td>'+namesHtml+'<div>'+imgHtml+'</div></td></tr></table>';showStep('confirm');}if(docFiles.length){showUploadProgress(true);Promise.all(docFiles.map(f=>new Promise((res)=>{const r=new FileReader();r.onload=(e)=>res(e.target.result);r.onerror=()=>res(null);r.readAsDataURL(f);}))).then(urls=>{showUploadProgress(false);renderConfirm(urls.filter(Boolean));});}else{renderConfirm([]);}}
async function submitRegistration(){showErr('confirm-err','');const btn=document.getElementById('submit-btn');btn.disabled=true;btn.textContent='送信中...';try{if(!_verifiedEmail)throw new Error('セッションが切れました。ページをリロードしてください。');const userEmail=_verifiedEmail;const genre=document.getElementById('shop-gender').value;const name=document.getElementById('shop-name').value.trim();const url=document.getElementById('shop-url').value.trim();const tel=document.getElementById('shop-tel').value.trim();const pw=document.getElementById('shop-pw').value;const docFiles=_selectedFiles.length?_selectedFiles:[];let documentUrls=[];for(const f of docFiles){try{const du=await new Promise((res,rej)=>{const r=new FileReader();r.onload=()=>res(r.result);r.onerror=()=>rej();r.readAsDataURL(f);});documentUrls.push(du);}catch(e){}}const payload={email:userEmail,shop_name:name,gender_mode:genre,shop_url:url||null,shop_tel:tel||null,document_url:documentUrls.length===1?documentUrls[0]:JSON.stringify(documentUrls)};if(pw)payload.password_hash=btoa(pw);const res=await fetch('/api/submit-shop.php',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const resData=await res.json();if(!res.ok||!resData.success)throw new Error('登録エラー: '+(resData.error||'不明なエラー'));try{await fetch('/api/send-mail.php',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({to:userEmail,subject:'【YobuHo】店舗登録を受付けました',body:'<div style="font-family:sans-serif;max-width:600px;margin:0 auto;padding:20px;"><h2 style="color:#b5627a;">YobuHo - 登録受付完了</h2><p>'+esc(name)+' 様</p><p>店舗登録を受付けました。</p><p>届出確認書の審査完了後、管理画面のログインURLをお送りいたします。</p><p>審査には通常1〜3営業日かかります。</p></div>'})});}catch(mailErr){}document.getElementById('done-summary').innerHTML='<tr><th>ジャンル</th><td>'+esc(GENRE_LABELS[genre]||genre)+'</td></tr><tr><th>店舗名</th><td>'+esc(name)+'</td></tr><tr><th>メール</th><td>'+esc(userEmail)+'</td></tr><tr><th>電話番号</th><td>'+esc(tel)+'</td></tr><tr><th>URL</th><td>'+esc(url)+'</td></tr>';showStep('done');}catch(e){showErr('confirm-err',e.message);btn.disabled=false;btn.textContent='登録する';}}
// Event listeners
document.addEventListener('DOMContentLoaded',()=>{
document.getElementById('send-btn').addEventListener('click',()=>{(async()=>{const email=document.getElementById('reg-email').value.trim();if(!email){showErr('email-err','メールアドレスを入力してください');return;}showErr('email-err','');const selectedGenre=document.getElementById('reg-genre').value;localStorage.setItem('shop_register_genre',selectedGenre);const btn=document.getElementById('send-btn');btn.disabled=true;btn.innerHTML='<span style="display:inline-flex;align-items:center;gap:8px;"><span style="display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,0.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;"></span>送信中...</span>';if(!document.getElementById('spin-style')){const s=document.createElement('style');s.id='spin-style';s.textContent='@keyframes spin{to{transform:rotate(360deg)}}';document.head.appendChild(s);}try{const res=await fetch('/api/send-email-token.php',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,genre:selectedGenre})});const data=await res.json();if(!res.ok||!data.success){btn.disabled=false;btn.textContent='認証メールを送信する';if(data.existing){showErr('email-err','このメールアドレスは既に登録済みです。<br><a href="/shop-admin.html" style="color:var(--rose);font-weight:700;">店舗管理画面からログイン →</a>');}else{showErr('email-err',data.error||'送信エラーが発生しました');}return;}showStep('sent');}catch(e){btn.disabled=false;btn.textContent='認証メールを送信する';showErr('email-err','通信エラーが発生しました');}})();});
document.getElementById('reg-email').addEventListener('keydown',(e)=>{if(e.key==='Enter')document.getElementById('send-btn').click();});
document.getElementById('pw-toggle-check').addEventListener('change',(e)=>{togglePwVis(e.target.checked);});
document.getElementById('file-zone').addEventListener('click',()=>{document.getElementById('shop-doc').click();});
document.getElementById('shop-doc').addEventListener('change',(e)=>{onFileSelect(e.target);});
['shop-name','shop-url','shop-tel','shop-pw','shop-pw2'].forEach(id=>{document.getElementById(id).addEventListener('input',function(){clearFieldErr(this);});});
document.getElementById('btn-confirm').addEventListener('click',goToConfirm);
document.getElementById('submit-btn').addEventListener('click',submitRegistration);
document.getElementById('btn-back-form').addEventListener('click',()=>{showStep('form');});
// Drag and drop
const dropArea=document.getElementById('file-zone');['dragenter','dragover','dragleave','drop'].forEach(e=>{dropArea.addEventListener(e,(ev)=>{ev.preventDefault();ev.stopPropagation();});});['dragenter','dragover'].forEach(e=>{dropArea.addEventListener(e,()=>{dropArea.classList.add('dragover');});});['dragleave','drop'].forEach(e=>{dropArea.addEventListener(e,()=>{dropArea.classList.remove('dragover');});});dropArea.addEventListener('drop',(e)=>{const files=e.dataTransfer.files;if(!files.length)return;const at=['image/jpeg','image/png','image/gif','image/webp'];for(const f of files){if(_selectedFiles.length>=3){showFieldErr('file-zone','err-shop-doc','最大3枚までです');break;}if(!at.includes(f.type)){showFieldErr('file-zone','err-shop-doc','許可されていないファイル形式です');continue;}if(f.size>5*1024*1024){showFieldErr('file-zone','err-shop-doc','ファイルサイズが5MBを超えています');continue;}_selectedFiles.push(f);clearFieldErr(document.getElementById('file-zone'));}renderFilePreviews();});
});
</script>

<style>
    :root {
        --gold: #c9a96e; --gold-dim: #a8894e; --gold-bg: rgba(201,169,110,0.08); --gold-border: rgba(201,169,110,0.25);
        --rose: #b5627a; --rose-dim: #9a4e65; --rose-bg: rgba(181,98,122,0.07); --rose-border: rgba(181,98,122,0.22);
        --bg: #f8f7f5; --bg-2: #ffffff; --bg-3: #f3f1ee;
        --border: #e8e4e0; --border-s: #d5d0cb;
        --text: #1a1a1a; --text-2: #666666; --text-3: #999999;
        --red: #c05050; --green: #2e8b57; --r: 10px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Noto Sans JP", sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 40px 20px 80px; }
    .logo { font-family: "Cormorant Garamond", serif; font-size: 22px; font-weight: 300; letter-spacing: 0.12em; color: var(--gold); margin-bottom: 10px; text-align: center; }
    .logo em { font-style: italic; font-weight: 600; }
    .logo-sub { font-size: 11px; color: var(--text-3); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 36px; text-align: center; }
    .card { background: var(--bg-2); border: 1px solid var(--border); border-radius: 16px; padding: 36px 32px; width: 100%; max-width: 480px; box-shadow: 0 8px 40px rgba(0,0,0,0.08); }
    .card-title { font-size: 19px; font-weight: 700; margin-bottom: 4px; }
    .card-sub { font-size: 12px; color: var(--text-3); margin-bottom: 28px; line-height: 1.6; }
    .steps { display: flex; gap: 6px; margin-bottom: 28px; }
    .step-dot { flex: 1; height: 6px; border-radius: 3px; background: var(--border); transition: background 0.3s; }
    .step-dot.on { background: var(--rose); }
    .f-group { margin-bottom: 18px; }
    .f-label { display: block; font-size: 12px; font-weight: 700; color: var(--text-3); margin-bottom: 8px; letter-spacing: 0.5px; text-transform: uppercase; }
    .f-label .req { color: var(--rose); margin-left: 2px; }
    .f-input { width: 100%; padding: 11px 14px; background: #fff; border: 1px solid var(--border); border-radius: var(--r); color: var(--text); font-family: inherit; font-size: 16px; outline: none; transition: border-color 0.2s; -webkit-appearance: none; }
    .f-input:focus { border-color: var(--rose); background: rgba(181,98,122,0.03); }
    .f-input::placeholder { color: var(--text-3); }
    select.f-input { cursor: pointer; }
    .f-hint { font-size: 12px; color: #888; margin-top: 5px; }
    .btn-primary { width: 100%; padding: 14px; background: var(--rose); border: none; border-radius: var(--r); color: #fff; font-family: inherit; font-size: 14px; font-weight: 700; cursor: pointer; letter-spacing: 0.8px; transition: background 0.2s, opacity 0.2s; margin-top: 16px; min-height: 48px; }
    .btn-primary:focus-visible { outline: 2px solid var(--rose); outline-offset: 2px; }
    .btn-primary:hover:not(:disabled) { background: var(--rose-dim); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-secondary { width: 100%; padding: 12px; background: transparent; border: 1px solid var(--border-s); border-radius: var(--r); color: var(--text-2); font-family: inherit; font-size: 13px; cursor: pointer; transition: border-color 0.2s; margin-top: 8px; min-height: 44px; }
    .btn-secondary:hover { border-color: var(--rose-border); color: var(--text); }
    .btn-secondary:focus-visible { outline: 2px solid var(--text-2); outline-offset: 2px; }
    .err-msg { display: none; font-size: 12px; color: var(--red); margin-top: 10px; padding: 9px 12px; background: rgba(192,80,80,0.1); border: 1px solid rgba(192,80,80,0.2); border-radius: 8px; }
    .info-box { background: var(--rose-bg); border: 1px solid var(--rose-border); border-radius: var(--r); padding: 14px 16px; font-size: 12px; color: var(--text-2); line-height: 1.75; margin-bottom: 22px; }
    .file-zone { border: 1.5px dashed var(--rose-border); border-radius: var(--r); padding: 24px 16px; min-height: 100px; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; background: var(--rose-bg); position: relative; }
    .file-zone:hover, .file-zone.dragover { border-color: var(--rose); background: rgba(181,98,122,0.10); }
    .file-zone input[type="file"] { display: none; }
    .file-zone-icon { font-size: 30px; margin-bottom: 6px; }
    .file-zone-label { font-size: 16px; color: var(--text-2); line-height: 1.6; font-weight: 500; }
    .file-zone-hint { font-size: 13px; color: var(--text-3); }
    .file-zone-name { font-size: 12px; color: var(--rose); margin-top: 8px; font-weight: 500; }
    .file-preview { margin-top: 10px; max-width: 100%; max-height: 180px; border-radius: 6px; object-fit: contain; }
    .file-preview-item { display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid var(--border); }
    .file-preview-item:last-child { border-bottom:none; margin-bottom:12px; }
    .file-preview-item img { width:60px; height:60px; object-fit:cover; border-radius:6px; flex-shrink:0; }
    .file-preview-item .file-info { flex:1; min-width:0; }
    .file-preview-item .file-name { font-size:12px; color:var(--rose); font-weight:500; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .file-preview-item .file-remove { background:none; border:1px solid rgba(192,80,80,0.3); border-radius:6px; color:var(--red); font-size:16px; cursor:pointer; padding:6px 12px; flex-shrink:0; min-width:44px; min-height:44px; display:flex; align-items:center; justify-content:center; }
    .pw-toggle { display: flex; align-items: center; gap: 8px; margin-top: 12px; cursor: pointer; font-size: 13px; color: var(--text-3); min-height: 44px; }
    .pw-toggle input { accent-color: var(--rose); cursor: pointer; width: 18px; height: 18px; margin: 0; }
    .confirm-table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
    .confirm-table th { text-align: left; font-size: 11px; color: var(--text-3); font-weight: 600; padding: 8px 4px 8px 0; border-bottom: 1px solid var(--border); width: auto; min-width: 72px; vertical-align: top; letter-spacing: 0.3px; white-space: nowrap; }
    .confirm-table td { font-size: 13px; padding: 8px 0 8px 12px; border-bottom: 1px solid var(--border); word-break: break-word; }
    .confirm-img { max-width: 100%; max-height: 160px; border-radius: 6px; margin-top: 4px; object-fit: contain; }
    .success-wrap { text-align: center; padding: 12px 0; }
    .success-icon { font-size: 54px; margin-bottom: 14px; }
    .success-title { font-size: 20px; font-weight: 700; margin-bottom: 10px; }
    .success-sub { font-size: 13px; color: var(--text-3); line-height: 1.9; }
    .note { font-size: 11px; color: var(--text-3); margin-top: 16px; line-height: 1.7; padding-top: 14px; border-top: 1px solid var(--border); }
    .note-small { font-size: 11px; }
    .f-err { font-size: 12px; color: var(--red); margin-top: 8px; display: none; }
    .f-input.has-error { border-color: var(--red) !important; }
    .file-zone.has-error { border-color: var(--red) !important; }
    .progress-bar-bg { background: #2a2a34; border-radius: 4px; height: 6px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: var(--gold); width: 0%; transition: width 0.2s; }
    .progress-text { font-size: 12px; color: var(--text-2); margin-top: 4px; }
    .session-email-box { background: var(--rose-bg); border: 1px solid var(--rose-border); padding: 12px 16px; border-radius: 10px; margin-bottom: 20px; }
    .session-email-label { margin: 0; font-size: 12px; color: var(--text-3); }
    .session-email-val { margin: 4px 0 0; font-size: 15px; font-weight: 700; color: var(--rose); }
    .pricing-section { width: 100%; max-width: 520px; margin-bottom: 32px; }
    .pricing-title { font-size: 20px; font-weight: 700; text-align: center; margin-bottom: 6px; }
    .pricing-sub { font-size: 12px; color: var(--text-3); text-align: center; margin-bottom: 20px; line-height: 1.7; }
    .merit-list { max-width: 480px; margin: 16px auto 0; text-align: left; display: flex; flex-direction: column; gap: 12px; }
    .merit-item { display: flex; align-items: flex-start; gap: 10px; }
    .merit-icon { font-size: 20px; flex-shrink: 0; }
    .merit-item strong { color: var(--gold-dim); }
    .merit-desc { font-size: 13px; color: var(--text-3); }
    .done-hero { text-align: center; padding: 40px 20px; }
    .done-icon { font-size: 48px; margin-bottom: 16px; }
    .done-title { font-size: 20px; font-weight: 700; margin-bottom: 0; }
    .done-text { color: var(--text-2); margin: 8px 0 0; }
    .done-note { color: var(--text-3); margin-top: 24px; font-size: 12px; }
    .done-summary-card { background: var(--bg-2); border: 1px solid var(--border); border-radius: 12px; padding: 24px 20px; margin-top: 8px; }
    .done-summary-title { font-size: 13px; font-weight: 700; margin-bottom: 14px; color: var(--text-2); }
    .done-summary-note { font-size: 11px; color: var(--text-3); margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--border); line-height: 1.7; }
    .shop-footer { background: var(--bg-3); padding: 20px 16px 12px; margin-top: 40px; text-align: center; font-size: 11px; line-height: 1.6; width: 100%; }
    .shop-footer .footer-links { display: flex; justify-content: center; align-items: center; gap: 12px; flex-wrap: wrap; }
    .shop-footer .footer-links a { color: var(--text-3); text-decoration: none; }
    .shop-footer .footer-links span { color: var(--border); }
    .shop-footer > p { margin: 8px 0 0; color: var(--text-3); }
    select.f-input { appearance: none; -webkit-appearance: none; -moz-appearance: none; background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23999' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e"); background-repeat: no-repeat; background-position: right 10px center; background-size: 18px; padding-right: 36px; }
    @media (max-width: 480px) {
        body { padding: 24px 12px 60px; }
        .card { padding: 24px 16px; }
        .card-title { font-size: 17px; }
        .f-label { font-size: 11px; margin-bottom: 6px; }
        .btn-primary { margin-top: 12px; }
        .done-icon { font-size: 40px; margin-bottom: 12px; }
        .done-hero { padding: 28px 16px; }
        .file-zone { padding: 20px 14px; }
    }
</style>
