---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';

const csp = "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; img-src 'self' data: https:;";

const plans = [
  { name: '無料プラン', price: '0', features: ['お店様の投稿に店名テキスト掲載','認証バッジ付与','お店様専用URL発行'], tag: 'まず無料で', color: '#888' },
  { name: '投稿リンクプラン', price: '5,500', features: ['お店様の投稿に店名リンク付き🔗','認証バッジ付与','お店様専用URL発行(専用デザイン)'], tag: '手軽に集客', color: '#6a8a5a' },
  { name: '市区町村プラン', price: '11,000', features: ['お店様の投稿に店名リンク付き🔗','認証バッジ付与','お店様専用URL発行(専用デザイン)','市区町村一覧にリッチ広告','指定市区町村のホテル詳細にリッチ広告','複数契約OK'], tag: '人気No.1', color: '#b5627a', limited: '各市区町村 先着3店様限定' },
  { name: 'エリアプラン', price: '33,000', features: ['お店様の投稿に店名リンク付き🔗','認証バッジ付与','お店様専用URL発行(専用デザイン)','エリア一覧にリッチ広告','該当ホテル詳細にもスタンダード広告表示','エリアをカバー','複数契約OK'], tag: '網羅プラン', color: '#b5627a', limited: '各エリア 先着3店様限定' },
  { name: 'ブロック(地域)プラン', price: '55,000', features: ['お店様の投稿に店名リンク付き🔗','認証バッジ付与','お店様専用URL発行(専用デザイン)','ブロック(地域)一覧にリッチ広告','該当ホテル詳細にもスタンダード広告表示','複数市区町村を一括カバー','複数契約OK'], tag: 'コスパ◎', color: '#c9a84c', limited: '各ブロック(地域) 先着3店様限定' },
  { name: '都道府県プラン', price: '77,000', features: ['お店様の投稿に店名リンク付き🔗','認証バッジ付与','お店様専用URL発行(専用デザイン)','都道府県一覧にリッチ広告','該当ホテル詳細にもスタンダード広告表示','都道府県全域をカバー','複数契約OK'], tag: '広域カバー', color: '#b5627a', limited: '各都道府県 先着3店様限定' },
  { name: '地方プラン', price: '110,000', features: ['お店様の投稿に店名リンク付き🔗','認証バッジ付与','お店様専用URL発行(専用デザイン)','地方一覧にリッチ広告','該当ホテル詳細にもスタンダード広告表示','地方全域をカバー','複数契約OK'], tag: 'エリア拡大', color: '#b5627a', limited: '各地方 先着3店様限定' },
  { name: '全国プラン', price: '165,000', features: ['お店様の投稿に店名リンク付き🔗','認証バッジ付与','お店様専用URL発行(専用デザイン)','全国トップにリッチ広告','全該当ホテル詳細にもスタンダード広告表示','43,000件以上の全ホテルに露出','最大リーチ'], tag: 'ブランド戦略', color: '#c9a84c', limited: '全国 先着3店様限定' },
];

const faqs = [
  { q: '本当に無料で始められますか？', a: 'はい。無料プランは初期費用・月額費用ともに0円です。お店様名テキスト掲載・認証バッジ・専用URLがすべて無料で利用できます。' },
  { q: '複数の地域に掲載できますか？', a: 'はい。同じプランを複数契約できます。例えば市区町村プランを3つ契約して、新宿区・渋谷区・港区の3エリアに同時掲載できます。' },
  { q: '掲載開始までどのくらいかかりますか？', a: '届出確認書の審査後、通常1〜2営業日で掲載開始です。※誠に恐れ入りますが、土日祝日・年末年始は審査対応をお休みさせていただいております。' },
  { q: '途中でプラン変更・解約はできますか？', a: 'はい。プランのアップグレード・ダウングレード・解約はいつでも可能です。' },
  { q: '1つのホテルに何店まで表示されますか？', a: '各市区町村・各エリア・各ブロック・各都道府県・各地方・全国、リッチ広告はそれぞれ最大3店様です。ただし、ホテルの所在地が複数エリアに関連する場合、それぞれのエリアの掲載店様が表示されるため、スタンダード広告が3店様を超える場合があります。' },
  { q: 'どんな業種が掲載できますか？', a: 'デリヘル、女性用風俗(女風)、デリエステ(回春マッサージ・M性感・風俗エステ)、同性向けサービスが掲載可能です。届出確認書が必要です。' },
];
---

<BaseLayout
  title="掲載プラン・料金 | YobuHo Check-In Partners"
  description="YobuHoの掲載プラン・料金一覧。全国43,000件以上のホテルに広告掲載。デリヘル・女性用風俗・デリエステの集客に。無料プランから始められます。"
  keywords="YobuHo 料金,掲載プラン,デリヘル 広告 料金,女風 広告 掲載,風俗 ホテル広告,デリエステ 広告,風俗 集客"
  canonical="https://yobuho.com/plan.html"
  ogTitle="掲載プラン・料金 | YobuHo"
  ogDescription="全国43,000件以上のホテル検索ポータルに広告掲載。無料プランから。"
  ogUrl="https://yobuho.com/plan.html"
  themeColor="#b5627a"
  csp={csp}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
  </Fragment>

  <PageHeader pageTitle="掲載プラン・料金" />

  <main class="plan-page">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-badge">広告掲載のご案内</div>
      <h1>お店様の情報を<br>43,000件以上のホテルに届ける</h1>
      <p class="hero-sub">YobuHoは、デリヘル・女性用風俗・デリエステ・同性同士のユーザーが<br>「呼べるホテル」を探す日本最大級の検索ポータルです</p>
      <div class="hero-stats">
        <div class="stat"><span class="stat-num">43,000<small>件+</small></span><span class="stat-label">掲載ホテル数</span></div>
        <div class="stat"><span class="stat-num">5<small>ジャンル</small></span><span class="stat-label">対応ジャンル</span></div>
        <div class="stat"><span class="stat-num">0<small>円〜</small></span><span class="stat-label">初期費用</span></div>
      </div>
    </section>

    <!-- Why YobuHo -->
    <section class="why-section">
      <h2 class="section-title">YobuHoに掲載するメリット</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🎯</div>
          <h3>ホテルを探しているユーザーに直接リーチ</h3>
          <p>「呼べるホテル」を検索しているユーザーに、ホテル詳細ページで直接お店様の情報を表示。「このホテルに呼べるの？」「ラブホに一人で入れるの？」<br>—初めての方はもちろん、すでにご利用中の方でも、ホテルが変われば不安は同じです。<br>YobuHoはそんな『誰にも聞けない疑問』を解決する情報源。お店様の実績が信頼となり、お客様の獲得からリピート利用まで自然とつながり高い集客効果が期待できます。</p>
        </div>
        <div class="why-card">
          <div class="why-icon">📊</div>
          <h3>口コミ実績がそのまま信頼に</h3>
          <p>ユーザー口コミだけでは「本当に呼べるの？」という不安が残ります。<strong>お店様が投稿いただいたご案内実績</strong>が広告に表示されることで、ユーザーの信頼度が格段にアップ。<strong>ご実績件数が多いほど各プラン内で上位表示</strong>されるため、投稿するほど集客力が高まります。</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🔗</div>
          <h3>お店様専用URLでブランディング</h3>
          <p>全プランでお店様専用URLを発行。お店様のオフィシャルサイトやSNSに設置すれば、そのまま集客導線として活用できます。<br><strong>専用ページにはお店様の口コミ実績だけを表示し、他店様の情報は一切表示されません。</strong><br>見やすく洗練されたページ設計で、<strong>お店様のイメージアップ</strong>にもお役に立てれば嬉しいです。</p>
        </div>
      </div>
    </section>

    <!-- Pricing Cards -->
    <section class="pricing-section">
      <h2 class="section-title">料金プラン</h2>
      <p class="section-sub">すべての有料プランでリッチ広告(サムネイル+お店様情報)を表示<br>複数エリアへの同時掲載も可能です</p>
      <div class="plan-grid">
        {plans.map((plan) => (
          <div class={`plan-card ${plan.tag ? 'plan-tagged' : ''}`} style={plan.tag ? `border-color:${plan.color}` : ''}>
            {plan.tag && <div class="plan-badge" style={`background:${plan.color}`}>{plan.tag}</div>}
            <div class="plan-name">{plan.name}</div>
            {plan.limited && <div class="limit-badge">{plan.limited}</div>}
            <div class="plan-price">
              <span class="plan-yen">&yen;</span><span class="plan-amount">{plan.price}</span><span class="plan-month">/月(税込)</span>
            </div>
            <ul class="plan-features">
              {plan.features.map((f) => <li>{f}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Ad Examples -->
    <section class="example-section">
      <h2 class="section-title">2つの広告フォーマット</h2>
      <p class="section-sub">プランに応じて最適なフォーマットで表示されます</p>
      <div class="example-grid">
        <div class="example-card example-premium">
          <div class="example-label">📌 リッチ広告</div>
          <div class="example-plan-tag"><strong>各プランの該当エリアページ上部に表示<br>市区町村プランはホテル詳細ページにも表示</strong></div>
          <div class="example-mock">
            <div class="mock-thumb">🖼</div>
            <div class="mock-info">
              <div class="mock-name-row"><span class="mock-name">お店様の名前</span><span class="mock-count">📋6件</span></div>
              <div class="mock-catch">キャッチコピー20文字</div>
              <div class="mock-desc">紹介文50文字以内</div>
              <div class="mock-bottom">
                <span class="mock-price">60分 10,000円〜</span>
                <span class="mock-hours">🕐 6:00〜翌4:30</span>
              </div>
            </div>
          </div>
          <p class="example-note">エリア一覧ページ・ホテル詳細ページの両方に表示。サムネイル画像・キャッチコピー・紹介文・料金・営業時間・対応件数(📋)を掲載。<strong>投稿実績が多いほど上位に表示</strong>されるため、積極的な情報提供が集客力に直結します。</p>
        </div>
        <div class="example-card example-standard">
          <div class="example-label">📌 スタンダード広告</div>
          <div class="example-plan-tag"><strong>エリア〜全国プラン / ホテル詳細ページ</strong></div>
          <div class="example-mock example-mock-std">
            <div class="mock-thumb-sm">🖼</div>
            <div class="mock-info">
              <div class="mock-name-row"><span class="mock-name">お店様の名前</span><span class="mock-count">📋6件</span></div>
              <div class="mock-desc-std">紹介文50文字以内で表示されます。2行まで表示可能です。</div>
            </div>
          </div>
          <p class="example-note">広いエリアのホテル詳細ページに表示。対応件数が表示されるため<strong>実績のあるお店様ほど信頼度UP</strong>。広域カバーで<strong>認知拡大に効果的</strong>です。</p>
        </div>
      </div>
      <div class="example-places-section">
        <h3 class="places-title">表示される場所</h3>
        <div class="example-places">
          <div class="place-item"><span class="place-dot" style="background:#b5627a"></span><strong>リッチ広告</strong> — 各プランの該当エリアページ上部 + ホテル詳細ページ(市区町村プラン)</div>
          <div class="place-item"><span class="place-dot" style="background:#c9a84c"></span><strong>スタンダード広告</strong> — ホテル詳細ページ内(エリア〜全国プラン)</div>
        </div>
        <p class="example-note" style="margin-top:8px;">上位プランほど広い範囲のホテルに表示され、より多くのユーザーにリーチします。各エリア内の表示順は、お店様からの情報提供数(ホテル口コミ・ラブホ口コミ)で決まります。投稿が多いほど上位に表示されます。</p>
      </div>
    </section>

    <!-- Brand Page -->
    <section class="brand-section">
      <h2 class="section-title">お店様専用URL</h2>
      <p class="section-sub">全プランでお店様専用URLを発行。有料プランではお店様専用URL発行(専用デザイン)にアップグレード。</p>
      <div class="brand-grid">
        <div class="brand-card">
          <div class="brand-label">無料プラン</div>
          <div class="brand-url">yobuho.com/deli/shop/your-slug/</div>
          <ul class="brand-features">
            <li>通常のポータルヘッダー・フッター</li>
            <li>ユーザー口コミ + 自店様情報を表示</li>
            <li>他店様の広告は非表示（自店様の情報だけ）</li>
            <li>各ホテルへの交通費も記載できます(未記載も可)</li>
            <li>自店様だけの専用ページとして活用</li>
            <li>オフィシャルサイトやSNSに設置可能</li>
          </ul>
        </div>
        <div class="brand-card brand-card-paid">
          <div class="brand-label-paid">有料プラン</div>
          <div class="brand-url">yobuho.com/deli/shop/your-slug/</div>
          <ul class="brand-features">
            <li><strong>ヘッダーにお店様名を表示</strong>（他ジャンルリンクなし）</li>
            <li><strong>簡易フッター</strong>（ポータルリンクなし）</li>
            <li>自店様だけの専用ページとして活用</li>
            <li>オフィシャルサイトやSNSに設置可能</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Comparison -->
    <section class="compare-section">
      <h2 class="section-title">プラン比較</h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr><th>プラン</th><th>月額</th><th>表示範囲</th><th>リッチ広告</th><th>ホテル詳細</th><th>複数契約</th><th>専用URL</th></tr>
          </thead>
          <tbody>
            <tr><td>無料</td><td>¥0</td><td>テキストのみ</td><td>-</td><td>-</td><td>-</td><td>通常</td></tr>
            <tr><td>投稿リンク</td><td>¥5,500</td><td>口コミ内リンク</td><td>-</td><td>-</td><td>-</td><td>オリジナル</td></tr>
            <tr><td>市区町村</td><td>¥11,000</td><td>指定市区町村</td><td>&#9745;</td><td>リッチ広告</td><td>&#9745;</td><td>オリジナル</td></tr>
            <tr><td>エリア</td><td>¥33,000</td><td>指定エリア</td><td>&#9745;</td><td>スタンダード</td><td>&#9745;</td><td>オリジナル</td></tr>
            <tr class="tr-highlight"><td>ブロック(地域)</td><td>¥55,000</td><td>指定ブロック(地域)</td><td>&#9745;</td><td>スタンダード</td><td>&#9745;</td><td>オリジナル</td></tr>
            <tr><td>都道府県</td><td>¥77,000</td><td>指定都道府県</td><td>&#9745;</td><td>スタンダード</td><td>&#9745;</td><td>オリジナル</td></tr>
            <tr><td>地方</td><td>¥110,000</td><td>指定地方</td><td>&#9745;</td><td>スタンダード</td><td>&#9745;</td><td>オリジナル</td></tr>
            <tr class="tr-highlight"><td>全国</td><td>¥165,000</td><td>全国</td><td>&#9745;</td><td>スタンダード</td><td>-</td><td>オリジナル</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <h2 class="section-title">よくある質問</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <div class="faq-item">
            <div class="faq-q">Q. {faq.q}</div>
            <div class="faq-a">{faq.a}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="cta-box">
        <h2>まずは無料で始めてみませんか？</h2>
        <p>無料プランなら初期費用・月額費用ともに0円。<br>お店様名掲載・認証バッジ・専用URLをすぐにご利用いただけます。</p>
        <a href="/shop-register.html" class="cta-btn">無料でお店様登録する &rarr;</a>
        <p class="cta-note">※有料プランへのアップグレードはいつでも可能です</p>
      </div>
    </section>
  </main>

  <Footer variant="full" />
</BaseLayout>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Noto Sans JP', sans-serif; background: #faf8f5; color: #1a1410; }
  .plan-page { max-width: 960px; margin: 0 auto; padding: 0 16px; }

  /* Hero */
  .hero { text-align: center; padding: 40px 16px 32px; }
  .hero-badge { display: inline-block; font-size: 12px; font-weight: 600; color: #b5627a; background: rgba(181,98,122,0.1); padding: 4px 16px; border-radius: 20px; margin-bottom: 16px; }
  .hero h1 { font-size: clamp(22px, 5vw, 32px); font-weight: 700; color: #1a1410; margin-bottom: 12px; line-height: 1.4; }
  .hero-sub { font-size: 14px; color: #5a4a3a; line-height: 1.8; }
  .hero-stats { display: flex; justify-content: center; gap: 24px; margin-top: 24px; flex-wrap: wrap; }
  .stat { text-align: center; }
  .stat-num { display: block; font-size: 28px; font-weight: 700; color: #b5627a; line-height: 1.2; }
  .stat-num small { font-size: 14px; font-weight: 500; }
  .stat-label { font-size: 11px; color: #8a7a6a; }

  /* Section common */
  .section-title { font-size: 20px; font-weight: 700; text-align: center; margin-bottom: 8px; color: #1a1410; }
  .section-sub { font-size: 13px; text-align: center; color: #8a7a6a; margin-bottom: 24px; line-height: 1.7; }
  .limit-badge { display: block; margin: 4px auto 8px; padding: 4px 16px; font-size: 13px; font-weight: 700; color: #c9a84c; background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.3); border-radius: 20px; text-align: center; width: fit-content; }

  /* Why */
  .why-section { padding: 32px 0; }
  .why-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
  @media (min-width: 640px) { .why-grid { grid-template-columns: repeat(3, 1fr); } }
  .why-card { background: #fff; border: 1px solid #e8e0d8; border-radius: 12px; padding: 24px 16px; text-align: center; }
  .why-icon { font-size: 32px; margin-bottom: 12px; }
  .why-card h3 { font-size: 14px; font-weight: 700; color: #1a1410; margin-bottom: 8px; line-height: 1.5; }
  .why-card p { font-size: 13px; color: #5a4a3a; line-height: 1.7; }

  /* Pricing cards */
  .pricing-section { padding: 32px 0; }
  .plan-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  @media (min-width: 640px) { .plan-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 900px) { .plan-grid { grid-template-columns: repeat(4, 1fr); } }
  .plan-card {
