---
import BaseLayout from './BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  pageTitle: string;
  description?: string;
  canonical?: string;
  robots?: string;
}

const { title, pageTitle, description, canonical, robots } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  robots={robots}
  ogTitle={title}
  themeColor="#b5627a"
>
    <Fragment slot="head">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="preload" as="style" data-font-async href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap">
        <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap"></noscript>
        <style>
            * { box-sizing: border-box; margin: 0; padding: 0; }
            body { font-family: 'Noto Sans JP', 'Noto Sans JP Fallback', system-ui, sans-serif; background: #faf8f4; color: #1a1410; line-height: 1.8; }
        </style>
    </Fragment>

    <PageHeader pageTitle={pageTitle} />
    <div class="content">
        <slot />
    </div>
    <Footer variant="full" />

    <script is:inline>
    (function(){
        var qs = new URLSearchParams(window.location.search);
        var shopSlug = qs.get('shop');
        if (!shopSlug) return;
        // 店舗情報を取得して該当ジャンルの店舗URLに書き換える
        fetch('/api/shop-info.php?slug=' + encodeURIComponent(shopSlug))
            .then(function(r){ return r.ok ? r.json() : null; })
            .then(function(d){
                if (!d) return;
                var modePathMap = {men:'/deli/',women:'/jofu/',men_same:'/same-m/',women_same:'/same-f/',este:'/este/'};
                var shopUrl = (modePathMap[d.gender_mode] || '/deli/') + 'shop/' + encodeURIComponent(d.slug || shopSlug) + '/';
                // フッターのトップページリンクを店舗ページに置換
                document.querySelectorAll('footer a[href="/index.html"]').forEach(function(a){
                    a.setAttribute('href', shopUrl);
                    a.textContent = '店舗ページに戻る';
                });
                // 法的ページ間の遷移にもshop param保持
                ['/terms/','/privacy/','/contact/'].forEach(function(p){
                    document.querySelectorAll('footer a[href="'+p+'"]').forEach(function(a){
                        a.setAttribute('href', p + '?shop=' + encodeURIComponent(shopSlug));
                    });
                });
                // ヘッダーの「全国へ」ボタン等も店舗ページに
                document.querySelectorAll('a[href="/index.html"]').forEach(function(a){
                    if (a.closest('footer')) return;
                    a.setAttribute('href', shopUrl);
                });
            }).catch(function(){});
    })();
    </script>
</BaseLayout>

<style>
    .content { max-width: 720px; margin: 0 auto; padding: 32px 20px 40px; }
</style>
