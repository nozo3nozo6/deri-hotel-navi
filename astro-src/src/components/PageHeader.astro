---
interface Props {
  pageTitle: string;
}
const { pageTitle } = Astro.props;
---

<div class="page-header">
    <a href="/index.html" class="btn-back">← トップへ</a>
    <span class="page-header-logo">YobuHo</span>
    <span class="page-header-title">{pageTitle}</span>
</div>

<style>
    .page-header { background: #1a1410; padding: 12px 20px; display: flex; align-items: center; gap: 12px; }
    .btn-back { display: inline-flex; align-items: center; gap: 4px; padding: 6px 14px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; color: #e0d5c8; font-size: 12px; text-decoration: none; cursor: pointer; font-family: inherit; }
    .btn-back:hover { background: rgba(255,255,255,0.2); }
    .page-header-logo { font-size: 16px; font-weight: 700; color: #c9a84c; letter-spacing: 0.08em; }
    .page-header-title { font-size: 14px; font-weight: 500; color: #fff; margin-left: auto; }
</style>
