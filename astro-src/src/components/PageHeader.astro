---
interface Props {
  pageTitle: string;
}
const { pageTitle } = Astro.props;
---

<header class="site-header">
    <div class="site-header-accent"></div>
    <div class="site-header-inner">
        <a href="/index.html" class="site-header-back">← トップへ</a>
        <a href="/index.html" class="site-header-logo"><b>YobuHo</b></a>
        <span class="site-header-title">{pageTitle}</span>
    </div>
</header>

<style>
    .site-header {
        background: rgba(250,248,244,0.97);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid #e8e0d8;
        position: sticky;
        top: 0;
        z-index: 100;
    }
    .site-header-accent {
        height: 2px;
        background: linear-gradient(90deg, transparent, #b5627a 20%, #d4899e 50%, #b5627a 80%, transparent);
    }
    .site-header-inner {
        max-width: 960px;
        margin: 0 auto;
        padding: 10px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .site-header-back {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        background: rgba(181,98,122,0.08);
        border: 1px solid rgba(181,98,122,0.2);
        border-radius: 6px;
        color: #b5627a;
        font-size: 12px;
        text-decoration: none;
        font-family: inherit;
        white-space: nowrap;
    }
    .site-header-back:hover { background: rgba(181,98,122,0.15); }
    .site-header-logo {
        font-size: 18px;
        font-weight: 700;
        color: #b5627a;
        text-decoration: none;
        letter-spacing: 0.05em;
    }
    .site-header-title {
        font-size: 13px;
        font-weight: 500;
        color: #5a4a3a;
        margin-left: auto;
    }
    @media (max-width: 480px) {
        .site-header-back { font-size: 11px; padding: 4px 8px; }
        .site-header-logo { font-size: 15px; }
        .site-header-title { font-size: 11px; }
    }
</style>
